    images, edge_generator, coarse_generator, fine_generator, refinement_network,\n","            discriminator, edge_optimizer, g_optimizer, refine_optimizer, d_optimizer, scaler\n","        )\n","        epoch_g_loss += g_loss_b; epoch_d_loss += d_loss_b; epoch_edge_loss += edge_loss_b; epoch_refine_loss += refine_loss_b; num_batches += 1\n","\n","        if step % 50 == 0:\n","            print(f\" Step {step:3d}: Edge={edge_loss_b:.4f}, G={g_loss_b:.4f}, Refine={refine_loss_b:.4f}, D={d_loss_b:.4f}\")\n","\n","        if np.isnan(g_loss_b) and np.isnan(d_loss_b):\n","            print(f\"⚠️ CRITICAL: NaN losses at step {step}.\"); break\n","\n","    avg_g_loss = epoch_g_loss / num_batches; avg_d_loss = epoch_d_loss / num_batches\n","    train_g_losses.append(avg_g_loss); train_d_losses.append(avg_d_loss)\n","    print(f\"Epoch {epoch+1} Train - Edge: {epoch_edge_loss/num_batches:.4f}, G: {avg_g_loss:.4f}, Refine: {epoch_refine_loss/num_batches:.4f}, D: {avg_d_loss:.4f}\")\n","\n","    # Validation\n","    edge_generator.eval(); coarse_generator.eval(); fine_generator.eval(); refinement_network.eval(); discriminator.eval()\n","    val_g_loss = val_d_loss = val_batches = 0\n","    with torch.no_grad():\n","        for images in val_loader:\n","            images = images.to(device); masks = generate_adaptive_mask(images); masked_images = images * masks\n","            edge_map = edge_generator(masked_images, masks)\n","            coarse_output, mu, logvar = coarse_generator(masked_images, masks, edge_map)\n","            if coarse_output.shape != images.shape: coarse_output = F.interpolate(coarse_output, size=images.shape[2:], mode='bilinear', align_corners=False)\n","            fine_output = fine_generator(masked_images, coarse_output, masks, edge_map)\n","            if fine_output.shape != images.shape: fine_output = F.interpolate(fine_output, size=images.shape[2:], mode='bilinear', align_corners=False)\n","            blend_masks = make_blend_mask(masks)\n","            refined_output = refinement_network(images * blend_masks + fine_output * (1.0 - blend_masks), masks)\n","            \n","            disc_real_logits, disc_features_real = discriminator(images, masks, return_features=True)\n","            disc_fake_logits, disc_features_fake = discriminator(refined_output, masks, return_features=True)\n","            val_g_loss += generator_loss(disc_fake_logits, images, refined_output, disc_features_real, disc_features_fake, masks, mu, logvar).item()\n","            val_d_loss += discriminator_loss(disc_real_logits, disc_fake_logits).item()\n","            val_batches += 1\n","\n","    avg_val_g_loss = val_g_loss / val_batches; avg_val_d_loss = val_d_loss / val_batches\n","    val_g_losses.append(avg_val_g_loss); val_d_losses.append(avg_val_d_loss)\n","    print(f\"Epoch {epoch+1} Val - G: {avg_val_g_loss:.4f}, D: {avg_val_d_loss:.4f}\")\n","\n","    edge_scheduler.step(avg_val_g_loss); g_scheduler.step(avg_val_g_loss); refine_scheduler.step(avg_val_g_loss); d_scheduler.step(avg_val_d_loss)\n","\n","    if avg_val_g_loss < best_val_loss:\n","        best_val_loss = avg_val_g_loss\n","        print(f\"🏆 New best val loss! Saving models...\")\n","        os.makedirs('/kaggle/working/models', exist_ok=True)\n","        torch.save(edge_generator.state_dict(), \"/kaggle/working/models/edge_generator_best.pth\")\n","        torch.save(coarse_generator.state_dict(), \"/kaggle/working/models/coarse_generator_best.pth\")\n","        torch.save(fine_generator.state_dict(), \"/kaggle/working/models/fine_generator_best.pth\")\n","        torch.save(refinement_network.state_dict(), \"/kaggle/working/models/refinement_network_best.pth\")\n","        torch.save(discriminator.state_dict(), \"/kaggle/working/models/discriminator_best.pth\")\n","\n","    if (epoch + 1) == num_epochs:\n","        print(f\"\\n💾 SAVING FINAL CHECKPOINT...\")\n","        checkpoint = {\n","            'epoch': epoch, 'edge_generator': edge_generator.state_dict(), 'coarse_generator': coarse_generator.state_dict(),\n","            'fine_generator': fine_generator.state_dict(), 'refinement_network': refinement_network.state_dict(), 'discriminator': discriminator.state_dict(),\n","            'edge_optimizer': edge_optimizer.state_dict(), 'g_optimizer': g_optimizer.state_dict(), \n","            'refine_optimizer': refine_optimizer.state_dict(), 'd_optimizer': d_optimizer.state_dict(),\n","            'best_val_loss': best_val_loss, 'train_g_losses': train_g_losses, 'train_d_losses': train_d_losses,\n","        }\n","        torch.save(checkpoint, os.path.join(CHECKPOINT_DIR, 'latest_checkpoint.pth'))\n","\n","    if (epoch + 1) % 5 == 0:\n","        plt.figure(figsize=(12, 4))\n","        plt.subplot(1, 2, 1); plt.plot(train_g_losses, label='G'); plt.plot(val_g_losses, label='Val G'); plt.legend(); plt.title('G Loss')\n","        plt.subplot(1, 2, 2); plt.plot(train_d_losses, label='D'); plt.plot(val_d_losses, label='Val D'); plt.legend(); plt.title('D Loss')\n","        plt.tight_layout(); plt.savefig(f'/kaggle/working/training_progress_epoch_{epoch+1}.png', dpi=150); plt.show()\n","\n","# Save final\n","print(\"Saving final models...\")\n","torch.save(edge_generator.state_dict(), \"/kaggle/working/models/edge_generator_bottom_half.pth\")\n","torch.save(coarse_generator.state_dict(), \"/kaggle/working/models/coarse_generator_bottom_half.pth\")\n","torch.save(fine_generator.state_dict(), \"/kaggle/working/models/fine_generator_bottom_half.pth\")\n","torch.save(refinement_network.state_dict(), \"/kaggle/working/models/refinement_network_bottom_half.pth\")\n","torch.save(discriminator.state_dict(), \"/kaggle/working/models/discriminator_bottom_half.pth\")\n","\n","\n","# ============================================================================\n","# EVALUATION (COMPLETE)\n","# ============================================================================\n","print(\"Starting evaluation on test set...\")\n","os.makedirs('/kaggle/working/results', exist_ok=True)\n","edge_generator.eval(); coarse_generator.eval(); fine_generator.eval(); refinement_network.eval(); discriminator.eval()\n","\n","psnr_values, ssim_values, mse_values, identity_values, landmark_values = [], [], [], [], []\n","num_samples = 10\n","\n","plt.figure(figsize=(20, 12))\n","with torch.no_grad():\n","    for i, images in enumerate(test_loader):\n","        if i >= num_samples: break\n","        images = images.to(device)\n","        masks = generate_adaptive_mask(images)\n","        masked_images = images * masks\n","\n","        # Full pipeline: Edge → Coarse → Fine → Blend → Refinement\n","        edge_map = edge_generator(masked_images, masks)\n","        coarse_output, mu, logvar = coarse_generator(masked_images, masks, edge_map)\n","        if coarse_output.shape != images.shape:\n","            coarse_output = F.interpolate(coarse_output, size=images.shape[2:], mode='bilinear', align_corners=False)\n","\n","        fine_output = fine_generator(masked_images, coarse_output, masks, edge_map)\n","        if fine_output.shape != images.shape:\n","            fine_output = F.interpolate(fine_output, size=images.shape[2:], mode='bilinear', align_corners=False)\n","\n","        blend_masks = make_blend_mask(masks)\n","        blended = images * blend_masks + fine_output * (1.0 - blend_masks)\n","        reconstructed = refinement_network(blended, masks)\n","\n","        # Calculate metrics\n","        psnr_val = calculate_psnr_bottom_half(images, reconstructed, masks).item()\n","        ssim_val = calculate_ssim_bottom_half(images, reconstructed, masks).item()\n","        mse_val = calculate_mse_bottom_half(images, reconstructed, masks).item()\n","        identity_val = identity_loss(images, reconstructed, masks).item()\n","        landmark_val = landmark_guided_loss(images, reconstructed, masks).item()\n","\n","        psnr_values.append(psnr_val); ssim_values.append(ssim_val); mse_values.append(mse_val)\n","        identity_values.append(identity_val); landmark_values.append(landmark_val)\n","\n","        # Plotting progression: Original, Input, Coarse, Fine, Refined, Diff\n","        plt.subplot(6, num_samples, i + 1)\n","        plt.title(\"Original\"); plt.imshow(images[0].permute(1, 2, 0).cpu().numpy() * 0.5 + 0.5); plt.axis(\"off\")\n","\n","        plt.subplot(6, num_samples, num_samples + i + 1)\n","        plt.title(\"Masked\"); plt.imshow(masked_images[0].permute(1, 2, 0).cpu().numpy() * 0.5 + 0.5); plt.axis(\"off\")\n","\n","        plt.subplot(6, num_samples, 2*num_samples + i + 1)\n","        plt.title(\"Coarse\"); plt.imshow(coarse_output[0].permute(1, 2, 0).cpu().numpy() * 0.5 + 0.5); plt.axis(\"off\")\n","\n","        plt.subplot(6, num_samples, 3*num_samples + i + 1)\n","        plt.title(\"Fine\"); plt.imshow(fine_output[0].permute(1, 2, 0).cpu().numpy() * 0.5 + 0.5); plt.axis(\"off\")\n","\n","        plt.subplot(6, num_samples, 4*num_samples + i + 1)\n","        plt.title(\"Refined\"); plt.imshow(reconstructed[0].permute(1, 2, 0).cpu().numpy() * 0.5 + 0.5); plt.axis(\"off\")\n","\n","        diff = torch.abs(images - reconstructed) * (1 - masks)\n","        plt.subplot(6, num_samples, 5*num_samples + i + 1)\n","        plt.title(\"Diff\"); plt.imshow(diff[0].permute(1, 2, 0).cpu().numpy() * 0.5 + 0.5, cmap='hot'); plt.axis(\"off\")\n","\n","        print(f\"Sample {i+1}: PSNR={psnr_val:.4f}, SSIM={ssim_val:.4f}, MSE={mse_val:.4f}\")\n","\n","plt.tight_layout()\n","plt.savefig('/kaggle/working/results/bottom_half_reconstruction_results.png', dpi=150, bbox_inches='tight')\n","plt.show()\n","\n","# Plot metrics\n","plt.figure(figsize=(20, 5))\n","plt.subplot(1, 3, 1); plt.plot(range(1, num_samples + 1), psnr_values, marker='o'); plt.title(\"PSNR\"); plt.grid(True, alpha=0.3)\n","plt.subplot(1, 3, 2); plt.plot(range(1, num_samples + 1), ssim_values, marker='s', color='orange'); plt.title(\"SSIM\"); plt.grid(True, alpha=0.3)\n","plt.subplot(1, 3, 3); plt.plot(r