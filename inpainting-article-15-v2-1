   Models  → /kaggle/working/models/\n","   Results → /kaggle/working/results/\n"]}],"source":["\"\"\"\n","Image Inpainting - Multi-Stage GAN (Edge → Coarse → Fine)\n","==========================================================\n","نسخه ۳ — اصلاح‌شده:\n","  • PyramidalGNN و networkx کاملاً حذف شدند\n","  • ViTPreprocessor اکنون attention کامل بدون pruning روی همه پچ‌ها اجرا می‌کند\n","  • تابع retrain() و بلوک epoch%10 حذف شدند\n","  • گراف‌سازی O(n²) CPU حذف شد\n","\"\"\"\n","\n","# ── استاندارد ──────────────────────────────────────────────────────────────────\n","import os\n","import random\n","\n","os.environ.setdefault(\"TORCH_CUDA_ARCH_LIST\", \"7.5\")  # سازگاری با Kaggle GPU\n","\n","# ── Third-party ────────────────────────────────────────────────────────────────\n","import cv2\n","import numpy as np\n","import matplotlib.pyplot as plt\n","from PIL import Image\n","from skimage.metrics import peak_signal_noise_ratio as psnr\n","from skimage.metrics import structural_similarity as ssim\n","\n","import torch\n","import torch.nn as nn\n","import torch.nn.functional as F\n","import torchvision.models as models\n","import torchvision.transforms as transforms\n","from torch import amp\n","from torch.utils.data import Dataset, DataLoader\n","\n","# ── MTCNN (اختیاری) ────────────────────────────────────────────────────────────\n","try:\n","    from mtcnn import MTCNN\n","    USE_MTCNN = False   # در طول آموزش غیرفعال می‌ماند\n","    print(\"MTCNN imported successfully (disabled during training).\")\n","except ImportError:\n","    print(\"MTCNN not found — landmark loss will fall back to bottom-half MSE.\")\n","    USE_MTCNN = False\n","\n","# ══════════════════════════════════════════════════════════════════════════════\n","# ۱. تنظیمات Checkpoint\n","# ══════════════════════════════════════════════════════════════════════════════\n","\n","RESUME_TRAINING      = True\n","CHECKPOINT_DIR       = \"/kaggle/working/checkpoints\"\n","CHECKPOINT_INTERVAL  = 1          # ذخیره هر N epoch\n","\n","USE_KAGGLE_INPUT     = True\n","KAGGLE_INPUT_DATASET = (\n","    \"/kaggle/input/models/masoudshahrian/image-inpainting-v1/pytorch/default/17\"\n",")\n","\n","LOAD_FROM_MODELS = True\n","MODELS_DIR       = \"/kaggle/working/models\"\n","USE_BEST_MODELS  = True\n","\n","print(\"=\" * 70)\n","print(\"🔧 CHECKPOINT CONFIGURATION\")\n","print(\"=\" * 70)\n","print(f\"📌 Resume Training  : {RESUME_TRAINING}\")\n","print(f\"📁 Checkpoint Dir   : {CHECKPOINT_DIR}\")\n","print(f\"💾 Save Interval    : every {CHECKPOINT_INTERVAL} epoch(s)\")\n","if USE_KAGGLE_INPUT:\n","    print(f\"📥 Kaggle Dataset   : {KAGGLE_INPUT_DATASET}\")\n","if LOAD_FROM_MODELS:\n","    suffix = \"*_best.pth\" if USE_BEST_MODELS else \"*_bottom_half.pth\"\n","    print(f\"🗂️  Models Dir       : {MODELS_DIR}  ({suffix})\")\n","print(\"=\" * 70 + \"\\n\")\n","\n","# ══════════════════════════════════════════════════════════════════════════════\n","# ۲. هایپرپارامترها\n","# ══════════════════════════════════════════════════════════════════════════════\n","\n","image_size       = (64, 64)\n","batch_size       = 128\n","eval_batch_size  = 1\n","num_epochs       = 1\n","\n","learning_rate_g  = 5e-5\n","learning_rate_d  = 2e-4\n","\n","lambda_adv       = 0.5\n","lambda_l1        = 50.0\n","lambda_style     = 0.05\n","lambda_fm        = 0.05\n","lambda_rec       = 1.0\n","lambda_identity  = 0.005\n","lambda_landmark  = 0.01\n","lambda_perc      = 0.1\n","lambda_vae       = 0.01\n","lambda_struct    = 0.05\n","lambda_d_reg     = 1e-4\n","lambda_attention = 0.05\n","lambda_gp        = 10.0\n","lambda_edge      = 0.7\n","lambda_hf        = 0.5\n","lambda_gradient  = 0.6\n","lambda_facial    = 0.8\n","\n","n_critic         = 2   # تعداد آپدیت Discriminator به ازای هر Generator\n","\n","device = torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\n","print(f\"Using device: {device}\")\n","\n","# ══════════════════════════════════════════════════════════════════════════════\n","# ۳. Dataset\n","# ══════════════════════════════════════════════════════════════════════════════\n","\n","def split_dataset(dataset_path, train_ratio=0.8, val_ratio=0.1, test_ratio=0.1, seed=42):\n","    random.seed(seed)\n","    np.random.seed(seed)\n","    torch.manual_seed(seed)\n","\n","    image_files = [\n","        f for f in os.listdir(dataset_path)\n","        if f.lower().endswith((\".png\", \".jpg\", \".jpeg\"))\n","    ]\n","    random.shuffle(image_files)\n","    n = len(image_files)\n","    t = int(n * train_ratio)\n","    v = t + int(n * val_ratio)\n","\n","    train_f, val_f, test_f = image_files[:t], image_files[t:v], image_files[v:]\n","    print(\n","        f\"Dataset split  Total={n}  \"\n","        f\"Train={len(train_f)} ({len(train_f)/n*100:.1f}%)  \"\n","        f\"Val={len(val_f)} ({len(val_f)/n*100:.1f}%)  \"\n","        f\"Test={len(test_f)} ({len(test_f)/n*100:.1f}%)\"\n","    )\n","    return train_f, val_f, test_f\n","\n","\n","class CelebADataset(Dataset):\n","    def __init__(self, dataset_path, file_list, image_size, augment=True):\n","        self.dataset_path = dataset_path\n","        self.file_list    = file_list\n","\n","        base = [\n","            transforms.Resize(image_size),\n","            transforms.ToTensor(),\n","            transforms.Normalize(mean=[0.5, 0.5, 0.5], std=[0.5, 0.5, 0.5]),\n","        ]\n","        aug = [transforms.RandomHorizontalFlip(p=0.5), transforms.RandomRotation(10)]\n","        self.transform = transforms.Compose((aug + base) if augment else base)\n","\n","    def __len__(self):\n","        return len(self.file_list)\n","\n","    def __getitem__(self, idx):\n","        img = Image.open(os.path.join(self.dataset_path, self.file_list[idx])).convert(\"RGB\")\n","        return self.transform(img)\n","\n","\n","def create_split_datasets(dataset_path, train_files, val_files, test_files, image_size, batch_size):\n","    train_ds = CelebADataset(dataset_path, train_files, image_size, augment=True)\n","    val_ds   = CelebADataset(dataset_path, val_files,   image_size, augment=False)\n","    test_ds  = CelebADataset(dataset_path, test_files,  image_size, augment=False)\n","\n","    kw = dict(num_workers=2, pin_memory=True)\n","    train_loader = DataLoader(train_ds, batch_size=batch_size,      shuffle=True,  **kw)\n","    val_loader   = DataLoader(val_ds,   batch_size=batch_size,      shuffle=False, **kw)\n","    test_loader  = DataLoader(test_ds,  batch_size=eval_batch_size, shuffle=False, **kw)\n","    return train_loader, val_loader, test_loader\n","\n","# ══════════════════════════════════════════════════════════════════════════════\n","# ۴. ViTPreprocessor — بدون Graph/Pruning\n","# ══════════════════════════════════════════════════════════════════════════════\n","\n","class ViTPreprocessor(nn.Module):\n","    \"\"\"\n","    Patch-based ViT preprocessor.\n","    تغییر نسبت به نسخه قبل:\n","      - PyramidalGNN حذف شد\n","      - Graph-building / pruning / reconstruct حذف شد\n","      - Attention روی همه پچ‌ها به‌طور کامل اجرا می‌شود\n","    \"\"\"\n","\n","    def __init__(self, dim: int = 128, num_heads: int = 8,\n","                 patch_size: int = 8, num_layers: int = 3):\n","        super().__init__()\n","        self.patch_size  = patch_size\n","        self.dim         = dim\n","        self.num_patches = (image_size[0] // patch_size) * (image_size[1] // patch_size)\n","\n","        self.patch_embed = nn.Conv2d(3, dim, kernel_size=patch_size, stride=patch_size)\n","        self.pos_embed   = nn.Parameter(torch.zeros(1, self.num_patches, dim))\n","\n","        self.blocks = nn.ModuleList([\n","            nn.ModuleDict({\n","                \"attn\":  nn.MultiheadAttention(embed_dim=dim, num_heads=num_heads,\n","                                               dropout=0.1, batch_first=True),\n","                \"norm1\": nn.LayerNorm(dim, eps=1e-6),\n","                \"norm2\": nn.LayerNorm(dim, eps=1e-6),\n","                \"mlp\":   nn.Sequential(\n","                    nn.Linear(dim, dim * 4),\n","                    nn.GELU(),\n","                    nn.Dropout(0.1),\n","                    nn.Linear(dim * 4, dim),\n","                    nn.Dropout(0.1),\n","                ),\n","            })\n","            for _ in range(num_layers)\n","        ])\n","        self.final_norm = nn.LayerNorm(dim, eps=1e-6)\n","\n","        nn.init.trunc_normal_(self.pos_embed, std=0.02)\n","\n","    def forward(self, x: torch.Tensor) -> torch.Tensor:\n","        # x: [B, 3, H, W]\n","        emb = self.patch_embed(x)          # [B, dim, H/p, W/p]\n","        B, C, H, W = emb.shape\n","        tokens = emb.permute(0, 2, 3, 1).reshape(B, H * W, C)   # [B, n, dim]\n","\n","        # موقعیت embedding — adaptive اگر اندازه پچ با پیش‌فرض فرق داشت\n","        n = H * W\n","        if n != self.num_patches:\n","            pe = F.interpolate(\n","                self.pos_embed.permute(0, 2, 1),   # [1, dim, num_patches]\n","                size=n, mode=\"linear\", align_corners=False,\n","            ).permute(0, 2, 1)                     # [1, n, dim]\n","        else:\n","            pe = self.pos_embed\n","\n","        tokens = tokens + pe\n","\n","        # Transformer blocks — روی همه پچ‌ها بدون حذف\n","        for blk in self.blocks:\n","            attn_out, _ = blk[\"attn\"](tokens, tokens, tokens)\n","            tokens = blk[\"norm1\"](tokens + attn_out)\n","            tokens = blk[\"norm2\"](tokens + blk[\"mlp\"](tokens))\n","\n","        tokens = self.final_norm(tokens)   # [B, n, dim]\n","        return tokens.reshape(B, H, W, C).permute(0, 3, 1, 2)  # [B, dim, H, W]\n","\n","# ══════════════════════════════════════════════════════════════════════════════\n","# ۵. VAE Encoder / Sampling / Decoder\n","# ══════════════════════════════════════════════════════════════════════════════\n","\n","class VAESampling(nn.Module):\n","    def forward(self, mu: torch.Tensor, logvar: torch.Tensor) -> torch.Tensor:\n","        return mu + torch.exp(0.5 * logvar) * torch.randn_like(mu)\n","\n","\n","class VAEEncoder(nn.Module):\n","    def __init__(self, latent_dim: int = 128):\n","        super().__init__()\n","        self.conv1 = nn.Conv2d(128, 64,  kernel_size=4, stride=2, padding=1)\n","        self.conv2 = nn.Conv2d(64,  128, kernel_size=4, stride=2, padding=1)\n","        self.res_conv     = nn.Conv2d(128, 128, kernel_size=3, stride=1, padding=1)\n","        self.adaptive_pool = nn.AdaptiveAvgPool2d((2, 2))\n","        self.flatten      = nn.Flatten()\n","        self.fc_mu     = nn.Linear(128 * 4, latent_dim)\n","        self.fc_logvar = nn.Linear(128 * 4, latent_dim)\n","\n","    def forward(self, x: torch.Tensor):\n","        B, C, H, W = x.shape\n","        if H < 4 or W < 4:\n","            x = F.adaptive_avg_pool2d(x, (8, 8))\n","        x = F.relu(self.conv1(x))\n","        x = F.relu(self.conv2(x))\n","        x = F.relu(self.res_conv(x)) + x          # residual\n","        x = self.adaptive_pool(x)\n","        x = self.flatten(x)\n","        return self.fc_mu(x), self.fc_logvar(x)\n","\n","\n","class VAEDecoder(nn.Module):\n","    def __init__(self, latent_dim: int = 128):\n","        super().__init__()\n","        self.fc       = nn.Linear(latent_dim, 128 * 8 * 8)\n","        self.res_conv = nn.Conv2d(128, 128, kernel_size=3, stride=1, padding=1)\n","        self.deconv1  = nn.ConvTranspose2d(128, 64, kernel_size=4, stride=2, padding=1)\n","        self.deconv2  = nn.ConvTranspose2d(64,  32, kernel_size=4, stride=2, padding=1)\n","        self.deconv3  = nn.ConvTranspose2d(32,   3, kernel_size=4, stride=2, padding=1)\n","\n","    def forward(self, z: torch.Tensor) -> torch.Tensor:\n","        x = F.relu(self.fc(z)).view(-1, 128, 8, 8)\n","        x = F.relu(self.res_conv(x)) + x          # residual\n","        x = F.relu(self.deconv1(x))\n","        x = F.relu(self.deconv2(x))\n","        return torch.tanh(self.deconv3(x))\n","\n","# ══════════════════════════════════════════════════════════════════════════════\n","# ۶. Edge Detector\n","# ══════════════════════════════════════════════════════════════════════════════\n","\n","class EdgeDetector(nn.Module):\n","    \"\"\"Sobel-based edge detector — وزن‌های ثابت، بدون پارامتر قابل آموزش.\"\"\"\n","\n","    def __init__(self):\n","        super().__init__()\n","        sx = torch.tensor([[-1, 0, 1], [-2, 0, 2], [-1, 0, 1]], dtype=torch.float32)\n","        sy = torch.tensor([[-1, -2, -1], [0, 0, 0], [1, 2, 1]], dtype=torch.float32)\n","        self.register_buffer(\"sobel_x\", sx.unsqueeze(0).unsqueeze(0).repeat(3, 1, 1, 1))\n","        self.register_buffer(\"sobel_y\", sy.unsqueeze(0).unsqueeze(0).repeat(3, 1, 1, 1))\n","\n","    def forward(self, x: torch.Tensor) -> torch.Tensor:\n","        ex = F.conv2d(x, self.sobel_x, padding=1, groups=3)\n","        ey = F.conv2d(x, self.sobel_y, padding=1, groups=3)\n","        return torch.sqrt(ex ** 2 + ey ** 2 + 1e-8)\n","\n","# ══════════════════════════════════════════════════════════════════════════════\n","# ۷. Edge Generator\n","# ══════════════════════════════════════════════════════════════════════════════\n","\n","class EdgeGenerator(nn.Module):\n","    \"\"\"U-Net با attention در bottleneck برای بازسازی لبه‌های بینی و لب‌ها.\"\"\"\n","\n","    def __init__(self):\n","        super().__init__()\n","        # Encoder\n","        self.enc1 = nn.Sequential(nn.Conv2d(6,   64,  4, 2, 1), nn.LeakyReLU(0.2, True))\n","        self.enc2 = nn.Sequential(nn.Conv2d(64,  128, 4, 2, 1), nn.LeakyReLU(0.2, True))\n","        self.enc3 = nn.Sequential(nn.Conv2d(128, 256, 4, 2, 1), nn.LeakyReLU(0.2, True))\n","        self.bottleneck = nn.Sequential(nn.Conv2d(256, 512, 4, 2, 1), nn.LeakyReLU(0.2, True))\n","\n","        # Attention در bottleneck\n","        self.attention      = nn.MultiheadAttention(512, num_heads=8, dropout=0.1, batch_first=True)\n","        self.attention_norm = nn.LayerNorm(512, eps=1e-6)\n","\n","        # Decoder با skip connections\n","        self.dec1 = nn.Sequential(nn.ConvTranspose2d(512,     256, 4, 2, 1), nn.ReLU(True))\n","        self.dec2 = nn.Sequential(nn.ConvTranspose2d(256+256, 128, 4, 2, 1), nn.ReLU(True))\n","        self.dec3 = nn.Sequential(nn.ConvTranspose2d(128+128,  64, 4, 2, 1), nn.ReLU(True))\n","        self.dec4 = nn.Sequential(nn.ConvTranspose2d(64+64,     3, 4, 2, 1), nn.Sigmoid())\n","\n","    def forward(self, masked_image: torch.Tensor, mask: torch.Tensor) -> torch.Tensor:\n","        x = torch.cat([masked_image, mask], dim=1)      # [B, 6, H, W]\n","\n","        e1 = self.enc1(x)          # 64→32\n","        e2 = self.enc2(e1)         # 32→16\n","        e3 = self.enc3(e2)         # 16→8\n","        bt = self.bottleneck(e3)   # 8→4\n","\n","        # Attention\n","        B, C, H, W = bt.shape\n","        tok = bt.permute(0, 2, 3, 1).reshape(B, H * W, C)\n","        attn_out, _ = self.attention(tok, tok, tok)\n","        tok = self.attention_norm(tok + attn_out).reshape(B, H, W, C).permute(0, 3, 1, 2)\n","\n","        d1 = self.dec1(tok)\n","        d2 = self.dec2(torch.cat([d1, e3], 1))\n","        d3 = self.dec3(torch.cat([d2, e2], 1))\n","        return self.dec4(torch.cat([d3, e1], 1))\n","\n","# ══════════════════════════════════════════════════════════════════════════════\n","# ۸. Coarse Generator  (ViT + VAE)\n","# ══════════════════════════════════════════════════════════════════════════════\n","\n","class CoarseGenerator(nn.Module):\n","    def __init__(self):\n","        super().__init__()\n","        self.preprocessor  = ViTPreprocessor(dim=128, num_heads=8, patch_size=8, num_layers=3)\n","        self.encoder       = VAEEncoder(latent_dim=128)\n","        self.sampling      = VAESampling()\n","        self.decoder       = VAEDecoder(latent_dim=128)\n","        self.attention      = nn.MultiheadAttention(128, num_heads=8, dropout=0.1, batch_first=True)\n","        self.attention_norm = nn.LayerNorm(128, eps=1e-6)\n","        self.skip_conv      = nn.Conv2d(128, 128, kernel_size=1)\n","\n","    def forward(self, x: torch.Tensor, mask: torch.Tensor,\n","                edge_map: torch.Tensor = None):\n","        if edge_map is not None:\n","            x = x + edge_map * 0.1      # ترکیب اطلاعات لبه با ورودی\n","\n","        feats = self.preprocessor(x)    # [B, 128, H/p, W/p]\n","\n","        B, C, H, W = feats.shape\n","        tok = feats.permute(0, 2, 3, 1).reshape(B, H * W, C)\n","        attn_out, _ = self.attention(tok, tok, tok)\n","        tok = self.attention_norm(tok + attn_out).reshape(B, H, W, C).permute(0, 3, 1, 2)\n","        tok = tok + self.skip_conv(feats)\n","\n","        mu, logvar = self.encoder(tok)\n","        z = self.sampling(mu, logvar)\n","        return self.decoder(z), mu, logvar\n","\n","# ══════════════════════════════════════════════════════════════════════════════\n","# ۹. Fine Generator  (U-Net + edge-guided)\n","# ══════════════════════════════════════════════════════════════════════════════\n","\n","class FineGenerator(nn.Module):\n","    def __init__(self):\n","        super().__init__()\n","        # 9 channels: masked(3) + coarse(3) + edge(3)\n","        self.enc1 = nn.Sequential(nn.Conv2d(9,   64,  4, 2, 1), nn.LeakyReLU(0.2, True))\n","        self.enc2 = nn.Sequential(nn.Conv2d(64,  128, 4, 2, 1), nn.LeakyReLU(0.2, True))\n","        self.enc3 = nn.Sequential(nn.Conv2d(128, 256, 4, 2, 1), nn.LeakyReLU(0.2, True))\n","        self.bottleneck = nn.Sequential(nn.Conv2d(256, 512, 4, 2, 1), nn.LeakyReLU(0.2, True))\n","\n","        self.attention      = nn.MultiheadAttention(512, num_heads=8, dropout=0.1, batch_first=True)\n","        self.attention_norm = nn.LayerNorm(512, eps=1e-6)\n","\n","        self.dec1 = nn.Sequential(nn.ConvTranspose2d(512,     256, 4, 2, 1), nn.ReLU(True))\n","        self.dec2 = nn.Sequential(nn.ConvTranspose2d(256+256, 128, 4, 2, 1), nn.ReLU(True))\n","        self.dec3 = nn.Sequential(nn.ConvTranspose2d(128+128,  64, 4, 2, 1), nn.ReLU(True))\n","        self.dec4 = nn.Sequential(nn.ConvTranspose2d(64+64,     3, 4, 2, 1), nn.Tanh())\n","\n","    def forward(self, masked: torch.Tensor, coarse: torch.Tensor,\n","                mask: torch.Tensor, edge_map: torch.Tensor = None) -> torch.Tensor:\n","        if coarse.shape[2:] != masked.shape[2:]:\n","            coarse = F.interpolate(coarse, size=masked.shape[2:], mode=\"bilinear\", align_corners=False)\n","\n","        if edge_map is not None:\n","            if edge_map.shape[2:] != masked.shape[2:]:\n","                edge_map = F.interpolate(edge_map, size=masked.shape[2:], mode=\"bilinear\", align_corners=False)\n","            x = torch.cat([masked, coarse, edge_map], dim=1)\n","        else:\n","            x = torch.cat([masked, coarse, torch.zeros_like(masked)], dim=1)\n","\n","        e1 = self.enc1(x)\n","        e2 = self.enc2(e1)\n","        e3 = self.enc3(e2)\n","        bt = self.bottleneck(e3)\n","\n","        B, C, H, W = bt.shape\n","        tok = bt.permute(0, 2, 3, 1).reshape(B, H * W, C)\n","        attn_out, _ = self.attention(tok, tok, tok)\n","        tok = self.attention_norm(tok + attn_out).reshape(B, H, W, C).permute(0, 3, 1, 2)\n","\n","        d1 = self.dec1(tok)\n","        d2 = self.dec2(torch.cat([d1, e3], 1))\n","        d3 = self.dec3(torch.cat([d2, e2], 1))\n","        out = self.dec4(torch.cat([d3, e1], 1))\n","\n","        if out.shape[2:] != masked.shape[2:]:\n","            out = F.interpolate(out, size=masked.shape[2:], mode=\"bilinear\", align_corners=False)\n","        return out\n","\n","# ══════════════════════════════════════════════════════════════════════════════\n","# ۱۰. Discriminator\n","# ══════════════════════════════════════════════════════════════════════════════\n","\n","class Discriminator(nn.Module):\n","    def __init__(self):\n","        super().__init__()\n","        sn = nn.utils.spectral_norm\n","        self.conv1 = sn(nn.Conv2d(6,   64,  4, 2, 1))\n","        self.conv2 = sn(nn.Conv2d(64,  128, 4, 2, 1))\n","        self.conv3 = sn(nn.Conv2d(128, 256, 4, 2, 1))\n","        self.conv4 = sn(nn.Conv2d(256, 512, 4, 2, 1))\n","        self.conv5 = sn(nn.Conv2d(512, 512, 3, 1, 1))\n","        self.conv6 = sn(nn.Conv2d(512, 512, 3, 1, 1))\n","        self.conv_out = sn(nn.Conv2d(512, 1, 1))\n","\n","    def forward(self, x: torch.Tensor, mask: torch.Tensor,\n","                return_features: bool = False):\n","        h = torch.cat([x, mask], dim=1)\n","        features = []\n","\n","        h = F.leaky_relu(self.conv1(h), 0.2, True); features.append(h)\n","        h = F.leaky_relu(self.conv2(h), 0.2, True); features.append(h)\n","        h = F.leaky_relu(self.conv3(h), 0.2, True); features.append(h)\n","        h = F.leaky_relu(self.conv4(h), 0.2, True); features.append(h)\n","        h = F.leaky_relu(self.conv5(h), 0.2, True); features.append(h)\n","        h = F.leaky_relu(self.conv6(h), 0.2, True); features.append(h)\n","        logits = self.conv_out(h)\n","\n","        return (logits, features) if return_features else logits\n","\n","# ══════════════════════════════════════════════════════════════════════════════\n","# ۱۱. Mask و Blend\n","# ══════════════════════════════════════════════════════════════════════════════\n","\n","def generate_adaptive_mask(image: torch.Tensor) -> torch.Tensor:\n","    \"\"\"ماسک نیمه‌پایین با jitter تصادفی.\"\"\"\n","    B = image.shape[0]\n","    h, w = image_size\n","    half = h // 2\n","    jitter = 4\n","    cuts = (half + torch.randint(-jitter, jitter + 1, (B,), device=image.device)).clamp(0, h)\n","\n","    mask = torch.zeros(B, 1, h, w, device=image.device)\n","    for i in range(B):\n","        mask[i, :, :cuts[i], :] = 1.0\n","    mask = mask.repeat(1, 3, 1, 1)\n","\n","    # اگر MTCNN فعال باشد، ناحیه دهان از ماسک خارج می‌شود\n","    if USE_MTCNN and \"MTCNN\" in globals():\n","        detector = MTCNN()\n","        imgs_np = ((image * 0.5 + 0.5) * 255).permute(0, 2, 3, 1).cpu().detach().numpy()\n","        mask_np = mask.permute(0, 2, 3, 1).cpu().detach().numpy()\n","        for i, img in enumerate(imgs_np):\n","            result = detector.detect_faces(img.astype(np.uint8))\n","            if result:\n","                for key in (\"mouth_left\", \"mouth_right\"):\n","                    xp, yp = result[0][\"keypoints\"].get(key, (None, None))\n","                    if xp is not None:\n","                        yp = int(np.clip(yp, half, h - 1))\n","                        xp = int(np.clip(xp, 0,    w - 1))\n","                        mask_np[i, yp-5:yp+5, xp-5:xp+5, :] = 0.0\n","        mask = torch.from_numpy(mask_np).permute(0, 3, 1, 2).to(device)\n","\n","    return mask\n","\n","\n","def make_blend_mask(mask: torch.Tensor, radius: int = 5) -> torch.Tensor:\n","    if radius <= 0:\n","        return mask\n","    m = (mask[:, :1] > 0.5).float()\n","    k = radius * 2 + 1\n","    soft = F.avg_pool2d(m, kernel_size=k, stride=1, padding=radius).clamp(0, 1) * m\n","    return soft.repeat(1, mask.shape[1], 1, 1) if mask.shape[1] != 1 else soft\n","\n","# ══════════════════════════════════════════════════════════════════════════════\n","# ۱۲. توابع Loss\n","# ══════════════════════════════════════════════════════════════════════════════\n","\n","# VGG برای perceptual / style loss\n","try:\n","    _vgg_w = models.VGG16_Weights.DEFAULT\n","except AttributeError:\n","    _vgg_w = None\n","_vgg    = models.vgg16(weights=_vgg_w).features.to(device).eval()\n","loss_model = nn.Sequential(*list(_vgg.children())[:16]).to(device).eval()\n","for p in loss_model.parameters():\n","    p.requires_grad = False\n","\n","# Global edge detector (ثابت، بدون گرادیان)\n","edge_detector_global = EdgeDetector().to(device).eval()\n","for p in edge_detector_global.parameters():\n","    p.requires_grad = False\n","\n","\n","def _denorm(t: torch.Tensor) -> torch.Tensor:\n","    \"\"\"[-1,1] → [0,1]\"\"\"\n","    return t * 0.5 + 0.5\n","\n","\n","def perceptual_loss(y_true: torch.Tensor, y_pred: torch.Tensor) -> torch.Tensor:\n","    yt = loss_model(F.interpolate(_denorm(y_true), image_size, mode=\"bilinear\", align_corners=False))\n","    yp = loss_model(F.interpolate(_denorm(y_pred), image_size, mode=\"bilinear\", align_corners=False))\n","    return F.mse_loss(yt, yp)\n","\n","\n","def half_perceptual_loss(y_true: torch.Tensor, completion: torch.Tensor) -> torch.Tensor:\n","    yt = loss_model(F.interpolate(_denorm(y_true),     image_size, mode=\"bilinear\", align_corners=False))\n","    yp = loss_model(F.interpolate(_denorm(completion), image_size, mode=\"bilinear\", align_corners=False))\n","    return F.mse_loss(yt, yp)\n","\n","\n","def _gram(feat: torch.Tensor) -> torch.Tensor:\n","    B, C, H, W = feat.shape\n","    f = feat.view(B, C, H * W)\n","    return torch.bmm(f, f.transpose(1, 2)) / (C * H * W)\n","\n","\n","def style_loss(y_true: torch.Tensor, y_pred: torch.Tensor) -> torch.Tensor:\n","    tf = loss_model(F.interpolate(_denorm(y_true), image_size, mode=\"bilinear\", align_corners=False))\n","    pf = loss_model(F.interpolate(_denorm(y_pred), image_size, mode=\"bilinear\", align_corners=False))\n","    return F.mse_loss(_gram(tf), _gram(pf))\n","\n","\n","def bottom_half_loss(y_true: torch.Tensor, y_pred: torch.Tensor, mask: torch.Tensor) -> torch.Tensor:\n","    bm = (mask == 0).float()\n","    diff = (y_true - y_pred) ** 2 * bm\n","    return diff.sum() / (bm.sum() + 1e-8)\n","\n","\n","def feature_matching_loss(real_feats, fake_feats) -> torch.Tensor:\n","    return torch.mean(torch.stack([F.mse_loss(r, f) for r, f in zip(real_feats, fake_feats)]))\n","\n","\n","def identity_loss(y_true: torch.Tensor, y_pred: torch.Tensor, mask: torch.Tensor) -> torch.Tensor:\n","    bm = (mask == 0).float()\n","    return torch.mean(torch.abs(y_true * bm - y_pred * bm))\n","\n","\n","def landmark_guided_loss(y_true: torch.Tensor, y_pred: torch.Tensor,\n","                         mask: torch.Tensor, force_mtcnn=None) -> torch.Tensor:\n","    use = USE_MTCNN if force_mtcnn is None else force_mtcnn\n","    if not use or \"MTCNN\" not in globals():\n","        return bottom_half_loss(y_true, y_pred, mask)\n","\n","    detector = MTCNN()\n","    bm = (mask == 0).float()\n","    yt_np = (_denorm(y_true * bm) * 255).permute(0, 2, 3, 1).cpu().detach().numpy()\n","    yp_np = (_denorm(y_pred * bm) * 255).permute(0, 2, 3, 1).cpu().detach().numpy()\n","    loss = torch.tensor(0.0, device=device, requires_grad=True)\n","    for ti, pi in zip(yt_np, yp_np):\n","        tlm = detector.detect_faces(ti.astype(np.uint8))\n","        plm = detector.detect_faces(pi.astype(np.uint8))\n","        if tlm and plm:\n","            for k in (\"mouth_left\", \"mouth_right\"):\n","                tx, ty = tlm[0][\"keypoints\"][k]\n","                px, py = plm[0][\"keypoints\"][k]\n","                loss = loss + (tx - px) ** 2 + (ty - py) ** 2\n","    return loss / y_true.shape[0]\n","\n","\n","def structural_ssim_loss(y_true: torch.Tensor, y_pred: torch.Tensor,\n","                         mask: torch.Tensor) -> torch.Tensor:\n","    yt = _denorm(y_true) * (mask == 0).float()\n","    yp = _denorm(y_pred) * (mask == 0).float()\n","    vals = []\n","    for i in range(yt.shape[0]):\n","        t = yt[i].permute(1, 2, 0).cpu().detach().numpy()\n","        p = yp[i].permute(1, 2, 0).cpu().detach().numpy()\n","        vals.append(ssim(t, p, channel_axis=2, data_range=1.0, win_size=7))\n","    return 1.0 - torch.mean(torch.tensor(vals, device=device))\n","\n","\n","def gradient_penalty_loss(disc: nn.Module,\n","                          real: torch.Tensor, fake: torch.Tensor,\n","                          masks: torch.Tensor) -> torch.Tensor:\n","    alpha = torch.rand(real.size(0), 1, 1, 1, device=device)\n","    interp = (alpha * real + (1 - alpha) * fake).detach().requires_grad_(True)\n","    d_interp = disc(interp, masks, return_features=False)\n","    if not d_interp.requires_grad:\n","        return torch.tensor(0.0, device=device, requires_grad=True)\n","    grads = torch.autograd.grad(\n","        d_interp, interp,\n","        grad_outputs=torch.ones_like(d_interp),\n","        create_graph=True, retain_graph=True, only_inputs=True,\n","    )[0]\n","    return ((grads.view(real.size(0), -1).norm(2, dim=1) - 1) ** 2).mean()\n","\n","\n","def attention_loss(y_true: torch.Tensor, y_pred: torch.Tensor,\n","                   mask: torch.Tensor) -> torch.Tensor:\n","    bm = (mask == 0).float()\n","    gx = F.pad(torch.abs(y_true[:, :, :, 1:] - y_true[:, :, :, :-1]), (0, 1, 0, 0))\n","    gy = F.pad(torch.abs(y_true[:, :, 1:, :] - y_true[:, :, :-1, :]), (0, 0, 0, 1))\n","    w  = (gx + gy).mean(1, keepdim=True)\n","    w  = w / (w.mean() + 1e-8)\n","    return (torch.abs(y_true - y_pred) * bm * w).mean()\n","\n","\n","def edge_loss(y_true: torch.Tensor, y_pred: torch.Tensor,\n","              mask: torch.Tensor, det: nn.Module) -> torch.Tensor:\n","    with torch.no_grad():\n","        et = det(_denorm(y_true))\n","    ep = det(_denorm(y_pred))\n","    return (torch.abs(et - ep) * (mask == 0).float()).mean()\n","\n","\n","def high_frequency_loss(y_true: torch.Tensor, y_pred: torch.Tensor,\n","                        mask: torch.Tensor) -> torch.Tensor:\n","    lap = torch.tensor([[0,1,0],[1,-4,1],[0,1,0]], dtype=y_true.dtype, device=y_true.device)\n","    lap = lap.view(1, 1, 3, 3).repeat(3, 1, 1, 1)\n","    bm = (mask == 0).float()\n","    return (torch.abs(F.conv2d(y_true, lap, padding=1, groups=3) -\n","                      F.conv2d(y_pred, lap, padding=1, groups=3)) * bm).mean()\n","\n","\n","def gradient_loss(y_true: torch.Tensor, y_pred: torch.Tensor,\n","                  mask: torch.Tensor) -> torch.Tensor:\n","    sx = torch.tensor([[-1,0,1],[-2,0,2],[-1,0,1]], dtype=y_true.dtype, device=y_true.device)\n","    sy = torch.tensor([[-1,-2,-1],[0,0,0],[1,2,1]], dtype=y_true.dtype, device=y_true.device)\n","    sx = sx.view(1,1,3,3).repeat(3,1,1,1)\n","    sy = sy.view(1,1,3,3).repeat(3,1,1,1)\n","    def grad_mag(t):\n","        return torch.sqrt(F.conv2d(t,sx,padding=1,groups=3)**2 +\n","                          F.conv2d(t,sy,padding=1,groups=3)**2 + 1e-8)\n","    bm = (mask == 0).float()\n","    return (torch.abs(grad_mag(y_true) - grad_mag(y_pred)) * bm).mean()\n","\n","\n","def facial_region_loss(y_true: torch.Tensor, y_pred: torch.Tensor,\n","                       mask: torch.Tensor) -> torch.Tensor:\n","    B, C, H, W = y_true.shape\n","    w_map = torch.ones_like(mask)\n","    w_map[:, :, H//2:H, W//4:3*W//4] = 3.0\n","    w_map = w_map * (mask == 0).float()\n","    return (torch.abs(y_true - y_pred) * w_map).sum() / (w_map.sum() + 1e-8)\n","\n","\n","def _safe(t: torch.Tensor) -> torch.Tensor:\n","    return torch.nan_to_num(t, nan=0.0, posinf=0.0, neginf=0.0)\n","\n","\n","def generator_loss(disc_fake, y_true, y_pred, feat_real, feat_fake, mask, mu, logvar):\n","    logvar = logvar.clamp(-10, 10)\n","\n","    adv   = _safe(-torch.mean(disc_fake))\n","    l1    = _safe(torch.mean(torch.abs(y_true - y_pred) * (mask == 0).float()))\n","    rec   = _safe(bottom_half_loss(y_true, y_pred, mask))\n","    blend = make_blend_mask(mask)\n","    comp  = y_true * blend + y_pred * (1 - blend)\n","    perc  = _safe(half_perceptual_loss(y_true, comp))\n","    sty   = _safe(style_loss(y_true, y_pred))\n","    fm    = _safe(feature_matching_loss(feat_real, feat_fake))\n","    idn   = _safe(identity_loss(y_true, y_pred, mask))\n","    lm    = _safe(landmark_guided_loss(y_true, y_pred, mask))\n","    ssim_ = _safe(structural_ssim_loss(y_true, y_pred, mask))\n","    att   = _safe(attention_loss(y_true, y_pred, mask))\n","    edg   = _safe(edge_loss(y_true, y_pred, mask, edge_detector_global))\n","    hf    = _safe(high_frequency_loss(y_true, y_pred, mask))\n","    grad  = _safe(gradient_loss(y_true, y_pred, mask))\n","    face  = _safe(facial_region_loss(y_true, y_pred, mask))\n","    kl    = _safe((-0.5 * torch.mean(1 + logvar - mu**2 - logvar.exp())).clamp(0, 10))\n","\n","    total = (\n","        lambda_adv       * adv   +\n","        lambda_l1        * l1    +\n","        lambda_rec       * rec   +\n","        lambda_perc      * perc  +\n","        lambda_style     * sty   +\n","        lambda_fm        * fm    +\n","        lambda_identity  * idn   +\n","        lambda_landmark  * lm    +\n","        lambda_struct    * ssim_ +\n","        lambda_attention * att   +\n","        lambda_vae       * kl    +\n","        lambda_edge      * edg   +\n","        lambda_hf        * hf    +\n","        lambda_gradient  * grad  +\n","        lambda_facial    * face\n","    )\n","    return _safe(total)\n","\n","\n","def discriminator_loss(real_logits: torch.Tensor, fake_logits: torch.Tensor) -> torch.Tensor:\n","    rl = real_logits.clamp(-5, 5)\n","    fl = fake_logits.clamp(-5, 5)\n","    loss = (\n","        _safe(F.relu(1.0 - rl).mean()) +\n","        _safe(F.relu(1.0 + fl).mean()) +\n","        _safe(lambda_d_reg * (rl**2 + fl**2).mean())\n","    )\n","    return _safe(loss)\n","\n","# ══════════════════════════════════════════════════════════════════════════════\n","# ۱۳. Evaluation helpers\n","# ══════════════════════════════════════════════════════════════════════════════\n","\n","def calculate_psnr_bottom_half(y_true, y_pred, mask):\n","    yt = _denorm(y_true) * (mask == 0).float()\n","    yp = _denorm(y_pred) * (mask == 0).float()\n","    vals = []\n","    for i in range(yt.shape[0]):\n","        t = yt[i].permute(1,2,0).cpu().detach().numpy()\n","        p = yp[i].permute(1,2,0).cpu().detach().numpy()\n","        vals.append(psnr(t, p, data_range=1.0))\n","    return torch.mean(torch.tensor(vals, device=device))\n","\n","\n","def calculate_ssim_bottom_half(y_true, y_pred, mask):\n","    yt = _denorm(y_true) * (mask == 0).float()\n","    yp = _denorm(y_pred) * (mask == 0).float()\n","    vals = []\n","    for i in range(yt.shape[0]):\n","        t = yt[i].permute(1,2,0).cpu().detach().numpy()\n","        p = yp[i].permute(1,2,0).cpu().detach().numpy()\n","        vals.append(ssim(t, p, channel_axis=2, data_range=1.0, win_size=7))\n","    return torch.mean(torch.tensor(vals, device=device))\n","\n","\n","def calculate_mse_bottom_half(y_true, y_pred, mask):\n","    return bottom_half_loss(y_true, y_pred, mask)\n","\n","# ══════════════════════════════════════════════════════════════════════════════\n","# ۱۴. Multi-resolution inpainting\n","# ══════════════════════════════════════════════════════════════════════════════\n","\n","def multi_resolution_inpainting(image, mask, model, edge_map=None, levels=3):\n","    outputs, mus, logvars = [], [], []\n","    for lvl in range(levels):\n","        sf = 1.0 / (2 ** lvl)\n","        si = F.interpolate(image, scale_factor=sf, mode=\"bilinear\", align_corners=False)\n","        sm = F.interpolate(mask,  scale_factor=sf, mode=\"nearest\")\n","        se = F.interpolate(edge_map, scale_factor=sf, mode=\"bilinear\", align_corners=False) \\\n","             if edge_map is not None else None\n","        out, mu, lv = model(si, sm, se)\n","        outputs.append(F.interpolate(out, size=image.shape[-2:], mode=\"bilinear\", align_corners=False))\n","        mus.append(mu); logvars.append(lv)\n","    return (torch.stack(outputs).mean(0),\n","            torch.stack(mus).mean(0),\n","            torch.stack(logvars).mean(0))\n","\n","# ══════════════════════════════════════════════════════════════════════════════\n","# ۱۵. Train step\n","# ══════════════════════════════════════════════════════════════════════════════\n","\n","def train_step(images, edge_gen, coarse_gen, fine_gen, disc,\n","               edge_opt, g_opt, d_opt, scaler):\n","    images = images.to(device)\n","    masks  = generate_adaptive_mask(images)\n","    blends = make_blend_mask(masks)\n","    masked = images * masks\n","\n","    # ── Discriminator update ───────────────────────────────────────────────\n","    d_opt.zero_grad()\n","    d_loss_total = 0.0\n","    for _ in range(n_critic):\n","        with amp.autocast(\"cuda\"):\n","            with torch.no_grad():\n","                em   = edge_gen(masked, masks)\n","                co, mu, lv = multi_resolution_inpainting(masked, masks, coarse_gen, em)\n","                if co.shape != images.shape:\n","                    co = F.interpolate(co, images.shape[2:], mode=\"bilinear\", align_corners=False)\n","                fo = fine_gen(masked, co, masks, em)\n","                if fo.shape != images.shape:\n","                    fo = F.interpolate(fo, images.shape[2:], mode=\"bilinear\", align_corners=False)\n","                combo = (images * blends + fo * (1 - blends)).detach()\n","            rl  = disc(images, masks, return_features=False)\n","            fl  = disc(combo,  masks, return_features=False)\n","            dl  = discriminator_loss(rl, fl) + lambda_gp * gradient_penalty_loss(disc, images, combo, masks)\n","        scaler.scale(dl).backward()\n","        d_loss_total += dl.item()\n","\n","    scaler.unscale_(d_opt)\n","    torch.nn.utils.clip_grad_norm_(disc.parameters(), 1.0)\n","    scaler.step(d_opt)\n","    d_loss_val = d_loss_total / n_critic\n","\n","    # ── Generator update ───────────────────────────────────────────────────\n","    edge_opt.zero_grad()\n","    g_opt.zero_grad()\n","\n","    with amp.autocast(\"cuda\"):\n","        em  = edge_gen(masked, masks)\n","        with torch.no_grad():\n","            true_edges = edge_detector_global(_denorm(images))\n","        edge_recon = (torch.abs(true_edges - em) * (masks == 0).float()).mean()\n","\n","        co, mu, lv = multi_resolution_inpainting(masked, masks, coarse_gen, em)\n","        if co.shape != images.shape:\n","            co = F.interpolate(co, images.shape[2:], mode=\"bilinear\", align_corners=False)\n","        fo = fine_gen(masked, co, masks, em)\n","        if fo.shape != images.shape:\n","            fo = F.interpolate(fo, images.shape[2:], mode=\"bilinear\", align_corners=False)\n","        combo = images * blends + fo * (1 - blends)\n","\n","        rl, feat_r = disc(images, masks, return_features=True)\n","        fl, feat_f = disc(combo,  masks, return_features=True)\n","        g_loss = generator_loss(fl, images, fo, feat_r, feat_f, masks, mu, lv)\n","\n","    total = edge_recon + g_loss\n","    scaler.scale(total).backward()\n","\n","    scaler.unscale_(edge_opt)\n","    scaler.unscale_(g_opt)\n","    torch.nn.utils.clip_grad_norm_(edge_gen.parameters(), 1.0)\n","    torch.nn.utils.clip_grad_norm_(\n","        list(coarse_gen.parameters()) + list(fine_gen.parameters()), 1.0\n","    )\n","    scaler.step(edge_opt)\n","    scaler.step(g_opt)\n","    scaler.update()\n","\n","    g_v   = g_loss.item()    if not (np.isnan(g_loss.item()) or np.isinf(g_loss.item())) else 0.0\n","    d_v   = d_loss_val       if not (np.isnan(d_loss_val)    or np.isinf(d_loss_val))    else 0.0\n","    e_v   = edge_recon.item() if not (np.isnan(edge_recon.item()) or np.isinf(edge_recon.item())) else 0.0\n","    return g_v, d_v, e_v\n","\n","# ══════════════════════════════════════════════════════════════════════════════\n","# ۱۶. ساخت مدل‌ها و بارگذاری dataset\n","# ══════════════════════════════════════════════════════════════════════════════\n","\n","celeba_dir = \"/kaggle/input/datasets/masoudshahrian/celeba-6464/selected_celeba\"\n","\n","print(f\"Loading dataset from {celeba_dir} ...\")\n","try:\n","    print(f\"  First 5 files: {os.listdir(celeba_dir)[:5]}\")\n","except Exception as e:\n","    print(f\"Error: {e}\"); raise\n","\n","train_files, val_files, test_files = split_dataset(celeba_dir)\n","train_loader, val_loader, test_loader = create_split_datasets(\n","    celeba_dir, train_files, val_files, test_files, image_size, batch_size\n",")\n","\n","print(\"\\nBuilding models ...\")\n","edge_generator  = EdgeGenerator().to(device)\n","coarse_generator = CoarseGenerator().to(device)\n","fine_generator   = FineGenerator().to(device)\n","discriminator    = Discriminator().to(device)\n","\n","for name, m in [(\"Edge Generator\",   edge_generator),\n","                (\"Coarse Generator\",  coarse_generator),\n","                (\"Fine Generator\",    fine_generator),\n","                (\"Discriminator\",     discriminator)]:\n","    print(f\"  {name}: {sum(p.numel() for p in m.parameters()):,} parameters\")\n","\n","# ── بررسی سریع ابعاد ────────────────────────────────────────────────────────\n","print(\"\\nDimension check ...\")\n","_ti = torch.randn(1, 3, 64, 64).to(device)\n","_tm = torch.zeros(1, 3, 64, 64).to(device); _tm[:, :, :32, :] = 1.0\n","with torch.no_grad():\n","    _co, _mu, _lv = coarse_generator(_ti, _tm)\n","    _fo = fine_generator(_ti, _co, _tm)\n","    _d  = discriminator(_ti, _tm)\n","print(f\"  coarse={_co.shape}  fine={_fo.shape}  disc={_d.shape}  ✓\")\n","del _ti, _tm, _co, _mu, _lv, _fo, _d\n","\n","# ══════════════════════════════════════════════════════════════════════════════\n","# ۱۷. Optimizer و Scheduler\n","# ══════════════════════════════════════════════════════════════════════════════\n","\n","edge_optimizer = torch.optim.AdamW(\n","    edge_generator.parameters(), lr=learning_rate_g, betas=(0.5, 0.999), weight_decay=1e-4\n",")\n","g_optimizer = torch.optim.AdamW(\n","    list(coarse_generator.parameters()) + list(fine_generator.parameters()),\n","    lr=learning_rate_g, betas=(0.5, 0.999), weight_decay=1e-4,\n",")\n","d_optimizer = torch.optim.AdamW(\n","    discriminator.parameters(), lr=learning_rate_d, betas=(0.5, 0.999), weight_decay=1e-4\n",")\n","\n","_sch_kw = dict(mode=\"min\", factor=0.5, patience=5)\n","try:\n","    edge_scheduler = torch.optim.lr_scheduler.ReduceLROnPlateau(\n","        edge_optimizer, **_sch_kw, verbose=True, min_lr=learning_rate_g * 0.01)\n","    g_scheduler    = torch.optim.lr_scheduler.ReduceLROnPlateau(\n","        g_optimizer,    **_sch_kw, verbose=True, min_lr=learning_rate_g * 0.01)\n","    d_scheduler    = torch.optim.lr_scheduler.ReduceLROnPlateau(\n","        d_optimizer,    **_sch_kw, verbose=True, min_lr=learning_rate_d * 0.01)\n","except TypeError:\n","    edge_scheduler = torch.optim.lr_scheduler.ReduceLROnPlateau(\n","        edge_optimizer, **_sch_kw, min_lr=learning_rate_g * 0.01)\n","    g_scheduler    = torch.optim.lr_scheduler.ReduceLROnPlateau(\n","        g_optimizer,    **_sch_kw, min_lr=learning_rate_g * 0.01)\n","    d_scheduler    = torch.optim.lr_scheduler.ReduceLROnPlateau(\n","        d_optimizer,    **_sch_kw, min_lr=learning_rate_d * 0.01)\n","\n","scaler = amp.GradScaler(\"cuda\")\n","\n","# ══════════════════════════════════════════════════════════════════════════════\n","# ۱۸. بارگذاری Checkpoint\n","# ══════════════════════════════════════════════════════════════════════════════\n","\n","start_epoch      = 0\n","best_val_loss    = float(\"inf\")\n","train_g_losses   = []\n","train_d_losses   = []\n","val_g_losses     = []\n","val_d_losses     = []\n","checkpoint_loaded = False\n","models_loaded     = False\n","\n","os.makedirs(CHECKPOINT_DIR, exist_ok=True)\n","\n","checkpoint_load_dir = os.path.join(KAGGLE_INPUT_DATASET, \"checkpoints\") if USE_KAGGLE_INPUT else CHECKPOINT_DIR\n","models_load_dir     = os.path.join(KAGGLE_INPUT_DATASET, \"models\")      if USE_KAGGLE_INPUT else MODELS_DIR\n","\n","print(\"\\n\" + \"=\" * 70)\n","print(\"🚀 CHECKPOINT LOADING\")\n","print(\"=\" * 70)\n","\n","# ── تلاش برای بارگذاری model files ─────────────────────────────────────────\n","if RESUME_TRAINING and LOAD_FROM_MODELS and os.path.isdir(models_load_dir):\n","    suffix = \"_best\" if USE_BEST_MODELS else \"_bottom_half\"\n","    model_map = {\n","        \"edge_generator\":   edge_generator,\n","        \"coarse_generator\": coarse_generator,\n","        \"fine_generator\":   fine_generator,\n","        \"discriminator\":    discriminator,\n","    }\n","    all_ok = True\n","    for key, model in model_map.items():\n","        fpath = os.path.join(models_load_dir, f\"{key}{suffix}.pth\")\n","        if os.path.isfile(fpath):\n","            try:\n","                model.load_state_dict(torch.load(fpath, map_location=device))\n","                print(f\"  ✅ Loaded {fpath}\")\n","            except Exception as e:\n","                print(f\"  ⚠️  Failed to load {fpath}: {e}\")\n","                all_ok = False\n","        else:\n","            print(f\"  ⚠️  Not found: {fpath}\")\n","            all_ok = False\n","    models_loaded = all_ok\n","\n","# ── تلاش برای بارگذاری full checkpoint ──────────────────────────────────────\n","if RESUME_TRAINING and not checkpoint_loaded and os.path.isdir(checkpoint_load_dir):\n","    ckpt_files = sorted(\n","        [f for f in os.listdir(checkpoint_load_dir) if f.endswith(\".pth\")],\n","        reverse=True,\n","    )\n","    for fname in ckpt_files:\n","        fpath = os.path.join(checkpoint_load_dir, fname)\n","        try:\n","            ckpt = torch.load(fpath, map_location=device)\n","            edge_generator.load_state_dict(ckpt[\"edge_generator\"])\n","            coarse_generator.load_state_dict(ckpt[\"coarse_generator\"])\n","            fine_generator.load_state_dict(ckpt[\"fine_generator\"])\n","            discriminator.load_state_dict(ckpt[\"discriminator\"])\n","            edge_optimizer.load_state_dict(ckpt[\"edge_optimizer\"])\n","            g_optimizer.load_state_dict(ckpt[\"g_optimizer\"])\n","            d_optimizer.load_state_dict(ckpt[\"d_optimizer\"])\n","            edge_scheduler.load_state_dict(ckpt[\"edge_scheduler\"])\n","            g_scheduler.load_state_dict(ckpt[\"g_scheduler\"])\n","            d_scheduler.load_state_dict(ckpt[\"d_scheduler\"])\n","            start_epoch    = ckpt[\"epoch\"] + 1\n","            best_val_loss  = ckpt.get(\"best_val_loss\", float(\"inf\"))\n","            train_g_losses = ckpt.get(\"train_g_losses\", [])\n","            train_d_losses = ckpt.get(\"train_d_losses\", [])\n","            val_g_losses   = ckpt.get(\"val_g_losses\",   [])\n","            val_d_losses   = ckpt.get(\"val_d_losses\",   [])\n","            checkpoint_loaded = True\n","            print(f\"  ✅ Checkpoint loaded: {fname}  (resume from epoch {start_epoch + 1})\")\n","            break\n","        except Exception as e:\n","            print(f\"  ⚠️  Failed: {fname}: {e}\")\n","\n","if not checkpoint_loaded and not models_loaded:\n","    print(\"  ℹ️  No checkpoint found — starting from scratch.\")\n","\n","print(f\"\\n🎯 Training epochs {start_epoch + 1} → {num_epochs}\")\n","print(\"=\" * 70 + \"\\n\")\n","\n","# ══════════════════════════════════════════════════════════════════════════════\n","# ۱۹. حلقه آموزش\n","# ══════════════════════════════════════════════════════════════════════════════\n","\n","for epoch in range(start_epoch, num_epochs):\n","    print(f\"\\nEpoch {epoch+1}/{num_epochs}\")\n","    edge_generator.train()\n","    coarse_generator.train()\n","    fine_generator.train()\n","    discriminator.train()\n","\n","    epoch_g = epoch_d = epoch_e = n_batches = 0\n","\n","    for step, images in enumerate(train_loader):\n","        gv, dv, ev = train_step(\n","            images,\n","            edge_generator, coarse_generator, fine_generator, discriminator,\n","            edge_optimizer, g_optimizer, d_optimizer, scaler,\n","        )\n","        epoch_g += gv; epoch_d += dv; epoch_e += ev\n","        n_batches += 1\n","\n","        if step % 50 == 0:\n","            print(\n","                f\"  Step {step:3d} | \"\n","                f\"Edge={ev:.4f}  G={gv:.4f}  D={dv:.4f} | \"\n","                f\"LR: E={edge_optimizer.param_groups[0]['lr']:.6f} \"\n","                f\"G={g_optimizer.param_groups[0]['lr']:.6f} \"\n","                f\"D={d_optimizer.param_groups[0]['lr']:.6f}\"\n","            )\n","\n","        if np.isnan(gv) and np.isnan(dv):\n","            print(f\"  ⚠️ Both losses NaN at step {step} — stopping epoch early.\")\n","            break\n","\n","    avg_g = epoch_g / max(n_batches, 1)\n","    avg_d = epoch_d / max(n_batches, 1)\n","    avg_e = epoch_e / max(n_batches, 1)\n","    train_g_losses.append(avg_g)\n","    train_d_losses.append(avg_d)\n","    print(f\"Epoch {epoch+1} Train  Edge={avg_e:.4f}  G={avg_g:.4f}  D={avg_d:.4f}\")\n","\n","    # ── Validation ──────────────────────────────────────────────────────────\n","    if \"MTCNN\" in globals():\n","        USE_MTCNN = True\n","\n","    edge_generator.eval()\n","    coarse_generator.eval()\n","    fine_generator.eval()\n","    discriminator.eval()\n","\n","    vg = vd = vb = 0\n","    with torch.no_grad():\n","        for images in val_loader:\n","            images = images.to(device)\n","            masks  = generate_adaptive_mask(images)\n","            masked = images * masks\n","\n","            em  = edge_generator(masked, masks)\n","            co, mu, lv = coarse_generator(masked, masks, em)\n","            if co.shape != images.shape:\n","                co = F.interpolate(co, images.shape[2:], mode=\"bilinear\", align_corners=False)\n","            fo = fine_generator(masked, co, masks, em)\n","            if fo.shape != images.shape:\n","                fo = F.interpolate(fo, images.shape[2:], mode=\"bilinear\", align_corners=False)\n","            blend = make_blend_mask(masks)\n","            combo = images * blend + fo * (1 - blend)\n","\n","            rl, fr = discriminator(images, masks, return_features=True)\n","            fl, ff = discriminator(combo,  masks, return_features=True)\n","            vg += generator_loss(fl, images, fo, fr, ff, masks, mu, lv).item()\n","            vd += discriminator_loss(rl, fl).item()\n","            vb += 1\n","\n","    avg_vg = vg / max(vb, 1)\n","    avg_vd = vd / max(vb, 1)\n","    val_g_losses.append(avg_vg)\n","    val_d_losses.append(avg_vd)\n","    print(f\"Epoch {epoch+1} Val    G={avg_vg:.4f}  D={avg_vd:.4f}\")\n","\n","    # ── LR schedule ─────────────────────────────────────────────────────────\n","    edge_scheduler.step(avg_vg)\n","    g_scheduler.step(avg_vg)\n","    d_scheduler.step(avg_vd)\n","\n","    # ── ذخیره بهترین مدل‌ها ─────────────────────────────────────────────────\n","    if avg_vg < best_val_loss:\n","        best_val_loss = avg_vg\n","        os.makedirs(\"/kaggle/working/models\", exist_ok=True)\n","        torch.save(edge_generator.state_dict(),   \"/kaggle/working/models/edge_generator_best.pth\")\n","        torch.save(coarse_generator.state_dict(), \"/kaggle/working/models/coarse_generator_best.pth\")\n","        torch.save(fine_generator.state_dict(),   \"/kaggle/working/models/fine_generator_best.pth\")\n","        torch.save(discriminator.state_dict(),    \"/kaggle/working/models/discriminator_best.pth\")\n","        print(f\"  💾 Best models saved (val_loss={best_val_loss:.6f})\")\n","\n","    # ── ذخیره Checkpoint ────────────────────────────────────────────────────\n","    if (epoch + 1) % CHECKPOINT_INTERVAL == 0 or (epoch + 1) == num_epochs:\n","        ckpt_path = os.path.join(CHECKPOINT_DIR, f\"checkpoint_epoch_{epoch+1}.pth\")\n","        torch.save({\n","            \"epoch\":            epoch,\n","            \"edge_generator\":   edge_generator.state_dict(),\n","            \"coarse_generator\": coarse_generator.state_dict(),\n","            \"fine_generator\":   fine_generator.state_dict(),\n","            \"discriminator\":    discriminator.state_dict(),\n","            \"edge_optimizer\":   edge_optimizer.state_dict(),\n","            \"g_optimizer\":      g_optimizer.state_dict(),\n","            \"d_optimizer\":      d_optimizer.state_dict(),\n","            \"edge_scheduler\":   edge_scheduler.state_dict(),\n","            \"g_scheduler\":      g_scheduler.state_dict(),\n","            \"d_scheduler\":      d_scheduler.state_dict(),\n","            \"best_val_loss\":    best_val_loss,\n","            \"train_g_losses\":   train_g_losses,\n","            \"train_d_losses\":   train_d_losses,\n","            \"val_g_losses\":     val_g_losses