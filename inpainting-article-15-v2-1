{"metadata":{"kernelspec":{"language":"python","display_name":"Python 3","name":"python3"},"language_info":{"name":"python","version":"3.6.6","mimetype":"text/x-python","codemirror_mode":{"name":"ipython","version":3},"pygments_lexer":"ipython3","nbconvert_exporter":"python","file_extension":".py"},"kaggle":{"accelerator":"nvidiaTeslaT4","dataSources":[{"sourceType":"datasetVersion","sourceId":13151434,"datasetId":8332610,"databundleVersionId":13839553},{"sourceType":"modelInstanceVersion","sourceId":675798,"databundleVersionId":14829255,"modelInstanceId":464709,"modelId":480530}],"dockerImageVersionId":31401,"isInternetEnabled":true,"language":"python","sourceType":"notebook","isGpuEnabled":true}},"nbformat_minor":4,"nbformat":4,"cells":[{"source":"<a href=\"https://www.kaggle.com/code/masoudshahrian/inpainting-article-15-v2-1?scriptVersionId=322767070\" target=\"_blank\"><img align=\"left\" alt=\"Kaggle\" title=\"Open in Kaggle\" src=\"https://kaggle.com/static/images/open-in-kaggle.svg\"></a>","metadata":{},"cell_type":"markdown"},{"cell_type":"code","source":"","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"import os\nos.environ.setdefault('TORCH_CUDA_ARCH_LIST', '7.5')\nimport torch\nimport torch.nn as nn\nimport torch.nn.functional as F\nimport torchvision.models as models\nimport torchvision.transforms as transforms\nfrom torch.utils.data import Dataset, DataLoader\nimport matplotlib.pyplot as plt\nimport numpy as np\nfrom skimage.metrics import peak_signal_noise_ratio as psnr\nfrom skimage.metrics import structural_similarity as ssim\nimport random\nfrom PIL import Image\nfrom torch import amp\n# import network as nx\n\n# ============================================================================\n# CONFIGURATION\n# ============================================================================\n# 🔧 KEY FIX: Loss weights rebalanced for PSNR 28+\nlambda_l1 = 30.0        # Increased from 10 (PSNR needs strong L1)\nlambda_adv = 1.0\nlambda_perc = 5.0        # 🔧 CRITICAL: Increased from 1.0 to fight blurriness\nlambda_style = 0.5\nlambda_fm = 0.5\nlambda_edge = 3.0        # Increased from 2.0 (sharp edges → better PSNR)\nlambda_vae = 0.001\nlambda_ssim = 0.5\nlambda_gp = 10.0\nlambda_d_reg = 1e-4\nn_critic = 1\n\nimage_size = (64, 64)\nbatch_size = 128\neval_batch_size = 1\nnum_epochs = 5          # 🔧 CRITICAL: Was 1, need 50+ for PSNR 28\nlearning_rate_g = 0.0001\nlearning_rate_d = 0.0002\ndevice = torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\nprint(f\"Using device: {device}\")\n\ntry:\n    from mtcnn import MTCNN\n    USE_MTCNN = False\n    print(\"MTCNN imported (disabled during training).\")\nexcept ImportError:\n    USE_MTCNN = False\n\n# ============================================================================\n# CHECKPOINT CONFIGURATION\n# ============================================================================\nRESUME_TRAINING = True\nCHECKPOINT_DIR = '/kaggle/working/checkpoints'\nCHECKPOINT_INTERVAL = 5\nUSE_KAGGLE_INPUT = True\nKAGGLE_INPUT_DATASET = '/kaggle/input/models/masoudshahrian/image-inpainting-v1/pytorch/default/17'\nLOAD_FROM_MODELS = True\nMODELS_DIR = '/kaggle/working/models'\nUSE_BEST_MODELS = True\n\nprint(\"=\" * 70)\nprint(\"🔧 CHECKPOINT CONFIGURATION\")\nprint(f\"📌 Resume: {RESUME_TRAINING} | 📂 Dir: {CHECKPOINT_DIR}\")\nif USE_KAGGLE_INPUT:\n    print(f\"📥 Kaggle Dataset: {KAGGLE_INPUT_DATASET}\")\nif LOAD_FROM_MODELS:\n    print(f\"🗂️ Models: {MODELS_DIR} ({'best' if USE_BEST_MODELS else 'bottom_half'})\")\nprint(\"=\" * 70 + \"\\n\")\n\n# ============================================================================\n# DATASET\n# ============================================================================\ndef split_dataset(dataset_path, train_ratio=0.8, val_ratio=0.1, test_ratio=0.1, seed=42):\n    random.seed(seed)\n    np.random.seed(seed)\n    torch.manual_seed(seed)\n    image_files = [f for f in os.listdir(dataset_path) if f.lower().endswith(('.png', '.jpg', '.jpeg'))]\n    random.shuffle(image_files)\n    total = len(image_files)\n    train_end = int(total * train_ratio)\n    val_end = train_end + int(total * val_ratio)\n    train_files, val_files, test_files = image_files[:train_end], image_files[train_end:val_end], image_files[val_end:]\n    print(f\"Dataset: Total={total}, Train={len(train_files)}, Val={len(val_files)}, Test={len(test_files)}\")\n    return train_files, val_files, test_files\n\nclass CelebADataset(Dataset):\n    def __init__(self, dataset_path, file_list, image_size, augment=True):\n        self.dataset_path = dataset_path\n        self.file_list = file_list\n        base_transforms = [\n            transforms.Resize(image_size),\n            transforms.ToTensor(),\n            transforms.Normalize(mean=[0.5, 0.5, 0.5], std=[0.5, 0.5, 0.5])\n        ]\n        if augment:\n            self.transform = transforms.Compose([\n                transforms.RandomHorizontalFlip(p=0.5),\n                transforms.RandomRotation(10)\n            ] + base_transforms)\n        else:\n            self.transform = transforms.Compose(base_transforms)\n\n    def __len__(self):\n        return len(self.file_list)\n\n    def __getitem__(self, idx):\n        img_path = os.path.join(self.dataset_path, self.file_list[idx])\n        image = Image.open(img_path).convert('RGB')\n        return self.transform(image)\n\ndef create_split_datasets(dataset_path, train_files, val_files, test_files, image_size, batch_size):\n    train_dataset = CelebADataset(dataset_path, train_files, image_size, augment=True)\n    val_dataset = CelebADataset(dataset_path, val_files, image_size, augment=False)\n    test_dataset = CelebADataset(dataset_path, test_files, image_size, augment=False)\n    train_loader = DataLoader(train_dataset, batch_size=batch_size, shuffle=True, num_workers=2, pin_memory=True)\n    val_loader = DataLoader(val_dataset, batch_size=batch_size, shuffle=False, num_workers=2, pin_memory=True)\n    test_loader = DataLoader(test_dataset, batch_size=eval_batch_size, shuffle=False, num_workers=2, pin_memory=True)\n    return train_loader, val_loader, test_loader\n\n# ============================================================================\n# 🔧 FIX: ViTPreprocessor - NO new parameters (backward compatible)\n# Kept self.gnn for checkpoint loading compatibility\n# ============================================================================\nclass PyramidalGNN(nn.Module):\n    \"\"\"Kept for checkpoint compatibility - not used in forward\"\"\"\n    def __init__(self, in_channels, out_channels):\n        super().__init__()\n        self.lin = nn.Linear(in_channels, out_channels)\n        self.gate = nn.Linear(in_channels * 2, out_channels)\n    def forward(self, x, edge_index=None):\n        return self.lin(x)\n\nclass ViTPreprocessor(nn.Module):\n    def __init__(self, dim=128, num_heads=8, patch_size=8, num_layers=3):\n        super().__init__()\n        self.patch_size = patch_size\n        self.dim = dim\n        self.num_heads = num_heads\n        self.num_patches = (image_size[0] // patch_size) * (image_size[1] // patch_size)\n        self.patch_embed = nn.Conv2d(3, dim, kernel_size=patch_size, stride=patch_size, padding=0)\n        self.pos_embed = nn.Parameter(torch.zeros(1, self.num_patches, dim))\n\n        self.attention_blocks = nn.ModuleList([\n            nn.ModuleDict({\n                'attn': nn.MultiheadAttention(embed_dim=dim, num_heads=num_heads, dropout=0.1, batch_first=True),\n                'norm1': nn.LayerNorm(dim, eps=1e-6),\n                'norm2': nn.LayerNorm(dim, eps=1e-6),\n                'mlp': nn.Sequential(\n                    nn.Linear(dim, dim * 4),\n                    nn.GELU(),\n                    nn.Dropout(0.1),\n                    nn.Linear(dim * 4, dim),\n                    nn.Dropout(0.1)\n                )\n            }) for _ in range(num_layers)\n        ])\n\n        self.final_norm = nn.LayerNorm(dim, eps=1e-6)\n        # 🔧 Kept for checkpoint compatibility (not used in forward)\n        self.gnn = PyramidalGNN(dim, dim)\n\n    def forward(self, x):\n        embedded = self.patch_embed(x)\n        B, C, H, W = embedded.shape\n        num_patches = H * W\n        flat = embedded.permute(0, 2, 3, 1).reshape(B, num_patches, C)\n\n        if num_patches != self.num_patches:\n            pos_embed_adaptive = F.interpolate(\n                self.pos_embed.permute(0, 2, 1), size=num_patches, mode='linear', align_corners=False\n            ).permute(0, 2, 1)\n        else:\n            pos_embed_adaptive = self.pos_embed\n        flat = flat + pos_embed_adaptive\n\n        # 🔧 Process ALL patches through attention (replaces broken NetworkX)\n        for block in self.attention_blocks:\n            attn_out, _ = block['attn'](flat, flat, flat)\n            flat = block['norm1'](flat + attn_out)\n            mlp_out = block['mlp'](flat)\n            flat = block['norm2'](flat + mlp_out)\n\n        flat = self.final_norm(flat)\n        return flat.permute(0, 2, 1).reshape(B, C, H, W)\n\n# ============================================================================\n# VAE Components\n# ============================================================================\nclass VAESampling(nn.Module):\n    def __init__(self):\n        super().__init__()\n    def forward(self, mu, logvar):\n        std = torch.exp(0.5 * logvar)\n        eps = torch.randn_like(std)\n        return mu + eps * std\n\nclass VAEEncoder(nn.Module):\n    def __init__(self, latent_dim=128):\n        super().__init__()\n        self.latent_dim = latent_dim\n        self.conv1 = nn.Conv2d(128, 64, kernel_size=4, stride=2, padding=1)\n        self.conv2 = nn.Conv2d(64, 128, kernel_size=4, stride=2, padding=1)\n        self.res_conv = nn.Conv2d(128, 128, kernel_size=3, stride=1, padding=1)\n        self.adaptive_pool = nn.AdaptiveAvgPool2d((2, 2))\n        self.fc_mu = nn.Linear(128 * 2 * 2, latent_dim)\n        self.fc_logvar = nn.Linear(128 * 2 * 2, latent_dim)\n\n    def forward(self, x):\n        B, C, H, W = x.shape\n        if H < 4 or W < 4:\n            x = F.adaptive_avg_pool2d(x, (8, 8))\n        x = F.relu(self.conv1(x))\n        x = F.relu(self.conv2(x))\n        residual = x\n        x = F.relu(self.res_conv(x)) + residual\n        x = self.adaptive_pool(x).flatten(1)\n        return self.fc_mu(x), self.fc_logvar(x)\n\nclass VAEDecoder(nn.Module):\n    def __init__(self, latent_dim=128):\n        super().__init__()\n        self.fc = nn.Linear(latent_dim, 8 * 8 * 128)\n        self.res_conv = nn.Conv2d(128, 128, kernel_size=3, stride=1, padding=1)\n        self.deconv1 = nn.ConvTranspose2d(128, 64, 4, 2, 1)\n        self.deconv2 = nn.ConvTranspose2d(64, 32, 4, 2, 1)\n        self.deconv3 = nn.ConvTranspose2d(32, 3, 4, 2, 1)\n\n    def forward(self, z):\n        x = F.relu(self.fc(z)).view(-1, 128, 8, 8)\n        residual = x\n        x = F.relu(self.res_conv(x)) + residual\n        x = F.relu(self.deconv1(x))\n        x = F.relu(self.deconv2(x))\n        return torch.tanh(self.deconv3(x))\n\n# ============================================================================\n# Edge Detection & Edge Generator\n# ============================================================================\nclass EdgeDetector(nn.Module):\n    def __init__(self):\n        super().__init__()\n        sobel_x = torch.tensor([[-1, 0, 1], [-2, 0, 2], [-1, 0, 1]], dtype=torch.float32).unsqueeze(0).unsqueeze(0)\n        sobel_y = torch.tensor([[-1, -2, -1], [0, 0, 0], [1, 2, 1]], dtype=torch.float32).unsqueeze(0).unsqueeze(0)\n        self.register_buffer('sobel_x', sobel_x.repeat(3, 1, 1, 1))\n        self.register_buffer('sobel_y', sobel_y.repeat(3, 1, 1, 1))\n\n    def forward(self, x):\n        edge_x = F.conv2d(x, self.sobel_x, padding=1, groups=3)\n        edge_y = F.conv2d(x, self.sobel_y, padding=1, groups=3)\n        return torch.sqrt(edge_x ** 2 + edge_y ** 2 + 1e-8)\n\nclass EdgeGenerator(nn.Module):\n    def __init__(self):\n        super().__init__()\n        self.enc1 = nn.Sequential(nn.Conv2d(6, 64, 4, 2, 1), nn.LeakyReLU(0.2, inplace=True))\n        self.enc2 = nn.Sequential(nn.Conv2d(64, 128, 4, 2, 1), nn.LeakyReLU(0.2, inplace=True))\n        self.enc3 = nn.Sequential(nn.Conv2d(128, 256, 4, 2, 1), nn.LeakyReLU(0.2, inplace=True))\n        self.bottleneck = nn.Sequential(nn.Conv2d(256, 512, 4, 2, 1), nn.LeakyReLU(0.2, inplace=True))\n        self.attention = nn.MultiheadAttention(embed_dim=512, num_heads=8, dropout=0.1, batch_first=True)\n        self.attention_norm = nn.LayerNorm(512, eps=1e-6)\n        self.dec1 = nn.Sequential(nn.ConvTranspose2d(512, 256, 4, 2, 1), nn.ReLU(inplace=True))\n        self.dec2 = nn.Sequential(nn.ConvTranspose2d(512, 128, 4, 2, 1), nn.ReLU(inplace=True))\n        self.dec3 = nn.Sequential(nn.ConvTranspose2d(256, 64, 4, 2, 1), nn.ReLU(inplace=True))\n        self.dec4 = nn.Sequential(nn.ConvTranspose2d(128, 3, 4, 2, 1), nn.Sigmoid())\n\n    def forward(self, masked_image, mask):\n        x = torch.cat([masked_image, mask], dim=1)\n        e1 = self.enc1(x)\n        e2 = self.enc2(e1)\n        e3 = self.enc3(e2)\n        bn = self.bottleneck(e3)\n        B, C, H, W = bn.shape\n        attn_in = bn.permute(0, 2, 3, 1).reshape(B, H * W, C)\n        attn_out, _ = self.attention(attn_in, attn_in, attn_in)\n        bn = self.attention_norm(attn_in + attn_out).reshape(B, H, W, C).permute(0, 3, 1, 2)\n        d1 = torch.cat([self.dec1(bn), e3], dim=1)\n        d2 = torch.cat([self.dec2(d1), e2], dim=1)\n        d3 = torch.cat([self.dec3(d2), e1], dim=1)\n        return self.dec4(d3)\n\n# ============================================================================\n# 🔧 FIX: CoarseGenerator - NO new parameters (backward compatible)\n# ============================================================================\nclass CoarseGenerator(nn.Module):\n    def __init__(self):\n        super().__init__()\n        self.preprocessor = ViTPreprocessor(dim=128, num_heads=8, patch_size=8, num_layers=3)\n        self.encoder = VAEEncoder(latent_dim=128)\n        self.sampling = VAESampling()\n        self.decoder = VAEDecoder(latent_dim=128)\n        self.attention = nn.MultiheadAttention(embed_dim=128, num_heads=8, dropout=0.1, batch_first=True)\n        self.attention_norm = nn.LayerNorm(128, eps=1e-6)\n        self.skip_conv = nn.Conv2d(128, 128, kernel_size=1)\n\n    def forward(self, x, mask, edge_map=None):\n        # 🔧 Keep original edge integration (no new edge_proj layer)\n        if edge_map is not None:\n            x = x + edge_map * 0.1\n\n        original_features = self.preprocessor(x)\n\n        B, C, H, W = original_features.shape\n        attn_input = original_features.permute(0, 2, 3, 1).reshape(B, H * W, C)\n        attn_output, _ = self.attention(attn_input, attn_input, attn_input)\n        enhanced_features = self.attention_norm(attn_input + attn_output)\n        enhanced_features = enhanced_features.reshape(B, H, W, C).permute(0, 3, 1, 2)\n        enhanced_features = enhanced_features + self.skip_conv(original_features)\n\n        mu, logvar = self.encoder(enhanced_features)\n        z = self.sampling(mu, logvar)\n        output = self.decoder(z)\n        return output, mu, logvar\n\n# ============================================================================\n# FineGenerator\n# ============================================================================\nclass FineGenerator(nn.Module):\n    def __init__(self):\n        super().__init__()\n        self.enc1 = nn.Sequential(nn.Conv2d(9, 64, 4, 2, 1), nn.LeakyReLU(0.2, inplace=True))\n        self.enc2 = nn.Sequential(nn.Conv2d(64, 128, 4, 2, 1), nn.LeakyReLU(0.2, inplace=True))\n        self.enc3 = nn.Sequential(nn.Conv2d(128, 256, 4, 2, 1), nn.LeakyReLU(0.2, inplace=True))\n        self.bottleneck = nn.Sequential(nn.Conv2d(256, 512, 4, 2, 1), nn.LeakyReLU(0.2, inplace=True))\n        self.attention = nn.MultiheadAttention(embed_dim=512, num_heads=8, dropout=0.1, batch_first=True)\n        self.attention_norm = nn.LayerNorm(512, eps=1e-6)\n        self.dec1 = nn.Sequential(nn.ConvTranspose2d(512, 256, 4, 2, 1), nn.ReLU(inplace=True))\n        self.dec2 = nn.Sequential(nn.ConvTranspose2d(512, 128, 4, 2, 1), nn.ReLU(inplace=True))\n        self.dec3 = nn.Sequential(nn.ConvTranspose2d(256, 64, 4, 2, 1), nn.ReLU(inplace=True))\n        self.dec4 = nn.Sequential(nn.ConvTranspose2d(128, 3, 4, 2, 1), nn.Tanh())\n\n    def forward(self, masked_images, coarse_output, masks, edge_map=None):\n        if masked_images.shape[2:] != coarse_output.shape[2:]:\n            coarse_output = F.interpolate(coarse_output, size=masked_images.shape[2:], mode='bilinear', align_corners=False)\n\n        if edge_map is not None:\n            if edge_map.shape[2:] != masked_images.shape[2:]:\n                edge_map = F.interpolate(edge_map, size=masked_images.shape[2:], mode='bilinear', align_corners=False)\n            edge_map_normalized = edge_map * 2.0 - 1.0\n            x = torch.cat([masked_images, coarse_output, edge_map_normalized], dim=1)\n        else:\n            edge_map_zeros = torch.zeros_like(masked_images)\n            x = torch.cat([masked_images, coarse_output, edge_map_zeros], dim=1)\n\n        e1 = self.enc1(x)\n        e2 = self.enc2(e1)\n        e3 = self.enc3(e2)\n        bn = self.bottleneck(e3)\n        B, C, H, W = bn.shape\n        attn_in = bn.permute(0, 2, 3, 1).reshape(B, H * W, C)\n        attn_out, _ = self.attention(attn_in, attn_in, attn_in)\n        bn = self.attention_norm(attn_in + attn_out).reshape(B, H, W, C).permute(0, 3, 1, 2)\n\n        d1 = torch.cat([self.dec1(bn), e3], dim=1)\n        d2 = torch.cat([self.dec2(d1), e2], dim=1)\n        d3 = torch.cat([self.dec3(d2), e1], dim=1)\n        output = self.dec4(d3)\n\n        if output.shape[2:] != masked_images.shape[2:]:\n            output = F.interpolate(output, size=masked_images.shape[2:], mode='bilinear', align_corners=False)\n        return output\n\n# ============================================================================\n# Discriminator\n# ============================================================================\nclass Discriminator(nn.Module):\n    def __init__(self):\n        super().__init__()\n        self.conv1 = nn.utils.spectral_norm(nn.Conv2d(6, 64, 4, 2, 1))\n        self.conv2 = nn.utils.spectral_norm(nn.Conv2d(64, 128, 4, 2, 1))\n        self.conv3 = nn.utils.spectral_norm(nn.Conv2d(128, 256, 4, 2, 1))\n        self.conv4 = nn.utils.spectral_norm(nn.Conv2d(256, 512, 4, 2, 1))\n        self.conv5 = nn.utils.spectral_norm(nn.Conv2d(512, 512, 3, 1, 1))\n        self.conv6 = nn.utils.spectral_norm(nn.Conv2d(512, 512, 3, 1, 1))\n        self.conv_out = nn.utils.spectral_norm(nn.Conv2d(512, 1, 1, 1, 0))\n\n    def forward(self, x, mask, return_features=False):\n        h = torch.cat([x, mask], dim=1)\n        features = []\n        for layer in [self.conv1, self.conv2, self.conv3, self.conv4, self.conv5, self.conv6]:\n            h = F.leaky_relu(layer(h), 0.2, inplace=True)\n            if return_features:\n                features.append(h)\n        logits = self.conv_out(h)\n        return (logits, features) if return_features else logits\n\n# ============================================================================\n# Utility Functions\n# ============================================================================\ndef make_blend_mask(mask, radius=5):\n    if radius is None or radius <= 0 or mask.dim() != 4:\n        return mask\n    m = (mask[:, :1] > 0.5).float()\n    k = int(radius) * 2 + 1\n    soft = F.avg_pool2d(m, kernel_size=k, stride=1, padding=int(radius))\n    soft = torch.clamp(soft, 0.0, 1.0) * m\n    if mask.shape[1] != 1:\n        soft = soft.repeat(1, mask.shape[1], 1, 1)\n    return soft\n\ndef generate_adaptive_mask(image):\n    batch_size = image.shape[0]\n    h, w = image_size\n    half_height = h // 2\n    jitter = 4\n    cuts = half_height + torch.randint(-jitter, jitter + 1, (batch_size,), device=image.device)\n    cuts = torch.clamp(cuts, min=0, max=h).to(torch.long)\n    mask = torch.zeros(batch_size, 1, h, w, dtype=torch.float32, device=image.device)\n    for i in range(batch_size):\n        mask[i, :, :cuts[i], :] = 1.0\n    return mask.repeat(1, 3, 1, 1)\n\n# ============================================================================\n# Loss Functions - VGG\n# ============================================================================\ntry:\n    vgg_weights = models.VGG16_Weights.DEFAULT\nexcept AttributeError:\n    vgg_weights = None\nvgg = models.vgg16(weights=vgg_weights).features.to(device).eval()\nloss_model = nn.Sequential(*[vgg[i] for i in range(16)]).to(device)\nfor param in loss_model.parameters():\n    param.requires_grad = False\n\nedge_detector_global = EdgeDetector().to(device).eval()\nfor param in edge_detector_global.parameters():\n    param.requires_grad = False\n\n_sobel_x = torch.tensor([[-1, 0, 1], [-2, 0, 2], [-1, 0, 1]], dtype=torch.float32).unsqueeze(0).unsqueeze(0).repeat(3, 1, 1, 1).to(device)\n_sobel_y = torch.tensor([[-1, -2, -1], [0, 0, 0], [1, 2, 1]], dtype=torch.float32).unsqueeze(0).unsqueeze(0).repeat(3, 1, 1, 1).to(device)\n\ndef perceptual_loss(y_true, y_pred):\n    y_true = F.interpolate(y_true, size=image_size, mode='bilinear', align_corners=False) * 0.5 + 0.5\n    y_pred = F.interpolate(y_pred, size=image_size, mode='bilinear', align_corners=False) * 0.5 + 0.5\n    return torch.mean((loss_model(y_true) - loss_model(y_pred)) ** 2)\n\ndef style_loss(y_true, y_pred):\n    y_true = F.interpolate(y_true, size=image_size, mode='bilinear', align_corners=False) * 0.5 + 0.5\n    y_pred = F.interpolate(y_pred, size=image_size, mode='bilinear', align_corners=False) * 0.5 + 0.5\n    t_feat, p_feat = loss_model(y_true), loss_model(y_pred)\n    def gram(f):\n        B, C, H, W = f.shape\n        f = f.view(B, C, H * W)\n        return torch.bmm(f, f.transpose(1, 2)) / (C * H * W)\n    return torch.mean((gram(t_feat) - gram(p_feat)) ** 2)\n\ndef l1_masked_loss(y_true, y_pred, mask):\n    \"\"\"L1 in masked region (combines old l1 + rec + identity + facial)\"\"\"\n    bottom_region = (mask == 0).float()\n    diff = torch.abs(y_true - y_pred) * bottom_region\n    return diff.sum() / (bottom_region.sum() + 1e-8)\n\ndef feature_matching_loss(real_features, fake_features):\n    return torch.mean(torch.stack([torch.mean((r - f) ** 2) for r, f in zip(real_features, fake_features)]))\n\ndef combined_edge_gradient_loss(y_true, y_pred, mask):\n    bottom_region = (mask == 0).float()\n    with torch.no_grad():\n        edges_true = edge_detector_global(y_true * 0.5 + 0.5)\n    edges_pred = edge_detector_global(y_pred * 0.5 + 0.5)\n    edge_diff = torch.abs(edges_true - edges_pred) * bottom_region\n\n    grad_true_x = F.conv2d(y_true, _sobel_x, padding=1, groups=3)\n    grad_true_y = F.conv2d(y_true, _sobel_y, padding=1, groups=3)\n    grad_true = torch.sqrt(grad_true_x ** 2 + grad_true_y ** 2 + 1e-8)\n    grad_pred_x = F.conv2d(y_pred, _sobel_x, padding=1, groups=3)\n    grad_pred_y = F.conv2d(y_pred, _sobel_y, padding=1, groups=3)\n    grad_pred = torch.sqrt(grad_pred_x ** 2 + grad_pred_y ** 2 + 1e-8)\n    grad_diff = torch.abs(grad_true - grad_pred) * bottom_region\n    return edge_diff.mean() + grad_diff.mean()\n\n# ============================================================================\n# 🔧 CRITICAL FIX: differentiable_ssim_loss with float32 + variance clamping\n# ============================================================================\ndef differentiable_ssim_loss(y_true, y_pred, mask):\n    # 🔧 FORCE float32 - this prevents NaN in mixed precision\n    with torch.amp.autocast('cuda', enabled=False):\n        y_t = y_true.float() * 0.5 + 0.5\n        y_p = y_pred.float() * 0.5 + 0.5\n        bottom_region = mask.float()\n        # 🔧 Only compute SSIM in bottom half (avoid 0/0 in masked-out region)\n        y_t_masked = y_t * bottom_region\n        y_p_masked = y_p * bottom_region\n\n        C1 = 0.01 ** 2\n        C2 = 0.03 ** 2\n\n        mu_t = F.avg_pool2d(y_t_masked, 7, stride=1, padding=3)\n        mu_p = F.avg_pool2d(y_p_masked, 7, stride=1, padding=3)\n\n        sigma_t = F.avg_pool2d(y_t_masked ** 2, 7, stride=1, padding=3) - mu_t ** 2\n        sigma_p = F.avg_pool2d(y_p_masked ** 2, 7, stride=1, padding=3) - mu_p ** 2\n        sigma_cross = F.avg_pool2d(y_t_masked * y_p_masked, 7, stride=1, padding=3) - mu_t * mu_p\n\n        # 🔧 CRITICAL: Clamp variances to prevent negative values (float precision)\n        sigma_t = torch.clamp(sigma_t, min=0.0)\n        sigma_p = torch.clamp(sigma_p, min=0.0)\n\n        ssim_map = ((2 * mu_t * mu_p + C1) * (2 * sigma_cross + C2)) / \\\n                   ((mu_t ** 2 + mu_p ** 2 + C1) * (sigma_t + sigma_p + C2))\n\n        # 🔧 Only average over the masked region\n        ssim_masked = ssim_map * bottom_region\n        valid_pixels = bottom_region.sum() / bottom_region.numel() * ssim_map.numel()\n        ssim_val = ssim_masked.sum() / (valid_pixels + 1e-8)\n\n        loss = 1.0 - ssim_val\n        # 🔧 Final safety: clamp to valid range\n        loss = torch.clamp(loss, min=0.0, max=1.0)\n        return loss\n\ndef gradient_penalty_loss(discriminator, real_images, fake_images, masks, device):\n    batch_size = real_images.size(0)\n    alpha = torch.rand(batch_size, 1, 1, 1).to(device)\n    interpolated = (alpha * real_images + (1 - alpha) * fake_images).detach().requires_grad_(True)\n    disc_interpolated = discriminator(interpolated, masks)\n    if not disc_interpolated.requires_grad:\n        return torch.tensor(0.0, device=device, requires_grad=True)\n    gradients = torch.autograd.grad(\n        outputs=disc_interpolated, inputs=interpolated,\n        grad_outputs=torch.ones_like(disc_interpolated).to(device),\n        create_graph=True, retain_graph=True, only_inputs=True\n    )[0]\n    return ((gradients.view(gradients.size(0), -1).norm(2, dim=1) - 1) ** 2).mean()\n\n# ============================================================================\n# 🔧 CRITICAL FIX: generator_loss computes in float32\n# ============================================================================\ndef generator_loss(disc_fake_logits, y_true, y_pred, disc_features_real, disc_features_fake, mask, mu, logvar):\n    # 🔧 CRITICAL: Force float32 for ALL loss computations\n    with torch.amp.autocast('cuda', enabled=False):\n        disc_fake_logits = disc_fake_logits.float()\n        y_true = y_true.float()\n        y_pred = y_pred.float()\n        mu = mu.float()\n        logvar = torch.clamp(logvar.float(), min=-10, max=10)\n        disc_features_real = [f.float() for f in disc_features_real]\n        disc_features_fake = [f.float() for f in disc_features_fake]\n        mask = mask.float()\n\n        # 1. Adversarial loss\n        adv_loss = -torch.mean(disc_fake_logits)\n        adv_loss = torch.nan_to_num(adv_loss, nan=0.0, posinf=0.0, neginf=0.0)\n\n        # 2. L1 reconstruction (PSNR driver)\n        l1_loss = l1_masked_loss(y_true, y_pred, mask)\n        l1_loss = torch.nan_to_num(l1_loss, nan=0.0, posinf=0.0, neginf=0.0)\n\n        # 3. Perceptual loss on blended output\n        blend_masks = make_blend_mask(mask)\n        completion = y_true * blend_masks + y_pred * (1.0 - blend_masks)\n        perc_loss = perceptual_loss(y_true, completion)\n        perc_loss = torch.nan_to_num(perc_loss, nan=0.0, posinf=0.0, neginf=0.0)\n\n        # 4. Style loss\n        sty_loss = style_loss(y_true, y_pred)\n        sty_loss = torch.nan_to_num(sty_loss, nan=0.0, posinf=0.0, neginf=0.0)\n\n        # 5. Feature matching loss\n        fm_loss = feature_matching_loss(disc_features_real, disc_features_fake)\n        fm_loss = torch.nan_to_num(fm_loss, nan=0.0, posinf=0.0, neginf=0.0)\n\n        # 6. Combined edge + gradient loss\n        edge_grad_loss = combined_edge_gradient_loss(y_true, y_pred, mask)\n        edge_grad_loss = torch.nan_to_num(edge_grad_loss, nan=0.0, posinf=0.0, neginf=0.0)\n\n        # 7. Differentiable SSIM loss (now float32 safe)\n        ssim_loss = differentiable_ssim_loss(y_true, y_pred, mask)\n        ssim_loss = torch.nan_to_num(ssim_loss, nan=0.0, posinf=0.0, neginf=0.0)\n\n        # 8. KL divergence\n        kl_loss = -0.5 * torch.mean(1 + logvar - mu ** 2 - torch.exp(logvar))\n        kl_loss = torch.clamp(torch.nan_to_num(kl_loss, nan=0.0, posinf=0.0, neginf=0.0), min=0.0, max=10.0)\n\n        total_loss = (lambda_adv * adv_loss +\n                      lambda_l1 * l1_loss +\n                      lambda_perc * perc_loss +\n                      lambda_style * sty_loss +\n                      lambda_fm * fm_loss +\n                      lambda_edge * edge_grad_loss +\n                      lambda_ssim * ssim_loss +\n                      lambda_vae * kl_loss)\n\n        # 🔧 Per-component NaN check with logging\n        if torch.isnan(total_loss) or torch.isinf(total_loss):\n            components = {\n                'adv': adv_loss, 'l1': l1_loss, 'perc': perc_loss,\n                'sty': sty_loss, 'fm': fm_loss, 'edge': edge_grad_loss,\n                'ssim': ssim_loss, 'kl': kl_loss\n            }\n            for name, val in components.items():\n                if torch.isnan(val) or torch.isinf(val):\n                    print(f\"⚠️ NaN/Inf in {name}_loss: {val.item():.6f}\")\n            total_loss = torch.nan_to_num(total_loss, nan=0.0, posinf=0.0, neginf=0.0)\n\n        return total_loss\n\ndef discriminator_loss(disc_real_logits, disc_fake_logits):\n    # 🔧 Force float32\n    with torch.amp.autocast('cuda', enabled=False):\n        disc_real_logits = torch.clamp(disc_real_logits.float(), min=-5, max=5)\n        disc_fake_logits = torch.clamp(disc_fake_logits.float(), min=-5, max=5)\n        real_loss = torch.mean(F.relu(1.0 - disc_real_logits))\n        fake_loss = torch.mean(F.relu(1.0 + disc_fake_logits))\n        reg = lambda_d_reg * (torch.mean(disc_real_logits ** 2) + torch.mean(disc_fake_logits ** 2))\n        total = real_loss + fake_loss + reg\n        return torch.nan_to_num(total, nan=0.0, posinf=0.0, neginf=0.0)\n\n# ============================================================================\n# Evaluation functions\n# ============================================================================\ndef calculate_psnr_bottom_half(y_true, y_pred, mask):\n    y_true = y_true * 0.5 + 0.5\n    y_pred = y_pred * 0.5 + 0.5\n    bottom_mask = (mask == 0).float()\n    psnr_vals = []\n    for i in range(y_true.shape[0]):\n        true_img = (y_true * bottom_mask)[i].permute(1, 2, 0).cpu().detach().numpy()\n        pred_img = (y_pred * bottom_mask)[i].permute(1, 2, 0).cpu().detach().numpy()\n        psnr_vals.append(psnr(true_img, pred_img, data_range=1.0))\n    return torch.mean(torch.tensor(psnr_vals, device=device))\n\ndef calculate_ssim_bottom_half(y_true, y_pred, mask):\n    y_true = y_true * 0.5 + 0.5\n    y_pred = y_pred * 0.5 + 0.5\n    bottom_mask = (mask == 0).float()\n    ssim_vals = []\n    for i in range(y_true.shape[0]):\n        true_img = (y_true * bottom_mask)[i].permute(1, 2, 0).cpu().detach().numpy()\n        pred_img = (y_pred * bottom_mask)[i].permute(1, 2, 0).cpu().detach().numpy()\n        ssim_vals.append(ssim(true_img, pred_img, channel_axis=2, data_range=1.0, win_size=7))\n    return torch.mean(torch.tensor(ssim_vals, device=device))\n\ndef calculate_mse_bottom_half(y_true, y_pred, mask):\n    bottom_region = (mask == 0).float()\n    diff = (y_true - y_pred) ** 2 * bottom_region\n    return diff.sum() / (bottom_region.sum() + 1e-8)\n\n# ============================================================================\n# Training Step\n# ============================================================================\ndef train_step(images, edge_generator, coarse_generator, fine_generator, discriminator,\n               edge_optimizer, g_optimizer, d_optimizer, scaler):\n    images = images.to(device)\n    masks = generate_adaptive_mask(images)\n    blend_masks = make_blend_mask(masks)\n    masked_images = images * masks\n\n    # ---- Discriminator update ----\n    d_optimizer.zero_grad()\n    d_loss_accumulated = 0.0\n    for _ in range(n_critic):\n        with amp.autocast('cuda'):\n            with torch.no_grad():\n                edge_map = edge_generator(masked_images, masks)\n                coarse_output, mu, logvar = coarse_generator(masked_images, masks, edge_map)\n                if coarse_output.shape != images.shape:\n                    coarse_output = F.interpolate(coarse_output, size=images.shape[2:], mode='bilinear', align_corners=False)\n                fine_output = fine_generator(masked_images, coarse_output, masks, edge_map)\n                if fine_output.shape != images.shape:\n                    fine_output = F.interpolate(fine_output, size=images.shape[2:], mode='bilinear', align_corners=False)\n                combined_input = images * blend_masks + fine_output * (1.0 - blend_masks)\n\n            combined_input_detached = combined_input.detach()\n            disc_real_logits = discriminator(images, masks, return_features=False)\n            disc_fake_logits = discriminator(combined_input_detached, masks, return_features=False)\n            d_loss = discriminator_loss(disc_real_logits, disc_fake_logits)\n            gp = gradient_penalty_loss(discriminator, images, combined_input_detached, masks, device)\n            d_loss = d_loss + lambda_gp * gp\n\n        scaler.scale(d_loss).backward()\n        d_loss_accumulated += d_loss.item()\n\n    scaler.unscale_(d_optimizer)\n    torch.nn.utils.clip_grad_norm_(discriminator.parameters(), max_norm=1.0)\n    scaler.step(d_optimizer)\n    d_loss_val = d_loss_accumulated / n_critic\n\n    # ---- Generator + Edge update ----\n    edge_optimizer.zero_grad()\n    g_optimizer.zero_grad()\n\n    with amp.autocast('cuda'):\n        # Forward pass in mixed precision\n        edge_map = edge_generator(masked_images, masks)\n        coarse_output, mu, logvar = coarse_generator(masked_images, masks, edge_map)\n        if coarse_output.shape != images.shape:\n            coarse_output = F.interpolate(coarse_output, size=images.shape[2:], mode='bilinear', align_corners=False)\n        fine_output = fine_generator(masked_images, coarse_output, masks, edge_map)\n        if fine_output.shape != images.shape:\n            fine_output = F.interpolate(fine_output, size=images.shape[2:], mode='bilinear', align_corners=False)\n        combined_input = images * blend_masks + fine_output * (1.0 - blend_masks)\n\n        disc_real_logits, disc_features_real = discriminator(images, masks, return_features=True)\n        disc_fake_logits, disc_features_fake = discriminator(combined_input, masks, return_features=True)\n\n    # 🔧 CRITICAL FIX: Compute losses OUTSIDE autocast in float32\n    with amp.autocast('cuda', enabled=False):\n        # Edge reconstruction loss\n        with torch.no_grad():\n            true_edges = edge_detector_global(images.float() * 0.5 + 0.5)\n        bottom_region = (masks == 0).float()\n        edge_recon_loss = torch.mean(torch.abs(true_edges - edge_map.float()) * bottom_region)\n        edge_recon_loss = torch.nan_to_num(edge_recon_loss, nan=0.0, posinf=0.0, neginf=0.0)\n\n        # Generator loss (already float32 inside)\n        g_loss = generator_loss(\n            disc_fake_logits, images, fine_output,\n            disc_features_real, disc_features_fake, masks, mu, logvar\n        )\n\n    total_gen_loss = edge_recon_loss + g_loss\n    scaler.scale(total_gen_loss).backward()\n\n    scaler.unscale_(edge_optimizer)\n    scaler.unscale_(g_optimizer)\n    torch.nn.utils.clip_grad_norm_(edge_generator.parameters(), max_norm=1.0)\n    torch.nn.utils.clip_grad_norm_(\n        list(coarse_generator.parameters()) + list(fine_generator.parameters()), max_norm=1.0)\n\n    scaler.step(edge_optimizer)\n    scaler.step(g_optimizer)\n    scaler.update()\n\n    g_loss_val = g_loss.item()\n    edge_loss_val = edge_recon_loss.item()\n\n    if np.isnan(g_loss_val) or np.isinf(g_loss_val):\n        print(f\"⚠️ WARNING: G_Loss is {g_loss_val}\")\n        g_loss_val = 0.0\n    if np.isnan(d_loss_val) or np.isinf(d_loss_val):\n        print(f\"⚠️ WARNING: D_Loss is {d_loss_val}\")\n        d_loss_val = 0.0\n    if np.isnan(edge_loss_val) or np.isinf(edge_loss_val):\n        print(f\"⚠️ WARNING: Edge_Loss is {edge_loss_val}\")\n        edge_loss_val = 0.0\n\n    return g_loss_val, d_loss_val, edge_loss_val\n\n# ============================================================================\n# DATASET LOADING\n# ============================================================================\nceleba_dir = '/kaggle/input/datasets/masoudshahrian/celeba-6464/selected_celeba'\nprint(f\"Loading dataset from {celeba_dir}...\")\ntrain_files, val_files, test_files = split_dataset(celeba_dir)\ntrain_loader, val_loader, test_loader = create_split_datasets(\n    celeba_dir, train_files, val_files, test_files, image_size, batch_size)\n\n# ============================================================================\n# MODEL INITIALIZATION\n# ============================================================================\nprint(\"Building models...\")\nedge_generator = EdgeGenerator().to(device)\ncoarse_generator = CoarseGenerator().to(device)\nfine_generator = FineGenerator().to(device)\ndiscriminator = Discriminator().to(device)\n\nprint(f\"Edge Gen: {sum(p.numel() for p in edge_generator.parameters()):,}\")\nprint(f\"Coarse Gen: {sum(p.numel() for p in coarse_generator.parameters()):,}\")\nprint(f\"Fine Gen: {sum(p.numel() for p in fine_generator.parameters()):,}\")\nprint(f\"Discriminator: {sum(p.numel() for p in discriminator.parameters()):,}\")\n\nprint(\"\\nTesting model dimensions...\")\nwith torch.no_grad():\n    test_input = torch.randn(1, 3, 64, 64).to(device)\n    test_mask = torch.randn(1, 3, 64, 64).to(device)\n    coarse_out, mu, logvar = coarse_generator(test_input, test_mask)\n    print(f\"Coarse: {coarse_out.shape}, Fine: {fine_generator(test_input, coarse_out, test_mask).shape}\")\n    disc_logits, disc_feats = discriminator(test_input, test_mask, return_features=True)\n    print(f\"Disc: logits={disc_logits.shape}, features={len(disc_feats)}\")\n    print(\"✓ Dimensions correct!\")\n\n# ============================================================================\n# OPTIMIZERS & SCHEDULERS\n# ============================================================================\nedge_optimizer = torch.optim.AdamW(edge_generator.parameters(), lr=learning_rate_g, betas=(0.5, 0.999), weight_decay=1e-4)\ng_optimizer = torch.optim.AdamW(\n    list(coarse_generator.parameters()) + list(fine_generator.parameters()),\n    lr=learning_rate_g, betas=(0.5, 0.999), weight_decay=1e-4)\nd_optimizer = torch.optim.AdamW(discriminator.parameters(), lr=learning_rate_d, betas=(0.5, 0.999), weight_decay=1e-4)\n\ntry:\n    edge_scheduler = torch.optim.lr_scheduler.ReduceLROnPlateau(edge_optimizer, mode='min', factor=0.5, patience=5, verbose=True, min_lr=learning_rate_g * 0.01)\n    g_scheduler = torch.optim.lr_scheduler.ReduceLROnPlateau(g_optimizer, mode='min', factor=0.5, patience=5, verbose=True, min_lr=learning_rate_g * 0.01)\n    d_scheduler = torch.optim.lr_scheduler.ReduceLROnPlateau(d_optimizer, mode='min', factor=0.5, patience=5, verbose=True, min_lr=learning_rate_d * 0.01)\nexcept TypeError:\n    edge_scheduler = torch.optim.lr_scheduler.ReduceLROnPlateau(edge_optimizer, mode='min', factor=0.5, patience=5, min_lr=learning_rate_g * 0.01)\n    g_scheduler = torch.optim.lr_scheduler.ReduceLROnPlateau(g_optimizer, mode='min', factor=0.5, patience=5, min_lr=learning_rate_g * 0.01)\n    d_scheduler = torch.optim.lr_scheduler.ReduceLROnPlateau(d_optimizer, mode='min', factor=0.5, patience=5, min_lr=learning_rate_d * 0.01)\n\nscaler = amp.GradScaler('cuda')\n\n# Health check\nprint(\"\\n🔍 Model Health Check\")\nwith torch.no_grad():\n    test_batch = next(iter(train_loader)).to(device)\n    test_masks = generate_adaptive_mask(test_batch)\n    test_masked = test_batch * test_masks\n    try:\n        edge_map = edge_generator(test_masked, test_masks)\n        coarse_out, mu, logvar = coarse_generator(test_masked, test_masks, edge_map)\n        fine_out = fine_generator(test_masked, coarse_out, test_masks, edge_map)\n        disc_out = discriminator(test_batch, test_masks)\n        print(f\"✓ Edge: {edge_map.shape}, Coarse: {coarse_out.shape}, Fine: {fine_out.shape}\")\n        print(f\"✓ mu: [{mu.min().item():.4f}, {mu.max().item():.4f}]\")\n        print(\"✅ All models healthy!\")\n    except Exception as e:\n        print(f\"❌ Health check failed: {e}\")\n        raise\n\n# ============================================================================\n# CHECKPOINT LOADING\n# ============================================================================\nif USE_KAGGLE_INPUT:\n    checkpoint_load_dir = os.path.join(KAGGLE_INPUT_DATASET, 'checkpoints')\n    models_load_dir = os.path.join(KAGGLE_INPUT_DATASET, 'models')\nelse:\n    checkpoint_load_dir = CHECKPOINT_DIR\n    models_load_dir = MODELS_DIR\n\nos.makedirs(CHECKPOINT_DIR, exist_ok=True)\nos.makedirs(MODELS_DIR, exist_ok=True)\n\nstart_epoch = 0\nbest_val_loss = float('inf')\ntrain_g_losses, train_d_losses, val_g_losses, val_d_losses = [], [], [], []\ncheckpoint_loaded = False\nmodels_loaded = False\n\nif RESUME_TRAINING:\n    if LOAD_FROM_MODELS and not checkpoint_loaded:\n        suffix = \"_best.pth\" if USE_BEST_MODELS else \"_bottom_half.pth\"\n        model_files = {\n            'edge': os.path.join(models_load_dir, f'edge_generator{suffix}'),\n            'coarse': os.path.join(models_load_dir, f'coarse_generator{suffix}'),\n            'fine': os.path.join(models_load_dir, f'fine_generator{suffix}'),\n            'disc': os.path.join(models_load_dir, f'discriminator{suffix}')\n        }\n        print(f\"\\n🔍 Looking for model files ({suffix}):\")\n        for name, path in model_files.items():\n            exists = \"✅\" if os.path.exists(path) else \"❌\"\n            print(f\"   {exists} {os.path.basename(path)}\")\n\n        existing = {n: p for n, p in model_files.items() if os.path.exists(p)}\n        if existing:\n            try:\n                for name, path in existing.items():\n                    model = {'edge': edge_generator, 'coarse': coarse_generator,\n                             'fine': fine_generator, 'disc': discriminator}[name]\n                    sd = torch.load(path, map_location=device)\n                    missing, unexpected = model.load_state_dict(sd, strict=False)\n                    if missing or unexpected:\n                        print(f\"[{name}] {len(missing)} missing, {len(unexpected)} unexpected keys\")\n                models_loaded = True\n                print(\"✅ MODEL WEIGHTS LOADED!\")\n            except Exception as e:\n                print(f\"⚠️ Failed: {e}\")\n\n    if not checkpoint_loaded and not models_loaded:\n        for ckpt_path in [\n            os.path.join(checkpoint_load_dir, 'latest_checkpoint.pth'),\n            os.path.join(CHECKPOINT_DIR, 'latest_checkpoint.pth'),\n        ]:\n            if os.path.exists(ckpt_path):\n                try:\n                    checkpoint = torch.load(ckpt_path, map_location=device)\n                    if 'edge_generator' in checkpoint:\n                        edge_generator.load_state_dict(checkpoint['edge_generator'], strict=False)\n                    coarse_generator.load_state_dict(checkpoint['coarse_generator'], strict=False)\n                    fine_generator.load_state_dict(checkpoint['fine_generator'], strict=False)\n                    discriminator.load_state_dict(checkpoint['discriminator'], strict=False)\n                    g_optimizer.load_state_dict(checkpoint['g_optimizer'])\n                    d_optimizer.load_state_dict(checkpoint['d_optimizer'])\n                    if 'edge_optimizer' in checkpoint:\n                        edge_optimizer.load_state_dict(checkpoint['edge_optimizer'])\n                    g_scheduler.load_state_dict(checkpoint['g_scheduler'])\n                    d_scheduler.load_state_dict(checkpoint['d_scheduler'])\n                    if 'edge_scheduler' in checkpoint:\n                        edge_scheduler.load_state_dict(checkpoint['edge_scheduler'])\n                    start_epoch = checkpoint['epoch'] + 1\n                    best_val_loss = checkpoint.get('best_val_loss', float('inf'))\n                    train_g_losses = checkpoint.get('train_g_losses', [])\n                    train_d_losses = checkpoint.get('train_d_losses', [])\n                    val_g_losses = checkpoint.get('val_g_losses', [])\n                    val_d_losses = checkpoint.get('val_d_losses', [])\n                    checkpoint_loaded = True\n                    print(f\"✅ CHECKPOINT LOADED! From epoch {start_epoch}\")\n                    break\n                except Exception as e:\n                    print(f\"⚠️ Failed: {e}\")\n\nif not checkpoint_loaded and not models_loaded:\n    print(\"🆕 Starting from scratch.\" if not RESUME_TRAINING else \"⚠️ No checkpoints found, starting from scratch.\")\n\nprint(f\"\\n🎯 Training: epoch {start_epoch + 1} to {num_epochs}\")\n\n# ============================================================================\n# TRAINING LOOP\n# ============================================================================\nfor epoch in range(start_epoch, num_epochs):\n    print(f\"\\nEpoch {epoch + 1}/{num_epochs}\")\n    edge_generator.train()\n    coarse_generator.train()\n    fine_generator.train()\n    discriminator.train()\n\n    epoch_g_loss = epoch_d_loss = epoch_edge_loss = num_batches = 0\n\n    for step, images in enumerate(train_loader):\n        g_loss_batch, d_loss_batch, edge_loss_batch = train_step(\n            images, edge_generator, coarse_generator, fine_generator, discriminator,\n            edge_optimizer, g_optimizer, d_optimizer, scaler)\n        epoch_g_loss += g_loss_batch\n        epoch_d_loss += d_loss_batch\n        epoch_edge_loss += edge_loss_batch\n        num_batches += 1\n\n        if step % 50 == 0:\n            print(f\"  Step {step:3d}: Edge={edge_loss_batch:.4f}, G={g_loss_batch:.4f}, D={d_loss_batch:.4f}\")\n\n        if np.isnan(g_loss_batch) and np.isnan(d_loss_batch):\n            print(f\"⚠️ CRITICAL: Both NaN at step {step}. Stopping.\")\n            break\n\n    avg_g_loss = epoch_g_loss / num_batches if num_batches > 0 else 0\n    avg_d_loss = epoch_d_loss / num_batches if num_batches > 0 else 0\n    avg_edge_loss = epoch_edge_loss / num_batches if num_batches > 0 else 0\n    train_g_losses.append(avg_g_loss)\n    train_d_losses.append(avg_d_loss)\n    print(f\"Epoch {epoch + 1} Train - Edge: {avg_edge_loss:.4f}, G: {avg_g_loss:.4f}, D: {avg_d_loss:.4f}\")\n\n    # ---- Validation ----\n    edge_generator.eval()\n    coarse_generator.eval()\n    fine_generator.eval()\n    discriminator.eval()\n\n    val_g_loss = val_d_loss = val_batches = 0\n    with torch.no_grad():\n        for images in val_loader:\n            images = images.to(device)\n            masks = generate_adaptive_mask(images)\n            masked_images = images * masks\n\n            edge_map = edge_generator(masked_images, masks)\n            coarse_output, mu, logvar = coarse_generator(masked_images, masks, edge_map)\n            if coarse_output.shape != images.shape:\n                coarse_output = F.interpolate(coarse_output, size=images.shape[2:], mode='bilinear', align_corners=False)\n            fine_output = fine_generator(masked_images, coarse_output, masks, edge_map)\n            if fine_output.shape != images.shape:\n                fine_output = F.interpolate(fine_output, size=images.shape[2:], mode='bilinear', align_corners=False)\n\n            blend_masks = make_blend_mask(masks)\n            combined_input = images * blend_masks + fine_output * (1.0 - blend_masks)\n\n            disc_real_logits, disc_features_real = discriminator(images, masks, return_features=True)\n            disc_fake_logits, disc_features_fake = discriminator(combined_input, masks, return_features=True)\n\n            g_loss = generator_loss(disc_fake_logits, images, fine_output,\n                                    disc_features_real, disc_features_fake, masks, mu, logvar)\n            d_loss = discriminator_loss(disc_real_logits, disc_fake_logits)\n            val_g_loss += g_loss.item()\n            val_d_loss += d_loss.item()\n            val_batches += 1\n\n    avg_val_g_loss = val_g_loss / val_batches if val_batches > 0 else 0\n    avg_val_d_loss = val_d_loss / val_batches if val_batches > 0 else 0\n    val_g_losses.append(avg_val_g_loss)\n    val_d_losses.append(avg_val_d_loss)\n    print(f\"Epoch {epoch + 1} Val - G: {avg_val_g_loss:.4f}, D: {avg_val_d_loss:.4f}\")\n\n    edge_scheduler.step(avg_val_g_loss)\n    g_scheduler.step(avg_val_g_loss)\n    d_scheduler.step(avg_val_d_loss)\n\n    # Save best models\n    if avg_val_g_loss < best_val_loss:\n        best_val_loss = avg_val_g_loss\n        print(f\"🏆 New best val loss! Saving best models...\")\n        os.makedirs('/kaggle/working/models', exist_ok=True)\n        torch.save(edge_generator.state_dict(), \"/kaggle/working/models/edge_generator_best.pth\")\n        torch.save(coarse_generator.state_dict(), \"/kaggle/working/models/coarse_generator_best.pth\")\n        torch.save(fine_generator.state_dict(), \"/kaggle/working/models/fine_generator_best.pth\")\n        torch.save(discriminator.state_dict(), \"/kaggle/working/models/discriminator_best.pth\")\n\n    # Save checkpoint periodically\n    if (epoch + 1) % CHECKPOINT_INTERVAL == 0:\n        checkpoint = {\n            'epoch': epoch,\n            'edge_generator': edge_generator.state_dict(),\n            'coarse_generator': coarse_generator.state_dict(),\n            'fine_generator': fine_generator.state_dict(),\n            'discriminator': discriminator.state_dict(),\n            'edge_optimizer': edge_optimizer.state_dict(),\n            'g_optimizer': g_optimizer.state_dict(),\n            'd_optimizer': d_optimizer.state_dict(),\n            'edge_scheduler': edge_scheduler.state_dict(),\n            'g_scheduler': g_scheduler.state_dict(),\n            'd_scheduler': d_scheduler.state_dict(),\n            'best_val_loss': best_val_loss,\n            'train_g_losses': train_g_losses,\n            'train_d_losses': train_d_losses,\n            'val_g_losses': val_g_losses,\n            'val_d_losses': val_d_losses,\n        }\n        ckpt_path = os.path.join(CHECKPOINT_DIR, f'checkpoint_epoch_{epoch + 1}.pth')\n        torch.save(checkpoint, ckpt_path)\n        torch.save(checkpoint, os.path.join(CHECKPOINT_DIR, 'latest_checkpoint.pth'))\n        print(f\"💾 Checkpoint saved: epoch {epoch + 1}\")\n\n    # Plot progress\n    if (epoch + 1) % 5 == 0 and len(train_g_losses) > 1:\n        plt.figure(figsize=(15, 5))\n        plt.subplot(1, 3, 1)\n        plt.plot(train_g_losses, label='G Train', color='blue')\n        plt.plot(val_g_losses, label='G Val', color='lightblue')\n        plt.title('Generator Loss')\n        plt.legend(); plt.grid(True, alpha=0.3)\n\n        plt.subplot(1, 3, 2)\n        plt.plot(train_d_losses, label='D Train', color='red')\n        plt.plot(val_d_losses, label='D Val', color='lightcoral')\n        plt.title('Discriminator Loss')\n        plt.legend(); plt.grid(True, alpha=0.3)\n\n        plt.subplot(1, 3, 3)\n        plt.plot(train_g_losses, label='G', color='blue')\n        plt.plot(train_d_losses, label='D', color='red')\n        plt.title('G vs D')\n        plt.legend(); plt.grid(True, alpha=0.3)\n\n        plt.tight_layout()\n        plt.savefig(f'/kaggle/working/training_progress_epoch_{epoch + 1}.png', dpi=150, bbox_inches='tight')\n        plt.show()\n\n# Save final models\nprint(\"Saving final models...\")\nos.makedirs('/kaggle/working/models', exist_ok=True)\ntorch.save(edge_generator.state_dict(), \"/kaggle/working/models/edge_generator_bottom_half.pth\")\ntorch.save(coarse_generator.state_dict(), \"/kaggle/working/models/coarse_generator_bottom_half.pth\")\ntorch.save(fine_generator.state_dict(), \"/kaggle/working/models/fine_generator_bottom_half.pth\")\ntorch.save(discriminator.state_dict(), \"/kaggle/working/models/discriminator_bottom_half.pth\")\n\n# ============================================================================\n# EVALUATION\n# ============================================================================\nprint(\"\\nStarting evaluation...\")\nos.makedirs('/kaggle/working/results', exist_ok=True)\nedge_generator.eval()\ncoarse_generator.eval()\nfine_generator.eval()\ndiscriminator.eval()\n\npsnr_values, ssim_values, mse_values = [], [], []\nnum_samples = 10\nplt.figure(figsize=(20, 10))\n\nwith torch.no_grad():\n    for i, images in enumerate(test_loader):\n        if i >= num_samples:\n            break\n        images = images.to(device)\n        masks = generate_adaptive_mask(images)\n        masked_images = images * masks\n\n        edge_map = edge_generator(masked_images, masks)\n        coarse_output, mu, logvar = coarse_generator(masked_images, masks, edge_map)\n        if coarse_output.shape != images.shape:\n            coarse_output = F.interpolate(coarse_output, size=images.shape[2:], mode='bilinear', align_corners=False)\n        fine_output = fine_generator(masked_images, coarse_output, masks, edge_map)\n        if fine_output.shape != images.shape:\n            fine_output = F.interpolate(fine_output, size=images.shape[2:], mode='bilinear', align_corners=False)\n\n        blend_masks = make_blend_mask(masks)\n        reconstructed = images * blend_masks + fine_output * (1.0 - blend_masks)\n\n        # 🔧 Clamp reconstructed to [-1,1] for clean visualization\n        reconstructed = torch.clamp(reconstructed, -1.0, 1.0)\n\n        psnr_val = calculate_psnr_bottom_half(images, reconstructed, masks).item()\n        ssim_val = calculate_ssim_bottom_half(images, reconstructed, masks).item()\n        mse_val = calculate_mse_bottom_half(images, reconstructed, masks).item()\n        psnr_values.append(psnr_val)\n        ssim_values.append(ssim_val)\n        mse_values.append(mse_val)\n\n        plt.subplot(4, num_samples, i + 1)\n        plt.title(\"Original\")\n        plt.imshow(images[0].permute(1, 2, 0).cpu().numpy() * 0.5 + 0.5)\n        plt.axis(\"off\")\n\n        plt.subplot(4, num_samples, num_samples + i + 1)\n        plt.title(\"Input\")\n        plt.imshow(masked_images[0].permute(1, 2, 0).cpu().numpy() * 0.5 + 0.5)\n        plt.axis(\"off\")\n\n        plt.subplot(4, num_samples, 2 * num_samples + i + 1)\n        plt.title(\"Reconstructed\")\n        plt.imshow(reconstructed[0].permute(1, 2, 0).cpu().numpy() * 0.5 + 0.5)\n        plt.axis(\"off\")\n\n        diff = torch.abs(images - reconstructed) * (1 - masks)\n        plt.subplot(4, num_samples, 3 * num_samples + i + 1)\n        plt.title(\"Diff\")\n        plt.imshow(diff[0].permute(1, 2, 0).cpu().numpy(), cmap='hot')\n        plt.axis(\"off\")\n\n        print(f\"Sample {i + 1}: PSNR={psnr_val:.4f}, SSIM={ssim_val:.4f}, MSE={mse_val:.4f}\")\n\nplt.tight_layout()\nplt.savefig('/kaggle/working/results/bottom_half_reconstruction_results.png', dpi=150, bbox_inches='tight')\nplt.show()\n\n# Metrics plots\nplt.figure(figsize=(15, 5))\nfor idx, (vals, title, color, marker) in enumerate([\n    (psnr_values, \"PSNR\", 'blue', 'o'),\n    (ssim_values, \"SSIM\", 'orange', 's'),\n    (mse_values, \"MSE\", 'green', '^')\n]):\n    plt.subplot(1, 3, idx + 1)\n    plt.plot(range(1, len(vals) + 1), vals, marker=marker, linewidth=2, markersize=8, color=color)\n    plt.title(title, fontsize=14)\n    plt.xlabel(\"Sample\")\n    plt.grid(True, alpha=0.3)\nplt.tight_layout()\nplt.savefig('/kaggle/working/results/bottom_half_metrics.png', dpi=150, bbox_inches='tight')\nplt.show()\n\n# Print results\nprint(\"\\n\" + \"=\" * 60)\nprint(\"Evaluation Results (Bottom Half) - Test Set:\")\nprint(\"=\" * 60)\nprint(f\"Average PSNR: {np.mean(psnr_values):.4f} dB (±{np.std(psnr_values):.4f})\")\nprint(f\"Average SSIM: {np.mean(ssim_values):.4f} (±{np.std(ssim_values):.4f})\")\nprint(f\"Average MSE:  {np.mean(mse_values):.4f} (±{np.std(mse_values):.4f})\")\nprint(f\"Best PSNR: {np.max(psnr_values):.4f} | Worst PSNR: {np.min(psnr_values):.4f}\")\nprint(f\"Best SSIM: {np.max(ssim_values):.4f} | Worst SSIM: {np.min(ssim_values):.4f}\")\nprint(\"=\" * 60)\n\nwith open('/kaggle/working/results/enhanced_bottom_half_metrics.txt', 'w', encoding='utf-8') as f:\n    f.write(\"Bottom Half Face Reconstruction Results\\n\")\n    f.write(\"=\" * 60 + \"\\n\")\n    f.write(f\"Average PSNR: {np.mean(psnr_values):.4f} dB (±{np.std(psnr_values):.4f})\\n\")\n    f.write(f\"Average SSIM: {np.mean(ssim_values):.4f} (±{np.std(ssim_values):.4f})\\n\")\n    f.write(f\"Average MSE:  {np.mean(mse_values):.4f} (±{np.std(mse_values):.4f})\\n\")\n    f.write(f\"Best PSNR: {np.max(psnr_values):.4f} | Worst PSNR: {np.min(psnr_values):.4f}\\n\")\n    f.write(f\"Best SSIM: {np.max(ssim_values):.4f} | Worst SSIM: {np.min(ssim_values):.4f}\\n\")\n    f.write(\"=\" * 60 + \"\\n\")\n    for i, (p, s, m) in enumerate(zip(psnr_values, ssim_values, mse_values)):\n        f.write(f\"Sample {i + 1}: PSNR={p:.4f}, SSIM={s:.4f}, MSE={m:.4f}\\n\")\n\nprint(\"\\n✅ Training and evaluation complete!\")\nprint(f\"Models saved in '/kaggle/working/models/' directory.\")\nprint(f\"Evaluation results saved in '/kaggle/working/results/' directory.\")","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"","metadata":{"trusted":true},"outputs