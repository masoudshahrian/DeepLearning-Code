0..255] for integers). Got range [0.5..1.1411294].\n"]},{"data":{"image/png":"\n","text/plain":["<Figure size 2000x1000 with 40 Axes>"]},"metadata":{},"output_type":"display_data"},{"name":"stdout","output_type":"stream","text":["\n","Average PSNR: 16.8609 dB (±1.7325)\n","Average SSIM: 0.6005 (±0.0492)\n","Average MSE: 0.1717 (±0.0595)\n","Average Identity Loss: 0.1688 (±0.0375)\n","Average Landmark Loss: 0.1717 (±0.0595)\n","Training and evaluation complete!\n"]}],"source":["import os\n","os.environ.setdefault('TORCH_CUDA_ARCH_LIST', '7.5') # For Kaggle GPU compatibility\n","import torch\n","import torch.nn as nn\n","import torch.nn.functional as F\n","import torchvision.models as models\n","import torchvision.transforms as transforms\n","from torch.utils.data import Dataset, DataLoader\n","import matplotlib.pyplot as plt\n","import numpy as np\n","from skimage.metrics import peak_signal_noise_ratio as psnr\n","from skimage.metrics import structural_similarity as ssim\n","import random\n","import cv2\n","from PIL import Image\n","from torch import amp  # For mixed precision training (new API)\n","import networkx as nx  # For graph operations\n","\n","# Simplified GNN for graph processing\n","class PyramidalGNN(nn.Module):\n","    def __init__(self, in_channels, out_channels):\n","        super(PyramidalGNN, self).__init__()\n","        self.lin = nn.Linear(in_channels, out_channels)\n","        self.gate = nn.Linear(in_channels * 2, out_channels)\n","\n","    def forward(self, x, edge_index):\n","        return self.lin(x)\n","\n","# /kaggle/input/celeba-resized-6464/img_align_celeba/CelebA_Image_Cropped_64\n","# Configuration parameters\n","prune_threshold = 0.2\n","lambda_l1 = 50.0\n","n_critic = 2\n","\n","# Global prune_graph function using NetworkX\n","def prune_graph(model, graph, threshold=prune_threshold):\n","    deg_cent = nx.degree_centrality(graph)\n","    low_value_nodes = [n for n, score in deg_cent.items() if score < threshold]\n","    graph.remove_nodes_from(low_value_nodes)\n","    return graph\n","\n","# Try to import MTCNN for landmark detection\n","try:\n","    from mtcnn import MTCNN\n","    USE_MTCNN = False\n","    print(\"MTCNN imported successfully for landmark detection (disabled for training).\")\n","except ImportError:\n","    print(\"MTCNN not found. Landmark loss will be simplified.\")\n","    USE_MTCNN = False\n","\n","# ============================================================================\n","# CHECKPOINT CONFIGURATION - Resume Training Setup\n","# ============================================================================\n","\n","RESUME_TRAINING = False  # ⚠️ Must be False because architecture changed!\n","CHECKPOINT_DIR = '/kaggle/working/checkpoints'\n","CHECKPOINT_INTERVAL = 1\n","\n","USE_KAGGLE_INPUT = True\n","# KAGGLE_INPUT_DATASET = '/kaggle/input/image-inpainting-v1/pytorch/default/17'\n","KAGGLE_INPUT_DATASET = '/kaggle/input/models/masoudshahrian/image-inpainting-v1/pytorch/default/17'\n","\n","LOAD_FROM_MODELS = True\n","MODELS_DIR = '/kaggle/working/models'\n","USE_BEST_MODELS = True\n","\n","print(\"=\"*70)\n","print(\"🔧 CHECKPOINT CONFIGURATION\")\n","print(\"=\"*70)\n","print(f\"📌 Resume Training: {RESUME_TRAINING}\")\n","print(f\"📁 Checkpoint Directory: {CHECKPOINT_DIR}\")\n","print(f\"💾 Save Interval: Every {CHECKPOINT_INTERVAL} epoch(s)\")\n","if USE_KAGGLE_INPUT:\n","    print(f\"📥 Loading from Kaggle Dataset: {KAGGLE_INPUT_DATASET}\")\n","if LOAD_FROM_MODELS:\n","    print(f\"🗂️  Load from Models: {MODELS_DIR}\")\n","    print(f\"   Using: {'*_best.pth' if USE_BEST_MODELS else '*_bottom_half.pth'}\")\n","print(\"=\"*70 + \"\\n\")\n","\n","# ============================================================================\n","# TRAINING CONFIGURATION\n","# ============================================================================\n","\n","image_size = (64, 64)\n","batch_size = 64  # ⚠️ Reduced from 128 to prevent OOM with deeper models\n","eval_batch_size = 1\n","num_epochs = 1\n","learning_rate_g = 0.00005\n","learning_rate_d = 0.0002\n","lambda_adv = 0.5\n","lambda_style = 0.05\n","lambda_fm = 0.05\n","lambda_rec = 1.0\n","lambda_identity = 0.005\n","lambda_landmark = 0.01\n","lambda_perc = 0.1\n","lambda_vae = 0.01\n","lambda_struct = 0.05\n","lambda_d_reg = 1e-4\n","lambda_attention = 0.05\n","lambda_gp = 10.0\n","lambda_edge = 0.7\n","lambda_hf = 0.5\n","lambda_gradient = 0.6\n","lambda_facial = 0.8\n","device = torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\n","print(f\"Using device: {device}\")\n","\n","def split_dataset(dataset_path, train_ratio=0.8, val_ratio=0.1, test_ratio=0.1, seed=42):\n","    random.seed(seed)\n","    np.random.seed(seed)\n","    torch.manual_seed(seed)\n","    image_files = [f for f in os.listdir(dataset_path) if f.lower().endswith(('.png', '.jpg', '.jpeg'))]\n","    random.shuffle(image_files)\n","    total_files = len(image_files)\n","    train_end = int(total_files * train_ratio)\n","    val_end = train_end + int(total_files * val_ratio)\n","    train_files, val_files, test_files = image_files[:train_end], image_files[train_end:val_end], image_files[val_end:]\n","    print(f\"Dataset split: Total={total_files}, Train={len(train_files)}, Val={len(val_files)}, Test={len(test_files)}\")\n","    return train_files, val_files, test_files\n","\n","class CelebADataset(Dataset):\n","    def __init__(self, dataset_path, file_list, image_size, augment=True):\n","        self.dataset_path = dataset_path\n","        self.file_list = file_list\n","        base_transforms = [\n","            transforms.Resize(image_size),\n","            transforms.ToTensor(),\n","            transforms.Normalize(mean=[0.5, 0.5, 0.5], std=[0.5, 0.5, 0.5])\n","        ]\n","        if augment:\n","            aug_transforms = [\n","                transforms.RandomHorizontalFlip(p=0.5),\n","                transforms.RandomRotation(10)\n","            ]\n","            self.transform = transforms.Compose(aug_transforms + base_transforms)\n","        else:\n","            self.transform = transforms.Compose(base_transforms)\n","   \n","    def __len__(self):\n","        return len(self.file_list)\n","   \n","    def __getitem__(self, idx):\n","        img_path = os.path.join(self.dataset_path, self.file_list[idx])\n","        image = Image.open(img_path).convert('RGB')\n","        image = self.transform(image)\n","        return image\n","\n","def create_split_datasets(dataset_path, train_files, val_files, test_files, image_size, batch_size):\n","    train_dataset = CelebADataset(dataset_path, train_files, image_size, augment=True)\n","    val_dataset = CelebADataset(dataset_path, val_files, image_size, augment=False)\n","    test_dataset = CelebADataset(dataset_path, test_files, image_size, augment=False)\n","   \n","    train_loader = DataLoader(train_dataset, batch_size=batch_size, shuffle=True, num_workers=2, pin_memory=True)\n","    val_loader = DataLoader(val_dataset, batch_size=batch_size, shuffle=False, num_workers=2, pin_memory=True)\n","    test_loader = DataLoader(test_dataset, batch_size=eval_batch_size, shuffle=False, num_workers=2, pin_memory=True)\n","    return train_loader, val_loader, test_loader\n","\n","# ============================================================================\n","# UTILITY MODULES FOR DEEPER ARCHITECTURE (FIXED NORM LAYERS)\n","# ============================================================================\n","\n","class ResBlock(nn.Module):\n","    def __init__(self, channels):\n","        super().__init__()\n","        self.conv1 = nn.Conv2d(channels, channels, kernel_size=3, stride=1, padding=1)\n","        self.conv2 = nn.Conv2d(channels, channels, kernel_size=3, stride=1, padding=1)\n","        self.norm1 = nn.GroupNorm(8, channels) if channels % 8 == 0 else nn.GroupNorm(1, channels)\n","        self.norm2 = nn.GroupNorm(8, channels) if channels % 8 == 0 else nn.GroupNorm(1, channels)\n","\n","    def forward(self, x):\n","        residual = x\n","        out = F.leaky_relu(self.norm1(self.conv1(x)), 0.2)\n","        out = self.norm2(self.conv2(out))\n","        return F.leaky_relu(out + residual, 0.2)\n","\n","class SEBlock(nn.Module):\n","    def __init__(self, channels, reduction=16):\n","        super().__init__()\n","        mid = max(channels // reduction, 8)\n","        self.pool = nn.AdaptiveAvgPool2d(1)\n","        self.fc = nn.Sequential(\n","            nn.Linear(channels, mid),\n","            nn.ReLU(inplace=True),\n","            nn.Linear(mid, channels),\n","            nn.Sigmoid()\n","        )\n","\n","    def forward(self, x):\n","        b, c, _, _ = x.shape\n","        y = self.pool(x).view(b, c)\n","        y = self.fc(y).view(b, c, 1, 1)\n","        return x * y\n","\n","class AttentionGate(nn.Module):\n","    def __init__(self, F_g, F_l, F_int):\n","        super().__init__()\n","        self.W_g = nn.Sequential(\n","            nn.Conv2d(F_g, F_int, kernel_size=1, stride=1, padding=0),\n","            nn.GroupNorm(8, F_int) if F_int % 8 == 0 else nn.GroupNorm(1, F_int)\n","        )\n","        self.W_x = nn.Sequential(\n","            nn.Conv2d(F_l, F_int, kernel_size=1, stride=1, padding=0),\n","            nn.GroupNorm(8, F_int) if F_int % 8 == 0 else nn.GroupNorm(1, F_int)\n","        )\n","        self.psi = nn.Sequential(\n","            nn.Conv2d(F_int, 1, kernel_size=1, stride=1, padding=0),\n","            nn.GroupNorm(1, 1),\n","            nn.Sigmoid()\n","        )\n","        self.relu = nn.ReLU(inplace=True)\n","\n","    def forward(self, g, x):\n","        g1 = self.W_g(g)\n","        x1 = self.W_x(x)\n","        psi = self.relu(g1 + x1)\n","        psi = self.psi(psi)\n","        return x * psi\n","\n","# ============================================================================\n","# MODELS\n","# ============================================================================\n","\n","class ViTPreprocessor(nn.Module):\n","    def __init__(self, dim=128, num_heads=8, patch_size=8, num_layers=3):\n","        super().__init__()\n","        self.patch_size = patch_size\n","        self.dim = dim\n","        self.num_heads = num_heads\n","        self.num_patches = (image_size[0] // patch_size) * (image_size[1] // patch_size)\n","        self.patch_embed = nn.Conv2d(3, dim, kernel_size=patch_size, stride=patch_size, padding=0)\n","        self.pos_embed = nn.Parameter(torch.zeros(1, self.num_patches, dim))\n","       \n","        self.attention_blocks = nn.ModuleList([\n","            nn.ModuleDict({\n","                'attn': nn.MultiheadAttention(embed_dim=dim, num_heads=num_heads, dropout=0.1, batch_first=True),\n","                'norm1': nn.LayerNorm(dim, eps=1e-6),\n","                'norm2': nn.LayerNorm(dim, eps=1e-6),\n","                'mlp': nn.Sequential(\n","                    nn.Linear(dim, dim * 4),\n","                    nn.GELU(),\n","                    nn.Dropout(0.1),\n","                    nn.Linear(dim * 4, dim),\n","                    nn.Dropout(0.1)\n","                )\n","            }) for _ in range(num_layers)\n","        ])\n","       \n","        self.final_norm = nn.LayerNorm(dim, eps=1e-6)\n","        self.gnn = PyramidalGNN(dim, dim)\n","   \n","    def build_graph(self, features):\n","        B, C, H, W = features.shape\n","        nodes = features.view(B, C, -1).permute(0, 2, 1)\n","        G = nx.Graph()\n","        for i in range(nodes.shape[1]):\n","            G.add_node(i, feat=nodes[0, i])\n","        for i in range(nodes.shape[1]):\n","            for j in range(i+1, nodes.shape[1]):\n","                sim = F.cosine_similarity(nodes[0, i:i+1], nodes[0, j:j+1])\n","                if sim > 0.5:\n","                    G.add_edge(i, j, weight=sim)\n","        return G\n","   \n","    def graph_enhanced_forward(self, x, graph):\n","        node_list = list(graph.nodes)\n","        if not node_list:\n","            return x\n","        for node in graph.nodes:\n","            neighbors = list(graph.neighbors(node))\n","            if neighbors:\n","                neighbor_feats = torch.stack([graph.nodes[n]['feat'] for n in neighbors])\n","                aggregated = torch.mean(neighbor_feats, dim=0)\n","                graph.nodes[node]['feat'] = (graph.nodes[node]['feat'] + aggregated) / 2\n","        final_nodes = list(graph.nodes)\n","        if not final_nodes:\n","            return x\n","        node_features = [graph.nodes[n]['feat'] for n in sorted(final_nodes)]\n","        return torch.stack(node_features)\n","   \n","    def reconstruct_features(self, pruned_feats, pruned_indices, B, C, H, W):\n","        num_patches = H * W\n","        full_feats = torch.zeros(B, num_patches, C, device=pruned_feats.device, dtype=pruned_feats.dtype)\n","        if len(pruned_indices) > 0:\n","            full_feats[:, pruned_indices] = pruned_feats\n","        return full_feats.reshape(B, H, W, C).permute(0, 3, 1, 2)\n","   \n","    def forward(self, x):\n","        embedded = self.patch_embed(x)\n","        B, C, H, W = embedded.shape\n","        flat = embedded.permute(0, 2, 3, 1).reshape(B, H * W, C)\n","        \n","        num_patches = H * W\n","        if num_patches != self.num_patches:\n","            pos_embed_3d = self.pos_embed.permute(0, 2, 1)\n","            pos_embed_adaptive = F.interpolate(pos_embed_3d, size=num_patches, mode='linear', align_corners=False).permute(0, 2, 1)\n","        else:\n","            pos_embed_adaptive = self.pos_embed\n","        \n","        flat = flat + pos_embed_adaptive\n","        \n","        graph = self.build_graph(embedded)\n","        pruned_graph = prune_graph(self, graph)\n","        \n","        pruned_indices = list(pruned_graph.nodes)\n","        if pruned_indices:\n","            pruned_feats = torch.stack([pruned_graph.nodes[i]['feat'] for i in pruned_indices])\n","        else:\n","            pruned_feats = flat[0].clone()\n","            pruned_indices = list(range(flat.shape[1]))\n","        \n","        for block in self.attention_blocks:\n","            attn_out, _ = block['attn'](pruned_feats, pruned_feats, pruned_feats)\n","            pruned_feats = block['norm1'](pruned_feats + attn_out)\n","            mlp_out = block['mlp'](pruned_feats)\n","            pruned_feats = block['norm2'](pruned_feats + mlp_out)\n","        \n","        enhanced_pruned = self.graph_enhanced_forward(pruned_feats, pruned_graph)\n","        x = self.reconstruct_features(enhanced_pruned, pruned_indices, B, C, H, W)\n","        full_x = self.final_norm(x.view(B, C, -1).permute(0, 2, 1)).permute(0, 2, 1).view(B, C, H, W)\n","        return full_x\n","\n","class VAESampling(nn.Module):\n","    def __init__(self):\n","        super().__init__()\n","    def forward(self, mu, logvar):\n","        std = torch.exp(0.5 * logvar)\n","        eps = torch.randn_like(std)\n","        return mu + eps * std\n","\n","# DEEP VAE ENCODER\n","class VAEEncoder(nn.Module):\n","    def __init__(self, in_channels=128, latent_dim=256):\n","        super().__init__()\n","        self.latent_dim = latent_dim\n","        self.res_block_0 = nn.Sequential(ResBlock(in_channels), ResBlock(in_channels), ResBlock(in_channels), SEBlock(in_channels))\n","        self.down1 = nn.Sequential(nn.Conv2d(in_channels, 256, kernel_size=4, stride=2, padding=1), nn.LeakyReLU(0.2, inplace=True))\n","        self.res_block_1 = nn.Sequential(ResBlock(256), ResBlock(256), ResBlock(256), SEBlock(256))\n","        self.down2 = nn.Sequential(nn.Conv2d(256, 512, kernel_size=4, stride=2, padding=1), nn.LeakyReLU(0.2, inplace=True))\n","        self.res_block_2 = nn.Sequential(ResBlock(512), ResBlock(512), SEBlock(512))\n","        self.adaptive_pool = nn.AdaptiveAvgPool2d((2, 2))\n","        self.flatten = nn.Flatten()\n","        self.fc_mu = nn.Linear(512 * 2 * 2, latent_dim)\n","        self.fc_logvar = nn.Linear(512 * 2 * 2, latent_dim)\n","\n","    def forward(self, x):\n","        B, C, H, W = x.shape\n","        if H < 8 or W < 8:\n","            x = F.adaptive_avg_pool2d(x, (8, 8))\n","        x = self.res_block_0(x)\n","        x = self.res_block_1(self.down1(x))\n","        x = self.res_block_2(self.down2(x))\n","        x = self.adaptive_pool(x)\n","        x = self.flatten(x)\n","        return self.fc_mu(x), self.fc_logvar(x)\n","\n","# DEEP VAE DECODER\n","class VAEDecoder(nn.Module):\n","    def __init__(self, latent_dim=256):\n","        super().__init__()\n","        self.latent_dim = latent_dim\n","        self.fc = nn.Linear(latent_dim, 512 * 2 * 2)\n","        self.res_block_0 = nn.Sequential(ResBlock(512), ResBlock(512), SEBlock(512))\n","        self.up1 = nn.Sequential(nn.ConvTranspose2d(512, 256, kernel_size=4, stride=2, padding=1), nn.LeakyReLU(0.2, inplace=True))\n","        self.res_block_1 = nn.Sequential(ResBlock(256), ResBlock(256), SEBlock(256))\n","        self.up2 = nn.Sequential(nn.ConvTranspose2d(256, 128, kernel_size=4, stride=2, padding=1), nn.LeakyReLU(0.2, inplace=True))\n","        self.res_block_2 = nn.Sequential(ResBlock(128), ResBlock(128), SEBlock(128))\n","        self.up3 = nn.Sequential(nn.ConvTranspose2d(128, 64, kernel_size=4, stride=2, padding=1), nn.LeakyReLU(0.2, inplace=True))\n","        self.res_block_3 = nn.Sequential(ResBlock(64), ResBlock(64), SEBlock(64))\n","        self.up4 = nn.Sequential(nn.ConvTranspose2d(64, 32, kernel_size=4, stride=2, padding=1), nn.LeakyReLU(0.2, inplace=True))\n","        self.res_block_4 = nn.Sequential(ResBlock(32), ResBlock(32))\n","        self.up5 = nn.ConvTranspose2d(32, 3, kernel_size=4, stride=2, padding=1)\n","\n","    def forward(self, z):\n","        x = F.leaky_relu(self.fc(z), 0.2)\n","        x = x.view(-1, 512, 2, 2)\n","        x = self.res_block_0(x)\n","        x = self.res_block_1(self.up1(x))\n","        x = self.res_block_2(self.up2(x))\n","        x = self.res_block_3(self.up3(x))\n","        x = self.res_block_4(self.up4(x))\n","        x = torch.tanh(self.up5(x))\n","        return x\n","\n","class EdgeDetector(nn.Module):\n","    def __init__(self):\n","        super().__init__()\n","        sobel_x = torch.tensor([[-1, 0, 1], [-2, 0, 2], [-1, 0, 1]], dtype=torch.float32).unsqueeze(0).unsqueeze(0)\n","        sobel_y = torch.tensor([[-1, -2, -1], [0, 0, 0], [1, 2, 1]], dtype=torch.float32).unsqueeze(0).unsqueeze(0)\n","        self.register_buffer('sobel_x', sobel_x.repeat(3, 1, 1, 1))\n","        self.register_buffer('sobel_y', sobel_y.repeat(3, 1, 1, 1))\n","    \n","    def forward(self, x):\n","        edge_x = F.conv2d(x, self.sobel_x, padding=1, groups=3)\n","        edge_y = F.conv2d(x, self.sobel_y, padding=1, groups=3)\n","        edges = torch.sqrt(edge_x ** 2 + edge_y ** 2 + 1e-8)\n","        return edges\n","\n","# DEEP EDGE GENERATOR\n","class EdgeGenerator(nn.Module):\n","    def __init__(self):\n","        super().__init__()\n","        self.enc1_conv = nn.Conv2d(6, 64, kernel_size=4, stride=2, padding=1)\n","        self.enc1_res = nn.Sequential(ResBlock(64), ResBlock(64))\n","        self.enc2_conv = nn.Conv2d(64, 128, kernel_size=4, stride=2, padding=1)\n","        self.enc2_res = nn.Sequential(ResBlock(128), ResBlock(128), SEBlock(128))\n","        self.enc3_conv = nn.Conv2d(128, 256, kernel_size=4, stride=2, padding=1)\n","        self.enc3_res = nn.Sequential(ResBlock(256), ResBlock(256), SEBlock(256))\n","        \n","        self.bottleneck_conv = nn.Conv2d(256, 512, kernel_size=4, stride=2, padding=1)\n","        self.bottleneck_res = nn.Sequential(ResBlock(512), ResBlock(512), ResBlock(512), SEBlock(512))\n","        self.attention1 = nn.MultiheadAttention(embed_dim=512, num_heads=8, dropout=0.1, batch_first=True)\n","        self.attention_norm1 = nn.LayerNorm(512, eps=1e-6)\n","        self.attention2 = nn.MultiheadAttention(embed_dim=512, num_heads=8, dropout=0.1, batch_first=True)\n","        self.attention_norm2 = nn.LayerNorm(512, eps=1e-6)\n","        \n","        self.dec4_deconv = nn.ConvTranspose2d(512, 256, kernel_size=4, stride=2, padding=1)\n","        self.dec4_attn_gate = AttentionGate(F_g=256, F_l=256, F_int=64)\n","        self.dec4_conv = nn.Conv2d(256 + 256, 256, kernel_size=3, stride=1, padding=1)\n","        self.dec4_res = nn.Sequential(ResBlock(256), ResBlock(256))\n","        \n","        self.dec3_deconv = nn.ConvTranspose2d(256, 128, kernel_size=4, stride=2, padding=1)\n","        self.dec3_attn_gate = AttentionGate(F_g=128, F_l=128, F_int=32)\n","        self.dec3_conv = nn.Conv2d(128 + 128, 128, kernel_size=3, stride=1, padding=1)\n","        self.dec3_res = nn.Sequential(ResBlock(128), ResBlock(128))\n","        \n","        self.dec2_deconv = nn.ConvTranspose2d(128, 64, kernel_size=4, stride=2, padding=1)\n","        self.dec2_attn_gate = AttentionGate(F_g=64, F_l=64, F_int=16)\n","        self.dec2_conv = nn.Conv2d(64 + 64, 64, kernel_size=3, stride=1, padding=1)\n","        self.dec2_res = nn.Sequential(ResBlock(64), ResBlock(64))\n","        \n","        self.dec1_deconv = nn.ConvTranspose2d(64, 32, kernel_size=4, stride=2, padding=1)\n","        self.dec1_res = nn.Sequential(ResBlock(32), ResBlock(32))\n","        self.final_conv = nn.Conv2d(32, 3, kernel_size=3, stride=1, padding=1)\n","\n","    def forward(self, masked_image, mask):\n","        x = torch.cat([masked_image, mask], dim=1)\n","        e1 = self.enc1_res(F.leaky_relu(self.enc1_conv(x), 0.2))\n","        e2 = self.enc2_res(F.leaky_relu(self.enc2_conv(e1), 0.2))\n","        e3 = self.enc3_res(F.leaky_relu(self.enc3_conv(e2), 0.2))\n","        \n","        b = F.leaky_relu(self.bottleneck_conv(e3), 0.2)\n","        b = self.bottleneck_res(b)\n","        B, C, H, W = b.shape\n","        attn_in = b.permute(0, 2, 3, 1).reshape(B, H * W, C)\n","        attn_out, _ = self.attention1(attn_in, attn_in, attn_in)\n","        attn_in = self.attention_norm1(attn_in + attn_out)\n","        attn_out, _ = self.attention2(attn_in, attn_in, attn_in)\n","        b = self.attention_norm2(attn_in + attn_out)\n","        b = b.reshape(B, H, W, C).permute(0, 3, 1, 2)\n","        \n","        d4 = F.leaky_relu(self.dec4_deconv(b), 0.2)\n","        e3_g = self.dec4_attn_gate(d4, e3)\n","        d4 = torch.cat([d4, e3_g], dim=1)\n","        d4 = self.dec4_res(F.leaky_relu(self.dec4_conv(d4), 0.2))\n","        \n","        d3 = F.leaky_relu(self.dec3_deconv(d4), 0.2)\n","        e2_g = self.dec3_attn_gate(d3, e2)\n","        d3 = torch.cat([d3, e2_g], dim=1)\n","        d3 = self.dec3_res(F.leaky_relu(self.dec3_conv(d3), 0.2))\n","        \n","        d2 = F.leaky_relu(self.dec2_deconv(d3), 0.2)\n","        e1_g = self.dec2_attn_gate(d2, e1)\n","        d2 = torch.cat([d2, e1_g], dim=1)\n","        d2 = self.dec2_res(F.leaky_relu(self.dec2_conv(d2), 0.2))\n","        \n","        d1 = F.leaky_relu(self.dec1_deconv(d2), 0.2)\n","        d1 = self.dec1_res(d1)\n","        return torch.sigmoid(self.final_conv(d1))\n","\n","# DEEP COARSE GENERATOR\n","class CoarseGenerator(nn.Module):\n","    def __init__(self):\n","        super().__init__()\n","        self.preprocessor = ViTPreprocessor(dim=128, num_heads=8, patch_size=8, num_layers=4)\n","        self.attention1 = nn.MultiheadAttention(embed_dim=128, num_heads=8, dropout=0.1, batch_first=True)\n","        self.attention_norm1 = nn.LayerNorm(128, eps=1e-6)\n","        self.attention2 = nn.MultiheadAttention(embed_dim=128, num_heads=8, dropout=0.1, batch_first=True)\n","        self.attention_norm2 = nn.LayerNorm(128, eps=1e-6)\n","        self.skip_conv = nn.Conv2d(128, 128, kernel_size=1, padding=0)\n","        self.skip_res = ResBlock(128)\n","        self.skip_se = SEBlock(128)\n","        self.encoder = VAEEncoder(in_channels=128, latent_dim=256)\n","        self.sampling = VAESampling()\n","        self.decoder = VAEDecoder(latent_dim=256)\n","\n","    def forward(self, x, mask, edge_map=None):\n","        if edge_map is not None:\n","            x = x + edge_map * 0.1\n","        original_features = self.preprocessor(x)\n","        B, C, H, W = original_features.shape\n","        attn_input = original_features.permute(0, 2, 3, 1).reshape(B, H * W, C)\n","        attn_output, _ = self.attention1(attn_input, attn_input, attn_input)\n","        enhanced = self.attention_norm1(attn_input + attn_output)\n","        attn_output2, _ = self.attention2(enhanced, enhanced, enhanced)\n","        enhanced = self.attention_norm2(enhanced + attn_output2)\n","        enhanced = enhanced.reshape(B, H, W, C).permute(0, 3, 1, 2)\n","        skip = self.skip_se(self.skip_res(self.skip_conv(original_features)))\n","        enhanced = enhanced + skip\n","        mu, logvar = self.encoder(enhanced)\n","        z = self.sampling(mu, logvar)\n","        output = self.decoder(z)\n","        return output, mu, logvar\n","\n","# DEEP FINE GENERATOR\n","class FineGenerator(nn.Module):\n","    def __init__(self):\n","        super().__init__()\n","        self.enc1_conv = nn.Conv2d(9, 64, kernel_size=4, stride=2, padding=1)\n","        self.enc1_res = nn.Sequential(ResBlock(64), ResBlock(64), SEBlock(64))\n","        self.enc2_conv = nn.Conv2d(64, 128, kernel_size=4, stride=2, padding=1)\n","        self.enc2_res = nn.Sequential(ResBlock(128), ResBlock(128), SEBlock(128))\n","        self.enc3_conv = nn.Conv2d(128, 256, kernel_size=4, stride=2, padding=1)\n","        self.enc3_res = nn.Sequential(ResBlock(256), ResBlock(256), SEBlock(256))\n","        self.enc4_conv = nn.Conv2d(256, 512, kernel_size=4, stride=2, padding=1)\n","        self.enc4_res = nn.Sequential(ResBlock(512), ResBlock(512), SEBlock(512))\n","        \n","        self.bottleneck_conv = nn.Conv2d(512, 512, kernel_size=3, stride=1, padding=1)\n","        self.bottleneck_res = nn.Sequential(ResBlock(512), ResBlock(512), ResBlock(512), SEBlock(512))\n","        self.attention1 = nn.MultiheadAttention(embed_dim=512, num_heads=8, dropout=0.1, batch_first=True)\n","        self.attention_norm1 = nn.LayerNorm(512, eps=1e-6)\n","        self.attention2 = nn.MultiheadAttention(embed_dim=512, num_heads=8, dropout=0.1, batch_first=True)\n","        self.attention_norm2 = nn.LayerNorm(512, eps=1e-6)\n","        \n","        self.dec4_deconv = nn.ConvTranspose2d(512, 256, kernel_size=4, stride=2, padding=1)\n","        self.dec4_attn_gate = AttentionGate(F_g=256, F_l=256, F_int=64)\n","        self.dec4_conv = nn.Conv2d(256 + 256, 256, kernel_size=3, stride=1, padding=1)\n","        self.dec4_res = nn.Sequential(ResBlock(256), ResBlock(256), SEBlock(256))\n","        \n","        self.dec3_deconv = nn.ConvTranspose2d(256, 128, kernel_size=4, stride=2, padding=1)\n","        self.dec3_attn_gate = AttentionGate(F_g=128, F_l=128, F_int=32)\n","        self.dec3_conv = nn.Conv2d(128 + 128, 128, kernel_size=3, stride=1, padding=1)\n","        self.dec3_res = nn.Sequential(ResBlock(128), ResBlock(128), SEBlock(128))\n","        \n","        self.dec2_deconv = nn.ConvTranspose2d(128, 64, kernel_size=4, stride=2, padding=1)\n","        self.dec2_attn_gate = AttentionGate(F_g=64, F_l=64, F_int=16)\n","        self.dec2_conv = nn.Conv2d(64 + 64, 64, kernel_size=3, stride=1, padding=1)\n","        self.dec2_res = nn.Sequential(ResBlock(64), ResBlock(64), SEBlock(64))\n","        \n","        self.dec1_deconv = nn.ConvTranspose2d(64, 32, kernel_size=4, stride=2, padding=1)\n","        self.dec1_res = nn.Sequential(ResBlock(32), ResBlock(32), SEBlock(32))\n","        \n","        self.final_conv = nn.Conv2d(32, 3, kernel_size=3, stride=1, padding=1)\n","        self.final_tanh = nn.Tanh()\n","\n","    def forward(self, masked_images, coarse_output, masks, edge_map=None):\n","        if masked_images.shape[2:] != coarse_output.shape[2:]:\n","            coarse_output = F.interpolate(coarse_output, size=masked_images.shape[2:], mode='bilinear', align_corners=False)\n","        if edge_map is not None:\n","            if edge_map.shape[2:] != masked_images.shape[2:]:\n","                edge_map = F.interpolate(edge_map, size=masked_images.shape[2:], mode='bilinear', align_corners=False)\n","            x = torch.cat([masked_images, coarse_output, edge_map], dim=1)\n","        else:\n","            edge_map_zeros = torch.zeros_like(masked_images)\n","            x = torch.cat([masked_images, coarse_output, edge_map_zeros], dim=1)\n","            \n","        e1 = self.enc1_res(F.leaky_relu(self.enc1_conv(x), 0.2))\n","        e2 = self.enc2_res(F.leaky_relu(self.enc2_conv(e1), 0.2))\n","        e3 = self.enc3_res(F.leaky_relu(self.enc3_conv(e2), 0.2))\n","        e4 = self.enc4_res(F.leaky_relu(self.enc4_conv(e3), 0.2))\n","        \n","        b = F.leaky_relu(self.bottleneck_conv(e4), 0.2)\n","        b = self.bottleneck_res(b)\n","        B_b, C_b, H_b, W_b = b.shape\n","        attn_in = b.permute(0, 2, 3, 1).reshape(B_b, H_b * W_b, C_b)\n","        attn_out, _ = self.attention1(attn_in, attn_in, attn_in)\n","        attn_in = self.attention_norm1(attn_in + attn_out)\n","        attn_out, _ = self.attention2(attn_in, attn_in, attn_in)\n","        b = self.attention_norm2(attn_in + attn_out)\n","        b = b.reshape(B_b, H_b, W_b, C_b).permute(0, 3, 1, 2)\n","        \n","        d4 = F.leaky_relu(self.dec4_deconv(b), 0.2)\n","        e3_gated = self.dec4_attn_gate(d4, e3)\n","        d4 = torch.cat([d4, e3_gated], dim=1)\n","        d4 = self.dec4_res(F.leaky_relu(self.dec4_conv(d4), 0.2))\n","        \n","        d3 = F.leaky_relu(self.dec3_deconv(d4), 0.2)\n","        e2_gated = self.dec3_attn_gate(d3, e2)\n","        d3 = torch.cat([d3, e2_gated], dim=1)\n","        d3 = self.dec3_res(F.leaky_relu(self.dec3_conv(d3), 0.2))\n","        \n","        d2 = F.leaky_relu(self.dec2_deconv(d3), 0.2)\n","        e1_gated = self.dec2_attn_gate(d2, e1)\n","        d2 = torch.cat([d2, e1_gated], dim=1)\n","        d2 = self.dec2_res(F.leaky_relu(self.dec2_conv(d2), 0.2))\n","        \n","        d1 = F.leaky_relu(self.dec1_deconv(d2), 0.2)\n","        d1 = self.dec1_res(d1)\n","        \n","        output = self.final_tanh(self.final_conv(d1))\n","        if output.shape[2:] != masked_images.shape[2:]:\n","            output = F.interpolate(output, size=masked_images.shape[2:], mode='bilinear', align_corners=False)\n","        return output\n","\n","class Discriminator(nn.Module):\n","    def __init__(self):\n","        super().__init__()\n","        self.conv1 = nn.utils.spectral_norm(nn.Conv2d(6, 64, kernel_size=4, stride=2, padding=1))\n","        self.conv2 = nn.utils.spectral_norm(nn.Conv2d(64, 128, kernel_size=4, stride=2, padding=1))\n","        self.conv3 = nn.utils.spectral_norm(nn.Conv2d(128, 256, kernel_size=4, stride=2, padding=1))\n","        self.conv4 = nn.utils.spectral_norm(nn.Conv2d(256, 512, kernel_size=4, stride=2, padding=1))\n","        self.conv5 = nn.utils.spectral_norm(nn.Conv2d(512, 512, kernel_size=3, stride=1, padding=1))\n","        self.conv6 = nn.utils.spectral_norm(nn.Conv2d(512, 512, kernel_size=3, stride=1, padding=1))\n","        self.conv_out = nn.utils.spectral_norm(nn.Conv2d(512, 1, kernel_size=1, stride=1, padding=0))\n","        self.feature_layers = [self.conv1, self.conv2, self.conv3, self.conv4, self.conv5, self.conv6]\n","   \n","    def forward(self, x, mask, return_features=False):\n","        input_concat = torch.cat([x, mask], dim=1)\n","        features = []\n","        x = F.leaky_relu(self.conv1(input_concat), 0.2, inplace=True)\n","        if return_features: features.append(x)\n","        x = F.leaky_relu(self.conv2(x), 0.2, inplace=True)\n","        if return_features: features.append(x)\n","        x = F.leaky_relu(self.conv3(x), 0.2, inplace=True)\n","        if return_features: features.append(x)\n","        x = F.leaky_relu(self.conv4(x), 0.2, inplace=True)\n","        if return_features: features.append(x)\n","        x = F.leaky_relu(self.conv5(x), 0.2, inplace=True)\n","        if return_features: features.append(x)\n","        x = F.leaky_relu(self.conv6(x), 0.2, inplace=True)\n","        if return_features: features.append(x)\n","        logits = self.conv_out(x)\n","        if return_features: return logits, features\n","        return logits\n","\n","def make_blend_mask(mask, radius=5):\n","    if radius is None or radius <= 0: return mask\n","    if mask.dim() != 4: return mask\n","    m = (mask[:, :1] > 0.5).float()\n","    k = int(radius) * 2 + 1\n","    soft = F.avg_pool2d(m, kernel_size=k, stride=1, padding=int(radius))\n","    soft = torch.clamp(soft, 0.0, 1.0) * m\n","    if mask.shape[1] != 1: soft = soft.repeat(1, mask.shape[1], 1, 1)\n","    return soft\n","\n","def generate_adaptive_mask(image):\n","    batch_size = image.shape[0]\n","    h, w = image_size\n","    half_height = h // 2\n","    jitter = 4\n","    cuts = half_height + torch.randint(-jitter, jitter + 1, (batch_size,), device=image.device)\n","    cuts = torch.clamp(cuts, min=0, max=h).to(torch.long)\n","    mask = torch.zeros(batch_size, 1, h, w, dtype=torch.float32, device=image.device)\n","    for i in range(batch_size):\n","        mask[i, :, :cuts[i], :] = 1.0\n","    mask = mask.repeat(1, 3, 1, 1)\n","    if USE_MTCNN:\n","        detector = MTCNN()\n","        images_np = ((image * 0.5 + 0.5) * 255.0).permute(0, 2, 3, 1).detach().cpu().numpy()\n","        landmarks = []\n","        for img in images_np:\n","            img_uint8 = img.astype(np.uint8)\n","            result = detector.detect_faces(img_uint8)\n","            landmarks.append(result[0]['keypoints'] if result else {})\n","        mask_np = mask.permute(0, 2, 3, 1).cpu().detach().numpy()\n","        for i, lm in enumerate(landmarks):\n","            if lm:\n","                for key in ['mouth_left', 'mouth_right']:\n","                    if key in lm:\n","                        x, y = lm[key]\n","                        y = min(max(y, half_height), h-1)\n","                        x = min(max(x, 0), w-1)\n","                        mask_np[i, y-5:y+5, x-5:x+5, :] = 0.0\n","        mask = torch.from_numpy(mask_np).permute(0, 3, 1, 2).to(device)\n","    return mask\n","\n","try:\n","    vgg_weights = models.VGG16_Weights.DEFAULT\n","except AttributeError:\n","    vgg_weights = None\n","vgg = models.vgg16(weights=vgg_weights).features.to(device).eval()\n","loss_model = nn.Sequential(*[vgg[i] for i in range(16)]).to(device)\n","for param in loss_model.parameters():\n","    param.requires_grad = False\n","\n","edge_detector_global = EdgeDetector().to(device)\n","edge_detector_global.eval()\n","for param in edge_detector_global.parameters():\n","    param.requires_grad = False\n","\n","def perceptual_loss(y_true, y_pred):\n","    y_true = F.interpolate(y_true, size=image_size, mode='bilinear', align_corners=False)\n","    y_pred = F.interpolate(y_pred, size=image_size, mode='bilinear', align_corners=False)\n","    y_true = y_true * 0.5 + 0.5; y_pred = y_pred * 0.5 + 0.5\n","    return torch.mean((loss_model(y_true) - loss_model(y_pred)) ** 2)\n","\n","def half_perceptual_loss(y_true, completion):\n","    y_true = F.interpolate(y_true, size=image_size, mode='bilinear', align_corners=False)\n","    completion = F.interpolate(completion, size=image_size, mode='bilinear', align_corners=False)\n","    y_true = y_true * 0.5 + 0.5; completion = completion * 0.5 + 0.5\n","    return torch.mean((loss_model(y_true) - loss_model(completion)) ** 2)\n","\n","def style_loss(y_true, y_pred):\n","    y_true = F.interpolate(y_true, size=image_size, mode='bilinear', align_corners=False)\n","    y_pred = F.interpolate(y_pred, size=image_size, mode='bilinear', align_corners=False)\n","    y_true = y_true * 0.5 + 0.5; y_pred = y_pred * 0.5 + 0.5\n","    true_features = loss_model(y_true); pred_features = loss_model(y_pred)\n","    def gram_matrix(feat):\n","        B, C, H, W = feat.shape; feat = feat.view(B, C, H * W)\n","        return torch.bmm(feat, feat.transpose(1, 2)) / (C * H * W)\n","    return torch.mean(torch.stack([torch.mean((gram_matrix(t) - gram_matrix(p)) ** 2) for t, p in zip([true_features], [pred_features])]))\n","\n","def bottom_half_loss(y_true, y_pred, mask):\n","    bottom_region = (mask == 0).float(); diff = (y_true - y_pred) ** 2 * bottom_region\n","    return diff.sum() / (bottom_region.sum() + 1e-8)\n","\n","def feature_matching_loss(real_features, fake_features):\n","    return torch.mean(torch.stack([torch.mean((r - f) ** 2) for r, f in zip(real_features, fake_features)]))\n","\n","def identity_loss(y_true, y_pred, mask):\n","    bottom_region = (mask == 0).float()\n","    return torch.mean(torch.abs(y_true * bottom_region - y_pred * bottom_region))\n","\n","def landmark_guided_loss(y_true, y_pred, mask, force_mtcnn=None):\n","    use_mtcnn = USE_MTCNN if force_mtcnn is None else force_mtcnn\n","    if not use_mtcnn: return bottom_half_loss(y_true, y_pred, mask)\n","    detector = MTCNN()\n","    bottom_region = (mask == 0).float()\n","    # FIX: Added .detach() before converting to numpy\n","    y_true_np = ((y_true * bottom_region * 0.5 + 0.5) * 255.0).permute(0, 2, 3, 1).detach().cpu().numpy()\n","    y_pred_np = ((y_pred * bottom_region * 0.5 + 0.5) * 255.0).permute(0, 2, 3, 1).detach().cpu().numpy()\n","    loss_tensor = torch.tensor(0.0, device=device, requires_grad=True)\n","    for true_img, pred_img in zip(y_true_np, y_pred_np):\n","        true_lm = detector.detect_faces(true_img.astype(np.uint8))\n","        pred_lm = detector.detect_faces(pred_img.astype(np.uint8))\n","        if true_lm and pred_lm:\n","            for t, p in zip([true_lm[0]['keypoints'][k] for k in ['mouth_left', 'mouth_right']], \n","                           [pred_lm[0]['keypoints'][k] for k in ['mouth_left', 'mouth_right']]):\n","                loss_tensor = loss_tensor + (torch.tensor(t[0] - p[0], dtype=torch.float32, device=device) ** 2 + \n","                                             torch.tensor(t[1] - p[1], dtype=torch.float32, device=device) ** 2)\n","    return loss_tensor / y_true.shape[0]\n","\n","def structural_ssim_loss(y_true, y_pred, mask):\n","    y_true = y_true * 0.5 + 0.5; y_pred = y_pred * 0.5 + 0.5\n","    bottom_mask = (mask == 0).float()\n","    # FIX: Added .detach() before converting to numpy\n","    ssim_vals = [ssim((y_true[i] * bottom_mask[i]).permute(1,2,0).detach().cpu().numpy(), \n","                      (y_pred[i] * bottom_mask[i]).permute(1,2,0).detach().cpu().numpy(), \n","                      channel_axis=2, data_range=1.0, win_size=7) for i in range(y_true.shape[0])]\n","    return 1.0 - torch.mean(torch.tensor(ssim_vals, device=device))\n","\n","def gradient_penalty_loss(discriminator, real_images, fake_images, masks, device):\n","    alpha = torch.rand(real_images.size(0), 1, 1, 1).to(device)\n","    interpolated = (alpha * real_images + (1 - alpha) * fake_images).detach().requires_grad_(True)\n","    disc_interpolated = discriminator(interpolated, masks, return_features=False)\n","    if not disc_interpolated.requires_grad: return torch.tensor(0.0, device=device, requires_grad=True)\n","    gradients = torch.autograd.grad(outputs=disc_interpolated, inputs=interpolated, grad_outputs=torch.ones_like(disc_interpolated), create_graph=True, retain_graph=True, only_inputs=True)[0]\n","    return ((gradients.view(gradients.size(0), -1).norm(2, dim=1) - 1) ** 2).mean()\n","\n","def attention_loss(y_true, y_pred, mask):\n","    bottom_region = (mask == 0).float(); diff = torch.abs(y_true - y_pred) * bottom_region\n","    true_grad_x = torch.abs(y_true[:, :, :, 1:] - y_true[:, :, :, :-1])\n","    true_grad_y = torch.abs(y_true[:, :, 1:, :] - y_true[:, :, :-1, :])\n","    attention_weights = (F.pad(true_grad_x, (0,1,0,0)) + F.pad(true_grad_y, (0,0,0,1))).mean(dim=1, keepdim=True)\n","    return (diff * attention_weights / (attention_weights.mean() + 1e-8)).mean()\n","\n","def edge_loss(y_true, y_pred, mask, edge_detector):\n","    with torch.no_grad(): edges_true = edge_detector(y_true * 0.5 + 0.5)\n","    return torch.mean(torch.abs(edges_true - edge_detector(y_pred * 0.5 + 0.5)) * (mask == 0).float())\n","\n","def high_frequency_loss(y_true, y_pred, mask):\n","    lap = torch.tensor([[0,1,0],[1,-4,1],[0,1,0]], dtype=torch.float32).unsqueeze(0).unsqueeze(0).repeat(3,1,1,1).to(y_true.device)\n","    return torch.mean(torch.abs(F.conv2d(y_true, lap, padding=1, groups=3) - F.conv2d(y_pred, lap, padding=1, groups=3)) * (mask == 0).float())\n","\n","def gradient_loss(y_true, y_pred, mask):\n","    sobx = torch.tensor([[-1,0,1],[-2,0,2],[-1,0,1]], dtype=torch.float32).unsqueeze(0).unsqueeze(0).repeat(3,1,1,1).to(y_true.device)\n","    soby = torch.tensor([[-1,-2,-1],[0,0,0],[1,2,1]], dtype=torch.float32).unsqueeze(0).unsqueeze(0).repeat(3,1,1,1).to(y_true.device)\n","    gt = torch.sqrt(F.conv2d(y_true, sobx, padding=1, groups=3)**2 + F.conv2d(y_true, soby, padding=1, groups=3)**2 + 1e-8)\n","    gp = torch.sqrt(F.conv2d(y_pred, sobx, padding=1, groups=3)**2 + F.conv2d(y_pred, soby, padding=1, groups=3)**2 + 1e-8)\n","    return torch.mean(torch.abs(gt - gp) * (mask == 0).float())\n","\n","def facial_region_loss(y_true, y_pred, mask):\n","    B, C, H, W = y_true.shape; wm = torch.ones_like(mask)\n","    wm[:, :, H//2:H, W//4:3*W//4] = 3.0; wm = wm * (mask == 0).float()\n","    return (torch.abs(y_true - y_pred) * wm).sum() / (wm.sum() + 1e-8)\n","\n","def generator_loss(disc_fake_logits, y_true, y_pred, disc_features_real, disc_features_fake, mask, mu, logvar):\n","    logvar = torch.clamp(logvar, min=-10, max=10)\n","    calc = lambda v: torch.nan_to_num(v, nan=0.0, posinf=0.0, neginf=0.0)\n","    adv = calc(-torch.mean(disc_fake_logits))\n","    l1 = calc(torch.mean(torch.abs(y_true - y_pred) * (mask == 0).float()))\n","    rec = calc(bottom_half_loss(y_true, y_pred, mask))\n","    bm = make_blend_mask(mask); comp = y_true * bm + y_pred * (1.0 - bm)\n","    perc = calc(half_perceptual_loss(y_true, comp))\n","    sty = calc(style_loss(y_true, y_pred))\n","    fm = calc(feature_matching_loss(disc_features_real, disc_features_fake))\n","    idl = calc(identity_loss(y_true, y_pred, mask))\n","    lm = calc(landmark_guided_loss(y_true, y_pred, mask))\n","    struct = calc(structural_ssim_loss(y_true, y_pred, mask))\n","    att = calc(attention_loss(y_true, y_pred, mask))\n","    el = calc(edge_loss(y_true, y_pred, mask, edge_detector_global))\n","    hf = calc(high_frequency_loss(y_true, y_pred, mask))\n","    gl = calc(gradient_loss(y_true, y_pred, mask))\n","    fl = calc(facial_region_loss(y_true, y_pred, mask))\n","    kl = calc(torch.clamp(-0.5 * torch.mean(1 + logvar - mu**2 - torch.exp(logvar)), min=0.0, max=10.0))\n","    total = (lambda_adv*adv + lambda_l1*l1 + lambda_rec*rec + lambda_perc*perc + lambda_style*sty + \n","             lambda_fm*fm + lambda_identity*idl + lambda_landmark*lm + lambda_struct*struct + \n","             lambda_attention*att + lambda_vae*kl + lambda_edge*el + lambda_hf*hf + lambda_gradient*gl + lambda_facial*fl)\n","    return calc(total)\n","\n","def discriminator_loss(disc_real_logits, disc_fake_logits):\n","    calc = lambda v: torch.nan_to_num(v, nan=0.0, posinf=0.0, neginf=0.0)\n","    rl = calc(torch.mean(F.relu(1.0 - torch.clamp(disc_real_logits, -5, 5))))\n","    fl = calc(torch.mean(F.relu(1.0 + torch.clamp(disc_fake_logits, -5, 5))))\n","    reg = calc(lambda_d_reg * (torch.mean(disc_real_logits**2) + torch.mean(disc_fake_logits**2)))\n","    return calc(rl + fl + reg)\n","\n","def calculate_psnr_bottom_half(y_true, y_pred, mask):\n","    y_true = y_true * 0.5 + 0.5; y_pred = y_pred * 0.5 + 0.5\n","    bm = (mask == 0).float()\n","    # FIX: Added .detach()\n","    return torch.mean(torch.tensor([psnr((y_true[i]*bm[i]).permute(1,2,0).detach().cpu().numpy(), (y_pred[i]*bm[i]).permute(1,2,0).detach().cpu().numpy(), data_range=1.0) for i in range(y_true.shape[0])], device=device))\n","\n","def calculate_ssim_bottom_half(y_true, y_pred, mask):\n","    y_true = y_true * 0.5 + 0.5; y_pred = y_pred * 0.5 + 0.5\n","    bm = (mask == 0).float()\n","    # FIX: Added .detach()\n","    return torch.mean(torch.tensor([ssim((y_true[i]*bm[i]).permute(1,2,0).detach().cpu().numpy(), (y_pred[i]*bm[i]).permute(1,2,0).detach().cpu().numpy(), channel_axis=2, data_range=1.0, win_size=7) for i in range(y_true.shape[0])], device=device))\n","\n","def calculate_mse_bottom_half(y_true, y_pred, mask): return bottom_half_loss(y_true, y_pred, mask)\n","\n","# CRITICAL FIX: Resizing scaled inputs back to 64x64 so the network doesn't crash\n","def multi_resolution_inpainting(image, mask, model, edge_map=None, levels=3):\n","    outputs, mus, logvars = [], [], []\n","    target_size = image.shape[-2:]\n","    for level in range(levels):\n","        si = F.interpolate(image, scale_factor=1/(2**level), mode='bilinear')\n","        sm = F.interpolate(mask, scale_factor=1/(2**level), mode='nearest')\n","        si = F.interpolate(si, size=target_size, mode='bilinear', align_corners=False)\n","        sm = F.interpolate(sm, size=target_size, mode='nearest')\n","        if edge_map is not None:\n","            se = F.interpolate(edge_map, scale_factor=1/(2**level), mode='bilinear')\n","            se = F.interpolate(se, size=target_size, mode='bilinear', align_corners=False)\n","            out, mu, lv = model(si, sm, se)\n","        else:\n","            out, mu, lv = model(si, sm)\n","        outputs.append(out)\n","        mus.append(mu); logvars.append(lv)\n","    return torch.mean(torch.stack(outputs), dim=0), torch.mean(torch.stack(mus), dim=0), torch.mean(torch.stack(logvars), dim=0)\n","\n","def train_step(images, edge_generator, coarse_generator, fine_generator, discriminator, edge_optimizer, g_optimizer, d_optimizer, scaler):\n","    images = images.to(device); masks = generate_adaptive_mask(images)\n","    blend_masks = make_blend_mask(masks); masked_images = images * masks\n","   \n","    d_optimizer.zero_grad(); d_loss_accumulated = 0.0\n","    for _ in range(n_critic):\n","        with amp.autocast('cuda'):\n","            with torch.no_grad():\n","                edge_map = edge_generator(masked_images, masks)\n","                coarse_output, mu, logvar = multi_resolution_inpainting(masked_images, masks, coarse_generator, edge_map)\n","                if coarse_output.shape != images.shape: coarse_output = F.interpolate(coarse_output, size=images.shape[2:], mode='bilinear', align_corners=False)\n","                fine_output = fine_generator(masked_images, coarse_output, masks, edge_map)\n","                if fine_output.shape != images.shape: fine_output = F.interpolate(fine_output, size=images.shape[2:], mode='bilinear', align_corners=False)\n","                combined_input = images * blend_masks + fine_output * (1.0 - blend_masks)\n","            d_loss = discriminator_loss(discriminator(images, masks, return_features=False), discriminator(combined_input.detach(), masks, return_features=False))\n","            d_loss = d_loss + lambda_gp * gradient_penalty_loss(discriminator, images, combined_input.detach(), masks, device)\n","        scaler.scale(d_loss).backward(); d_loss_accumulated += d_loss.item()\n","    \n","    scaler.unscale_(d_optimizer); torch.nn.utils.clip_grad_norm_(discriminator.parameters(), max_norm=1.0); scaler.step(d_optimizer)\n","    d_loss_val = d_loss_accumulated / n_critic\n","   \n","    edge_optimizer.zero_grad(); g_optimizer.zero_grad()\n","    with amp.autocast('cuda'):\n","        edge_map = edge_generator(masked_images, masks)\n","        with torch.no_grad(): true_edges = edge_detector_global(images * 0.5 + 0.5)\n","        edge_recon_loss = torch.mean(torch.abs(true_edges - edge_map) * (masks == 0).float())\n","        \n","        coarse_output, mu, logvar = multi_resolution_inpainting(masked_images, masks, coarse_generator, edge_map)\n","        if coarse_output.shape != images.shape: coarse_output = F.interpolate(coarse_output, size=images.shape[2:], mode='bilinear', align_corners=False)\n","        fine_output = fine_generator(masked_images, coarse_output, masks, edge_map)\n","        if fine_output.shape != images.shape: fine_output = F.interpolate(fine_output, size=images.shape[2:], mode='bilinear', align_corners=False)\n","        combined_input = images * blend_masks + fine_output * (1.0 - blend_masks)\n","        \n","        disc_real_logits, disc_features_real = discriminator(images, masks, return_features=True)\n","        disc_fake_logits, disc_features_fake = discriminator(combined_input, masks, return_features=True)\n","        g_loss = generator_loss(disc_fake_logits, images, fine_output, disc_features_real, disc_features_fake, masks, mu, logvar)\n","    \n","    total_gen_loss = edge_recon_loss + g_loss\n","    scaler.scale(total_gen_loss).backward()\n","    scaler.unscale_(edge_optimizer); scaler.unscale_(g_optimizer)\n","    torch.nn.utils.clip_grad_norm_(edge_generator.parameters(), max_norm=1.0)\n","    torch.nn.utils.clip_grad_norm_(list(coarse_generator.parameters()) + list(fine_generator.parameters()), max_norm=1.0)\n","    scaler.step(edge_optimizer); scaler.step(g_optimizer); scaler.update()\n","    \n","    g_loss_val = g_loss.item(); edge_loss_val = edge_recon_loss.item()\n","    if np.isnan(g_loss_val) or np.isinf(g_loss_val): g_loss_val = 0.0\n","    if np.isnan(d_loss_val) or np.isinf(d_loss_val): d_loss_val = 0.0\n","    if np.isnan(edge_loss_val) or np.isinf(edge_loss_val): edge_loss_val = 0.0\n","    return g_loss_val, d_loss_val, edge_loss_val\n","\n","def check_model_gradients(model, model_name=\"Model\"):\n","    has_nan = has_inf = False; max_grad = 0.0\n","    for name, param in model.named_parameters():\n","        if param.grad is not None:\n","            if torch.isnan(param.grad).any(): has_nan = True\n","            if torch.isinf(param.grad).any(): has_inf = True\n","            max_grad = max(max_grad, param.grad.abs().max().item())\n","    return has_nan, has_inf, max_grad\n","\n","def retrain(model, pruned_graph, optimizer):\n","    optimizer.zero_grad()\n","    output, _, _ = model(torch.randn(1, 3, 64, 64).to(device), torch.randn(1, 3, 64, 64).to(device))\n","    loss = torch.mean(output); loss.backward(); optimizer.step()\n","    return loss.item()\n","\n","# celeba_dir = '/kaggle/input/celeba-6464/selected_celeba'\n","celeba_dir = '/kaggle/input/datasets/masoudshahrian/celeba-6464/selected_celeba'\n","\n","print(f\"Loading dataset from {celeba_dir}...\")\n","try: print(f\"Dataset directory contents: {os.listdir(celeba_dir)[:5]}\")\n","except Exception as e: print(f\"Error accessing dataset directory: {e}\"); raise\n","\n","train_files, val_files, test_files = split_dataset(celeba_dir)\n","train_loader, val_loader, test_loader = create_split_datasets(celeba_dir, train_files, val_files, test_files, image_size, batch_size)\n","\n","print(\"Building DEEPER models...\")\n","print(\"🔷 Multi-Stage Architecture: Edge → Coarse → Fine (DEEP)\")\n","edge_generator = EdgeGenerator().to(device)\n","coarse_generator = CoarseGenerator().to(device)\n","fine_generator = FineGenerator().to(device)\n","discriminator = Discriminator().to(device)\n","\n","print(f\"Edge Generator: {sum(p.numel() for p in edge_generator.parameters()):,} parameters\")\n","print(f\"Coarse Generator: {sum(p.numel() for p in coarse_generator.parameters()):,} parameters\")\n","print(f\"Fine Generator: {sum(p.numel() for p in fine_generator.parameters()):,} parameters\")\n","print(f\"Discriminator: {sum(p.numel() for p in discriminator.parameters()):,} parameters\")\n","\n","print(\"\\nTesting model dimensions...\")\n","test_input = torch.randn(1, 3, 64, 64).to(device)\n","test_mask = torch.randn(1, 3, 64, 64).to(device)\n","with torch.no_grad():\n","    coarse_output, mu, logvar = coarse_generator(test_input, test_mask)\n","    print(f\"Coarse output shape: {coarse_output.shape}\")\n","    fine_output = fine_generator(test_input, coarse_output, test_mask)\n","    print(f\"Fine output shape: {fine_output.shape}\")\n","    print(f\"Expected shape: {test_input.shape}\")\n","    disc_logits, disc_features = discriminator(test_input, test_mask, return_features=True)\n","    print(f\"Discriminator logits shape: {disc_logits.shape}\")\n","    print(\"✓ Model dimensions are correct!\")\n","\n","edge_optimizer = torch.optim.AdamW(edge_generator.parameters(), lr=learning_rate_g, betas=(0.5, 0.999), weight_decay=1e-4)\n","g_optimizer = torch.optim.AdamW(list(coarse_generator.parameters()) + list(fine_generator.parameters()), lr=learning_rate_g, betas=(0.5, 0.999), weight_decay=1e-4)\n","d_optimizer = torch.optim.AdamW(discriminator.parameters(), lr=learning_rate_d, betas=(0.5, 0.999), weight_decay=1e-4)\n","\n","try:\n","    edge_scheduler = torch.optim.lr_scheduler.ReduceLROnPlateau(edge_optimizer, mode='min', factor=0.5, patience=5, verbose=True, min_lr=learning_rate_g * 0.01)\n","    g_scheduler = torch.optim.lr_scheduler.ReduceLROnPlateau(g_optimizer, mode='min', factor=0.5, patience=5, verbose=True, min_lr=learning_rate_g * 0.01)\n","    d_scheduler = torch.optim.lr_scheduler.ReduceLROnPlateau(d_optimizer, mode='min', factor=0.5, patience=5, verbose=True, min_lr=learning_rate_d * 0.01)\n","except TypeError:\n","    edge_scheduler = torch.optim.lr_scheduler.ReduceLROnPlateau(edge_optimizer, mode='min', factor=0.5, patience=5, min_lr=learning_rate_g * 0.01)\n","    g_scheduler = torch.optim.lr_scheduler.ReduceLROnPlateau(g_optimizer, mode='min', factor=0.5, patience=5, min_lr=learning_rate_g * 0.01)\n","    d_scheduler = torch.optim.lr_scheduler.ReduceLROnPlateau(d_optimizer, mode='min', factor=0.5, patience=5, min_lr=learning_rate_d * 0.01)\n","\n","scaler = amp.GradScaler('cuda')\n","\n","# Model health check\n","print(\"\\n\" + \"=\"*60); print(\"🔍 Model Health Check\"); print(\"=\"*60)\n","test_batch = next(iter(train_loader)).to(device)\n","test_masks = generate_adaptive_mask(test_batch)\n","test_masked = test_batch * test_masks\n","print(\"Testing forward pass...\")\n","with torch.no_grad():\n","    try:\n","        coarse_out, mu, logvar = coarse_generator(test_masked, test_masks)\n","        print(f\"✓ Coarse Generator: output shape {coarse_out.shape}\")\n","        fine_out = fine_generator(test_masked, coarse_out, test_masks)\n","        print(f\"✓ Fine Generator: output shape {fine_out.shape}\")\n","        disc_out = discriminator(test_batch, test_masks)\n","        print(f\"✓ Discriminator: logits shape {disc_out.shape}\")\n","        print(\"✅ All models are healthy!\")\n","    except Exception as e:\n","        print(f\"❌ Model health check failed: {e}\"); raise\n","print(\"=\"*60 + \"\\n\")\n","\n","# Checkpoint Loading Logic\n","if USE_KAGGLE_INPUT:\n","    checkpoint_load_dir = os.path.join(KAGGLE_INPUT_DATASET, 'checkpoints')\n","    models_load_dir = os.path.join(KAGGLE_INPUT_DATASET, 'models')\n","else:\n","    checkpoint_load_dir = CHECKPOINT_DIR; models_load_dir = MODELS_DIR\n","\n","os.makedirs(CHECKPOINT_DIR, exist_ok=True); os.makedirs(MODELS_DIR, exist_ok=True)\n","\n","start_epoch = 0; best_val_loss = float('inf')\n","train_g_losses = []; train_d_losses = []; val_g_losses = []; val_d_losses = []\n","previous_val_g_loss = float('inf'); checkpoint_loaded = False; models_loaded = False\n","\n","if RESUME_TRAINING:\n","    if LOAD_FROM_MODELS and not checkpoint_loaded:\n","        suffix = \"_best.pth\" if USE_BEST_MODELS else \"_bottom_half.pth\"\n","        model_files = {'coarse': os.path.join(models_load_dir, f'coarse_generator{suffix}'), 'fine': os.path.join(models_load_dir, f'fine_generator{suffix}'), 'disc': os.path.join(models_load_dir, f'discriminator{suffix}')}\n","        if all(os.path.exists(path) for path in model_files.values()):\n","            try:\n","                missing, unexpected = coarse_generator.load_state_dict(torch.load(model_files['coarse'], map_location=device), strict=False)\n","                if missing or unexpected: print(\"[coarse_generator] non-strict load: missing/unexpected keys detected.\")\n","                missing, unexpected = fine_generator.load_state_dict(torch.load(model_files['fine'], map_location=device), strict=False)\n","                if missing or unexpected: print(\"[fine_generator] non-strict load: missing/unexpected keys detected.\")\n","                missing, unexpected = discriminator.load_state_dict(torch.load(model_files['disc'], map_location=device), strict=False)\n","                if missing or unexpected: print(\"[discriminator] non-strict load: missing/unexpected keys detected.\")\n","                models_loaded = True; print(\"✅ MODEL WEIGHTS LOADED SUCCESSFULLY!\")\n","            except Exception as e: print(f\"⚠️  Failed to load model files: {e}\"); models_loaded = False\n","        else: print(f\"⚠️  Not all model files found in {models_load_dir}\")\n","    \n","    if not checkpoint_loaded and not models_loaded:\n","        checkpoint_paths_to_try = [os.path.join(checkpoint_load_dir, 'latest_checkpoint.pth'), os.path.join(CHECKPOINT_DIR, 'latest_checkpoint.pth')]\n","        for checkpoint_path in checkpoint_paths_to_try:\n","            if os.path.exists(checkpoint_path):\n","                try:\n","                    checkpoint = torch.load(checkpoint_path, map_location=device)\n","                    if 'edge_generator' in checkpoint: edge_generator.load_state_dict(checkpoint['edge_generator'], strict=False)\n","                    coarse_generator.load_state_dict(checkpoint['coarse_generator'], strict=False)\n","                    fine_generator.load_state_dict(checkpoint['fine_generator'], strict=False)\n","                    discriminator.load_state_dict(checkpoint['discriminator'], strict=False)\n","                    g_optimizer.load_state_dict(checkpoint['g_optimizer']); d_optimizer.load_state_dict(checkpoint['d_optimizer'])\n","                    g_scheduler.load_state_dict(checkpoint['g_scheduler']); d_scheduler.load_state_dict(checkpoint['d_scheduler'])\n","                    start_epoch = checkpoint['epoch'] + 1; best_val_loss = checkpoint.get('best_val_loss', float('inf'))\n","                    train_g_losses = checkpoint.get('train_g_losses', []); train_d_losses = checkpoint.get('train_d_losses', [])\n","                    val_g_losses = checkpoint.get('val_g_losses', []); val_d_losses = checkpoint.get('val_d_losses', [])\n","                    checkpoint_loaded = True; print(\"✅ FULL CHECKPOINT LOADED SUCCESSFULLY!\"); break\n","                except Exception as e: print(f\"⚠️  Failed to load checkpoint from {checkpoint_path}: {e}\"); continue\n","\n","if not checkpoint_loaded and not models_loaded:\n","    if RESUME_TRAINING: print(\"⚠️  NO CHECKPOINT OR MODELS FOUND - Starting from scratch\")\n","    else: print(\"🆕 STARTING FRESH TRAINING\")\n","\n","# Training Loop\n","for epoch in range(start_epoch, num_epochs):\n","    print(f\"Epoch {epoch+1}/{num_epochs}\")\n","    edge_generator.train(); coarse_generator.train(); fine_generator.train(); discriminator.train()\n","    epoch_g_loss = epoch_d_loss = epoch_edge_loss = num_batches = 0\n","   \n","    for step, images in enumerate(train_loader):\n","        g_loss_batch, d_loss_batch, edge_loss_batch = train_step(images, edge_generator, coarse_generator, fine_generator, discriminator, edge_optimizer, g_optimizer, d_optimizer, scaler)\n","        epoch_g_loss += g_loss_batch; epoch_edge_loss += edge_loss_batch; epoch_d_loss += d_loss_batch; num_batches += 1\n","        \n","        if step % 50 == 0:\n","            print(f\" Step {step:3d} [E+G+D]: Edge_Loss: {edge_loss_batch:.4f}, G_Loss: {g_loss_batch:.4f}, D_Loss: {d_loss_batch:.4f} | LR: E={edge_optimizer.param_groups[0]['lr']:.6f}, G={g_optimizer.param_groups[0]['lr']:.6f}, D={d_optimizer.param_groups[0]['lr']:.6f}\")\n","            \n","        if np.isnan(g_loss_batch) and np.isnan(d_loss_batch):\n","            print(f\"⚠️ CRITICAL: Both losses are NaN at step {step}. Stopping epoch early.\"); break\n","   \n","    avg_g_loss = epoch_g_loss / num_batches if num_batches > 0 else 0\n","    avg_d_loss = epoch_d_loss / num_batches if num_batches > 0 else 0\n","    avg_edge_loss = epoch_edge_loss / num_batches if num_batches > 0 else 0\n","    train_g_losses.append(avg_g_loss); train_d_losses.append(avg_d_loss)\n","    print(f\"Epoch {epoch+1} Training - Edge_Loss: {avg_edge_loss:.4f}, G_Loss: {avg_g_loss:.4f}, D_Loss: {avg_d_loss:.4f}\")\n","   \n","    if 'MTCNN' in globals(): USE_MTCNN = True\n","    if epoch % 10 == 0:\n","        sample_images = next(iter(train_loader)).to(device); sample_masks = generate_adaptive_mask(sample_images)\n","        sample_masked = sample_images * sample_masks\n","        features = coarse_generator.preprocessor(sample_masked); sample_graph = coarse_generator.preprocessor.build_graph(features)\n","        pruned_graph = prune_graph(coarse_generator, sample_graph)\n","        for _ in range(5): retrain_loss = retrain(coarse_generator, pruned_graph, g_optimizer)\n","   \n","    edge_generator.eval(); coarse_generator.eval(); fine_generator.eval(); discriminator.eval()\n","    val_g_loss = val_d_loss = val_batches = 0\n","    with torch.no_grad():\n","        for images in val_loader:\n","            images = images.to(device); masks = generate_adaptive_mask(images); masked_images = images * masks\n","            edge_map = edge_generator(masked_images, masks)\n","            coarse_output, mu, logvar = coarse_generator(masked_images, masks, edge_map)\n","            if coarse_output.shape != images.shape: coarse_output = F.interpolate(coarse_output, size=images.shape[2:], mode='bilinear', align_corners=False)\n","            fine_output = fine_generator(masked_images, coarse_output, masks, edge_map)\n","            if fine_output.shape != images.shape: fine_output = F.interpolate(fine_output, size=images.shape[2:], mode='bilinear', align_corners=False)\n","            blend_masks = make_blend_mask(masks); combined_input = images * blend_masks + fine_output * (1.0 - blend_masks)\