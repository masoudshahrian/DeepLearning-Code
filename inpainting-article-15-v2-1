 as plt\n","import numpy as np\n","from skimage.metrics import peak_signal_noise_ratio as psnr\n","from skimage.metrics import structural_similarity as ssim\n","import random\n","import cv2\n","from PIL import Image\n","from torch import amp  # For mixed precision training\n","import networkx as nx  # For graph operations\n","\n","# Simplified GNN for graph processing\n","class PyramidalGNN(nn.Module):\n","    def __init__(self, in_channels, out_channels):\n","        super(PyramidalGNN, self).__init__()\n","        self.lin = nn.Linear(in_channels, out_channels)\n","        self.gate = nn.Linear(in_channels * 2, out_channels)\n","\n","    def forward(self, x, edge_index):\n","        return self.lin(x)\n","\n","# Configuration parameters\n","prune_threshold = 0.2\n","lambda_l1 = 50.0\n","n_critic = 2\n","\n","def prune_graph(model, graph, threshold=prune_threshold):\n","    deg_cent = nx.degree_centrality(graph)\n","    low_value_nodes = [n for n, score in deg_cent.items() if score < threshold]\n","    graph.remove_nodes_from(low_value_nodes)\n","    return graph\n","\n","try:\n","    from mtcnn import MTCNN\n","    USE_MTCNN = False # Disable during training to avoid NumPy conversions\n","    print(\"MTCNN imported successfully for landmark detection (disabled for training).\")\n","except ImportError:\n","    print(\"MTCNN not found. Landmark loss will be simplified.\")\n","    USE_MTCNN = False\n","\n","# ============================================================================\n","# CHECKPOINT CONFIGURATION\n","# ============================================================================\n","RESUME_TRAINING = True\n","CHECKPOINT_DIR = '/kaggle/working/checkpoints'\n","CHECKPOINT_INTERVAL = 1\n","USE_KAGGLE_INPUT = True\n","# KAGGLE_INPUT_DATASET = '/kaggle/input/image-inpainting-v1/pytorch/default/17'\n","KAGGLE_INPUT_DATASET = '/kaggle/input/models/masoudshahrian/image-inpainting-v1/pytorch/default/17'\n","LOAD_FROM_MODELS = True\n","MODELS_DIR = '/kaggle/working/models'\n","USE_BEST_MODELS = True\n","\n","print(\"=\"*70)\n","print(\"🔧 CHECKPOINT CONFIGURATION\")\n","print(\"=\"*70)\n","print(f\"📌 Resume Training: {RESUME_TRAINING}\")\n","if USE_KAGGLE_INPUT:\n","    print(f\"📥 Loading from Kaggle Dataset: {KAGGLE_INPUT_DATASET}\")\n","if LOAD_FROM_MODELS:\n","    print(f\"🗂️  Load from Models: {MODELS_DIR}\")\n","print(\"=\"*70 + \"\\n\")\n","\n","# ============================================================================\n","# TRAINING CONFIGURATION\n","# ============================================================================\n","image_size = (64, 64)\n","batch_size = 64  # Reduced slightly for deeper models\n","eval_batch_size = 1\n","num_epochs = 1\n","learning_rate_g = 0.00005\n","learning_rate_d = 0.0002\n","learning_rate_refine = 0.0001  # NEW: Refinement network LR\n","lambda_adv = 0.5\n","lambda_style = 0.05\n","lambda_fm = 0.05\n","lambda_rec = 1.0\n","lambda_identity = 0.005\n","lambda_landmark = 0.01\n","lambda_perc = 0.1\n","lambda_vae = 0.01\n","lambda_struct = 0.05\n","lambda_d_reg = 1e-4\n","lambda_attention = 0.05\n","lambda_gp = 10.0\n","lambda_edge = 0.7\n","lambda_hf = 0.5\n","lambda_gradient = 0.6\n","lambda_facial = 0.8\n","lambda_boundary = 0.3  # NEW: Boundary smoothness weight\n","lambda_refine = 0.2    # NEW: Refinement consistency weight\n","device = torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\n","print(f\"Using device: {device}\")\n","\n","def split_dataset(dataset_path, train_ratio=0.8, val_ratio=0.1, test_ratio=0.1, seed=42):\n","    random.seed(seed)\n","    np.random.seed(seed)\n","    torch.manual_seed(seed)\n","    image_files = [f for f in os.listdir(dataset_path) if f.lower().endswith(('.png', '.jpg', '.jpeg'))]\n","    random.shuffle(image_files)\n","    total_files = len(image_files)\n","    train_end = int(total_files * train_ratio)\n","    val_end = train_end + int(total_files * val_ratio)\n","    train_files, val_files, test_files = image_files[:train_end], image_files[train_end:val_end], image_files[val_end:]\n","    print(f\"Dataset split: Total={total_files}, Train={len(train_files)}, Val={len(val_files)}, Test={len(test_files)}\")\n","    return train_files, val_files, test_files\n","\n","class CelebADataset(Dataset):\n","    def __init__(self, dataset_path, file_list, image_size, augment=True):\n","        self.dataset_path = dataset_path\n","        self.file_list = file_list\n","        base_transforms = [\n","            transforms.Resize(image_size),\n","            transforms.ToTensor(),\n","            transforms.Normalize(mean=[0.5, 0.5, 0.5], std=[0.5, 0.5, 0.5])\n","        ]\n","        if augment:\n","            aug_transforms = [transforms.RandomHorizontalFlip(p=0.5), transforms.RandomRotation(10)]\n","            self.transform = transforms.Compose(aug_transforms + base_transforms)\n","        else:\n","            self.transform = transforms.Compose(base_transforms)\n","\n","    def __len__(self): return len(self.file_list)\n","    def __getitem__(self, idx):\n","        img_path = os.path.join(self.dataset_path, self.file_list[idx])\n","        image = Image.open(img_path).convert('RGB')\n","        return self.transform(image)\n","\n","def create_split_datasets(dataset_path, train_files, val_files, test_files, image_size, batch_size):\n","    train_dataset = CelebADataset(dataset_path, train_files, image_size, augment=True)\n","    val_dataset = CelebADataset(dataset_path, val_files, image_size, augment=False)\n","    test_dataset = CelebADataset(dataset_path, test_files, image_size, augment=False)\n","    train_loader = DataLoader(train_dataset, batch_size=batch_size, shuffle=True, num_workers=2, pin_memory=True)\n","    val_loader = DataLoader(val_dataset, batch_size=batch_size, shuffle=False, num_workers=2, pin_memory=True)\n","    test_loader = DataLoader(test_dataset, batch_size=eval_batch_size, shuffle=False, num_workers=2, pin_memory=True)\n","    return train_loader, val_loader, test_loader\n","\n","\n","# ============================================================================\n","# NEW: Residual Blocks for Deeper Generators\n","# ============================================================================\n","class ResidualBlock(nn.Module):\n","    def __init__(self, channels, dilation=1):\n","        super().__init__()\n","        padding = dilation\n","        self.conv1 = nn.Conv2d(channels, channels, kernel_size=3, padding=padding, dilation=dilation)\n","        self.conv2 = nn.Conv2d(channels, channels, kernel_size=3, padding=padding, dilation=dilation)\n","\n","    def forward(self, x):\n","        residual = x\n","        out = F.leaky_relu(self.conv1(x), 0.2)\n","        out = self.conv2(out)\n","        return F.leaky_relu(out + residual, 0.2)\n","\n","class DilatedResidualBlock(nn.Module):\n","    def __init__(self, channels):\n","        super().__init__()\n","        self.conv1 = nn.Conv2d(channels, channels, kernel_size=3, padding=1, dilation=1)\n","        self.conv2 = nn.Conv2d(channels, channels, kernel_size=3, padding=2, dilation=2)\n","        self.conv3 = nn.Conv2d(channels, channels, kernel_size=3, padding=4, dilation=4)\n","        self.fusion = nn.Conv2d(channels * 3, channels, kernel_size=1)\n","\n","    def forward(self, x):\n","        out1 = F.leaky_relu(self.conv1(x), 0.2)\n","        out2 = F.leaky_relu(self.conv2(x), 0.2)\n","        out3 = F.leaky_relu(self.conv3(x), 0.2)\n","        fused = self.fusion(torch.cat([out1, out2, out3], dim=1))\n","        return F.leaky_relu(fused + x, 0.2)\n","\n","class ChannelAttention(nn.Module):\n","    def __init__(self, channels, reduction=8):\n","        super().__init__()\n","        self.avg_pool = nn.AdaptiveAvgPool2d(1)\n","        self.fc = nn.Sequential(\n","            nn.Linear(channels, channels // reduction, bias=False),\n","            nn.ReLU(inplace=True),\n","            nn.Linear(channels // reduction, channels, bias=False),\n","            nn.Sigmoid()\n","        )\n","\n","    def forward(self, x):\n","        B, C, _, _ = x.shape\n","        y = self.avg_pool(x).view(B, C)\n","        y = self.fc(y).view(B, C, 1, 1)\n","        return x * y.expand_as(x)\n","\n","\n","# ============================================================================\n","# ViTPreprocessor (kept mostly same)\n","# ============================================================================\n","class ViTPreprocessor(nn.Module):\n","    def __init__(self, dim=128, num_heads=8, patch_size=8, num_layers=3):\n","        super().__init__()\n","        self.patch_size = patch_size\n","        self.dim = dim\n","        self.num_heads = num_heads\n","        self.num_patches = (image_size[0] // patch_size) * (image_size[1] // patch_size)\n","        self.patch_embed = nn.Conv2d(3, dim, kernel_size=patch_size, stride=patch_size, padding=0)\n","        self.pos_embed = nn.Parameter(torch.zeros(1, self.num_patches, dim))\n","        self.attention_blocks = nn.ModuleList([\n","            nn.ModuleDict({\n","                'attn': nn.MultiheadAttention(embed_dim=dim, num_heads=num_heads, dropout=0.1, batch_first=True),\n","                'norm1': nn.LayerNorm(dim, eps=1e-6),\n","                'norm2': nn.LayerNorm(dim, eps=1e-6),\n","                'mlp': nn.Sequential(nn.Linear(dim, dim * 4), nn.GELU(), nn.Dropout(0.1), nn.Linear(dim * 4, dim), nn.Dropout(0.1))\n","            }) for _ in range(num_layers)\n","        ])\n","        self.final_norm = nn.LayerNorm(dim, eps=1e-6)\n","        self.gnn = PyramidalGNN(dim, dim)\n","\n","    def build_graph(self, features):\n","        B, C, H, W = features.shape\n","        nodes = features.view(B, C, -1).permute(0, 2, 1)\n","        G = nx.Graph()\n","        for i in range(nodes.shape[1]):\n","            G.add_node(i, feat=nodes[0, i])\n","        for i in range(nodes.shape[1]):\n","            for j in range(i+1, nodes.shape[1]):\n","                sim = F.cosine_similarity(nodes[0, i:i+1], nodes[0, j:j+1])\n","                if sim > 0.5:\n","                    G.add_edge(i, j, weight=sim)\n","        return G\n","\n","    def graph_enhanced_forward(self, x, graph):\n","        node_list = list(graph.nodes)\n","        if not node_list: return x\n","        for node in graph.nodes:\n","            neighbors = list(graph.neighbors(node))\n","            if neighbors:\n","                neighbor_feats = torch.stack([graph.nodes[n]['feat'] for n in neighbors])\n","                graph.nodes[node]['feat'] = (graph.nodes[node]['feat'] + torch.mean(neighbor_feats, dim=0)) / 2\n","        final_nodes = list(graph.nodes)\n","        if not final_nodes: return x\n","        return torch.stack([graph.nodes[n]['feat'] for n in sorted(final_nodes)])\n","\n","    def reconstruct_features(self, pruned_feats, pruned_indices, B, C, H, W):\n","        num_patches = H * W\n","        full_feats = torch.zeros(B, num_patches, C, device=pruned_feats.device, dtype=pruned_feats.dtype)\n","        full_feats[:, pruned_indices] = pruned_feats\n","        return full_feats.reshape(B, H, W, C).permute(0, 3, 1, 2)\n","\n","    def forward(self, x):\n","        embedded = self.patch_embed(x)\n","        B, C, H, W = embedded.shape\n","        flat = embedded.permute(0, 2, 3, 1).reshape(B, H * W, C)\n","        num_patches = H * W\n","        if num_patches != self.num_patches:\n","            pos_embed_adaptive = F.interpolate(self.pos_embed.permute(0, 2, 1), size=num_patches, mode='linear', align_corners=False).permute(0, 2, 1)\n","        else:\n","            pos_embed_adaptive = self.pos_embed\n","        flat = flat + pos_embed_adaptive\n","\n","        graph = self.build_graph(embedded)\n","        pruned_graph = prune_graph(self, graph)\n","        pruned_indices = list(pruned_graph.nodes)\n","        if pruned_indices:\n","            pruned_feats = torch.stack([pruned_graph.nodes[i]['feat'] for i in pruned_indices])\n","        else:\n","            pruned_feats = flat[0].clone()\n","            pruned_indices = list(range(flat.shape[1]))\n","\n","        for block in self.attention_blocks:\n","            attn_out, _ = block['attn'](pruned_feats, pruned_feats, pruned_feats)\n","            pruned_feats = block['norm1'](pruned_feats + attn_out)\n","            mlp_out = block['mlp'](pruned_feats)\n","            pruned_feats = block['norm2'](pruned_feats + mlp_out)\n","\n","        enhanced_pruned = self.graph_enhanced_forward(pruned_feats, pruned_graph)\n","        x = self.reconstruct_features(enhanced_pruned, pruned_indices, B, C, H, W)\n","        return self.final_norm(x.view(B, C, -1).permute(0, 2, 1)).permute(0, 2, 1).view(B, C, H, W)\n","\n","\n","class VAESampling(nn.Module):\n","    def __init__(self): super().__init__()\n","    def forward(self, mu, logvar): return mu + torch.exp(0.5 * logvar) * torch.randn_like(torch.exp(0.5 * logvar))\n","\n","\n","# ============================================================================\n","# ENHANCED VAE Encoder & Decoder\n","# ============================================================================\n","class VAEEncoder(nn.Module):\n","    def __init__(self, latent_dim=256):  # Increased from 128\n","        super().__init__()\n","        self.conv1 = nn.Conv2d(128, 128, kernel_size=4, stride=2, padding=1)\n","        self.res1 = nn.Sequential(ResidualBlock(128), ResidualBlock(128))\n","        self.conv2 = nn.Conv2d(128, 256, kernel_size=4, stride=2, padding=1)\n","        self.res2 = nn.Sequential(ResidualBlock(256), ResidualBlock(256))\n","        self.dilated_res = DilatedResidualBlock(256)\n","        self.adaptive_pool = nn.AdaptiveAvgPool2d((2, 2))\n","        self.flatten = nn.Flatten()\n","        self.fc_mu = nn.Linear(256 * 2 * 2, latent_dim)\n","        self.fc_logvar = nn.Linear(256 * 2 * 2, latent_dim)\n","\n","    def forward(self, x):\n","        B, C, H, W = x.shape\n","        if H < 4 or W < 4: x = F.adaptive_avg_pool2d(x, (8, 8))\n","        x = F.leaky_relu(self.conv1(x), 0.2)\n","        x = self.res1(x)\n","        x = F.leaky_relu(self.conv2(x), 0.2)\n","        x = self.res2(x)\n","        x = self.dilated_res(x)\n","        x = self.adaptive_pool(x)\n","        x = self.flatten(x)\n","        return self.fc_mu(x), self.fc_logvar(x)\n","\n","class VAEDecoder(nn.Module):\n","    def __init__(self, latent_dim=256):  # Increased from 128\n","        super().__init__()\n","        self.fc = nn.Linear(latent_dim, 8 * 8 * 256)\n","        self.res_bottleneck = nn.Sequential(ResidualBlock(256), ResidualBlock(256), DilatedResidualBlock(256))\n","        self.deconv1 = nn.ConvTranspose2d(256, 128, kernel_size=4, stride=2, padding=1)\n","        self.res_dec1 = nn.Sequential(ResidualBlock(128), ResidualBlock(128))\n","        self.deconv2 = nn.ConvTranspose2d(128, 64, kernel_size=4, stride=2, padding=1)\n","        self.res_dec2 = nn.Sequential(ResidualBlock(64), ResidualBlock(64))\n","        self.deconv3 = nn.ConvTranspose2d(64, 32, kernel_size=4, stride=2, padding=1)\n","        self.res_dec3 = nn.Sequential(ResidualBlock(32), ResidualBlock(32))\n","        self.final_conv = nn.Conv2d(32, 3, kernel_size=3, stride=1, padding=1)\n","\n","    def forward(self, z):\n","        x = F.leaky_relu(self.fc(z), 0.2).view(-1, 256, 8, 8)\n","        x = self.res_bottleneck(x)\n","        x = self.res_dec1(F.leaky_relu(self.deconv1(x), 0.2))\n","        x = self.res_dec2(F.leaky_relu(self.deconv2(x), 0.2))\n","        x = self.res_dec3(F.leaky_relu(self.deconv3(x), 0.2))\n","        return torch.tanh(self.final_conv(x))\n","\n","\n","# ============================================================================\n","# Edge Detection and Enhanced Edge Generator\n","# ============================================================================\n","class EdgeDetector(nn.Module):\n","    def __init__(self):\n","        super().__init__()\n","        sobel_x = torch.tensor([[-1, 0, 1], [-2, 0, 2], [-1, 0, 1]], dtype=torch.float32).unsqueeze(0).unsqueeze(0)\n","        sobel_y = torch.tensor([[-1, -2, -1], [0, 0, 0], [1, 2, 1]], dtype=torch.float32).unsqueeze(0).unsqueeze(0)\n","        self.register_buffer('sobel_x', sobel_x.repeat(3, 1, 1, 1))\n","        self.register_buffer('sobel_y', sobel_y.repeat(3, 1, 1, 1))\n","\n","    def forward(self, x):\n","        edge_x = F.conv2d(x, self.sobel_x, padding=1, groups=3)\n","        edge_y = F.conv2d(x, self.sobel_y, padding=1, groups=3)\n","        return torch.sqrt(edge_x ** 2 + edge_y ** 2 + 1e-8)\n","\n","class EdgeGenerator(nn.Module):\n","    def __init__(self):\n","        super().__init__()\n","        self.enc1 = nn.Sequential(nn.Conv2d(6, 64, kernel_size=4, stride=2, padding=1), nn.LeakyReLU(0.2, inplace=True), ResidualBlock(64), ResidualBlock(64))\n","        self.enc2 = nn.Sequential(nn.Conv2d(64, 128, kernel_size=4, stride=2, padding=1), nn.LeakyReLU(0.2, inplace=True), ResidualBlock(128), ResidualBlock(128))\n","        self.enc3 = nn.Sequential(nn.Conv2d(128, 256, kernel_size=4, stride=2, padding=1), nn.LeakyReLU(0.2, inplace=True), ResidualBlock(256), ResidualBlock(256))\n","        self.bottleneck_conv = nn.Conv2d(256, 512, kernel_size=4, stride=2, padding=1)\n","        self.bottleneck_res = nn.Sequential(DilatedResidualBlock(512), DilatedResidualBlock(512))\n","        self.attention = nn.MultiheadAttention(embed_dim=512, num_heads=8, dropout=0.1, batch_first=True)\n","        self.attention_norm = nn.LayerNorm(512, eps=1e-6)\n","        self.channel_attn = ChannelAttention(512)\n","        self.dec3_up = nn.ConvTranspose2d(512, 256, kernel_size=4, stride=2, padding=1)\n","        self.dec3_reduce = nn.Conv2d(512, 256, kernel_size=1)\n","        self.dec3_res = nn.Sequential(ResidualBlock(256), ResidualBlock(256))\n","        self.dec2_up = nn.ConvTranspose2d(256, 128, kernel_size=4, stride=2, padding=1)\n","        self.dec2_reduce = nn.Conv2d(256, 128, kernel_size=1)\n","        self.dec2_res = nn.Sequential(ResidualBlock(128), ResidualBlock(128))\n","        self.dec1_up = nn.ConvTranspose2d(128, 64, kernel_size=4, stride=2, padding=1)\n","        self.dec1_reduce = nn.Conv2d(128, 64, kernel_size=1)\n","        self.dec1_res = nn.Sequential(ResidualBlock(64), ResidualBlock(64))\n","        self.final_up = nn.ConvTranspose2d(64, 3, kernel_size=4, stride=2, padding=1)\n","\n","    def forward(self, masked_image, mask):\n","        x = torch.cat([masked_image, mask], dim=1)\n","        enc1_out = self.enc1(x)\n","        enc2_out = self.enc2(enc1_out)\n","        enc3_out = self.enc3(enc2_out)\n","        bottleneck = F.leaky_relu(self.bottleneck_conv(enc3_out), 0.2)\n","        bottleneck = self.bottleneck_res(bottleneck)\n","        B, C, H, W = bottleneck.shape\n","        attn_input = bottleneck.permute(0, 2, 3, 1).reshape(B, H * W, C)\n","        attn_output, _ = self.attention(attn_input, attn_input, attn_input)\n","        enhanced = self.attention_norm(attn_input + attn_output).reshape(B, H, W, C).permute(0, 3, 1, 2)\n","        enhanced = self.channel_attn(enhanced)\n","        \n","        dec3 = self.dec3_res(self.dec3_reduce(torch.cat([F.leaky_relu(self.dec3_up(enhanced), 0.2), enc3_out], dim=1)))\n","        dec2 = self.dec2_res(self.dec2_reduce(torch.cat([F.leaky_relu(self.dec2_up(dec3), 0.2), enc2_out], dim=1)))\n","        dec1 = self.dec1_res(self.dec1_reduce(torch.cat([F.leaky_relu(self.dec1_up(dec2), 0.2), enc1_out], dim=1)))\n","        return torch.sigmoid(self.final_up(dec1))\n","\n","\n","# ============================================================================\n","# ENHANCED CoarseGenerator \n","# ============================================================================\n","class CoarseGenerator(nn.Module):\n","    def __init__(self):\n","        super().__init__()\n","        self.preprocessor = ViTPreprocessor(dim=128, num_heads=8, patch_size=8, num_layers=3)\n","        self.encoder = VAEEncoder(latent_dim=256)\n","        self.sampling = VAESampling()\n","        self.decoder = VAEDecoder(latent_dim=256)\n","        self.attention = nn.MultiheadAttention(embed_dim=128, num_heads=8, dropout=0.1, batch_first=True)\n","        self.attention_norm = nn.LayerNorm(128, eps=1e-6)\n","        self.channel_attn = ChannelAttention(128)\n","        self.skip_conv = nn.Conv2d(128, 128, kernel_size=1, padding=0)\n","        self.pre_encode_res = nn.Sequential(ResidualBlock(128), ResidualBlock(128), DilatedResidualBlock(128))\n","\n","    def forward(self, x, mask, edge_map=None):\n","        if edge_map is not None: x = x + edge_map * 0.1\n","        original_features = self.preprocessor(x)\n","        B, C, H, W = original_features.shape\n","        attn_input = original_features.permute(0, 2, 3, 1).reshape(B, H * W, C)\n","        attn_output, _ = self.attention(attn_input, attn_input, attn_input)\n","        enhanced_features = self.attention_norm(attn_input + attn_output).reshape(B, H, W, C).permute(0, 3, 1, 2)\n","        enhanced_features = self.channel_attn(enhanced_features)\n","        enhanced_features = enhanced_features + self.skip_conv(original_features)\n","        enhanced_features = self.pre_encode_res(enhanced_features)\n","        mu, logvar = self.encoder(enhanced_features)\n","        z = self.sampling(mu, logvar)\n","        output = self.decoder(z)\n","        return output, mu, logvar\n","\n","\n","# ============================================================================\n","# ENHANCED FineGenerator with 4-Level Deep U-Net\n","# ============================================================================\n","class FineGenerator(nn.Module):\n","    def __init__(self):\n","        super().__init__()\n","        self.enc1 = nn.Sequential(nn.Conv2d(9, 64, kernel_size=4, stride=2, padding=1), nn.LeakyReLU(0.2, inplace=True), ResidualBlock(64), ResidualBlock(64))\n","        self.enc2 = nn.Sequential(nn.Conv2d(64, 128, kernel_size=4, stride=2, padding=1), nn.LeakyReLU(0.2, inplace=True), ResidualBlock(128), ResidualBlock(128))\n","        self.enc3 = nn.Sequential(nn.Conv2d(128, 256, kernel_size=4, stride=2, padding=1), nn.LeakyReLU(0.2, inplace=True), ResidualBlock(256), ResidualBlock(256))\n","        self.enc4 = nn.Sequential(nn.Conv2d(256, 512, kernel_size=4, stride=2, padding=1), nn.LeakyReLU(0.2, inplace=True), DilatedResidualBlock(512), DilatedResidualBlock(512))\n","        \n","        self.bottleneck_conv = nn.Conv2d(512, 512, kernel_size=3, stride=1, padding=1)\n","        self.bottleneck_res = nn.Sequential(DilatedResidualBlock(512), ResidualBlock(512))\n","        self.attention = nn.MultiheadAttention(embed_dim=512, num_heads=8, dropout=0.1, batch_first=True)\n","        self.attention_norm = nn.LayerNorm(512, eps=1e-6)\n","        self.channel_attn = ChannelAttention(512)\n","\n","        self.dec4_up = nn.ConvTranspose2d(512, 256, kernel_size=4, stride=2, padding=1)\n","        self.dec4_reduce = nn.Conv2d(512, 256, kernel_size=1)\n","        self.dec4_res = nn.Sequential(ResidualBlock(256), ResidualBlock(256))\n","        self.dec3_up = nn.ConvTranspose2d(256, 128, kernel_size=4, stride=2, padding=1)\n","        self.dec3_reduce = nn.Conv2d(256, 128, kernel_size=1)\n","        self.dec3_res = nn.Sequential(ResidualBlock(128), ResidualBlock(128))\n","        self.dec2_up = nn.ConvTranspose2d(128, 64, kernel_size=4, stride=2, padding=1)\n","        self.dec2_reduce = nn.Conv2d(128, 64, kernel_size=1)\n","        self.dec2_res = nn.Sequential(ResidualBlock(64), ResidualBlock(64))\n","        self.dec1_up = nn.ConvTranspose2d(64, 32, kernel_size=4, stride=2, padding=1)\n","        self.dec1_res = nn.Sequential(ResidualBlock(32), ResidualBlock(32))\n","        self.final_conv = nn.Conv2d(32, 3, kernel_size=3, stride=1, padding=1)\n","\n","    def forward(self, masked_images, coarse_output, masks, edge_map=None):\n","        if masked_images.shape[2:] != coarse_output.shape[2:]:\n","            coarse_output = F.interpolate(coarse_output, size=masked_images.shape[2:], mode='bilinear', align_corners=False)\n","        if edge_map is not None:\n","            if edge_map.shape[2:] != masked_images.shape[2:]:\n","                edge_map = F.interpolate(edge_map, size=masked_images.shape[2:], mode='bilinear', align_corners=False)\n","            x = torch.cat([masked_images, coarse_output, edge_map], dim=1)\n","        else:\n","            x = torch.cat([masked_images, coarse_output, torch.zeros_like(masked_images)], dim=1)\n","\n","        enc1_out = self.enc1(x)\n","        enc2_out = self.enc2(enc1_out)\n","        enc3_out = self.enc3(enc2_out)\n","        enc4_out = self.enc4(enc3_out)\n","        \n","        bottleneck = self.bottleneck_res(F.leaky_relu(self.bottleneck_conv(enc4_out), 0.2))\n","        B, C, H, W = bottleneck.shape\n","        attn_input = bottleneck.permute(0, 2, 3, 1).reshape(B, H * W, C)\n","        attn_output, _ = self.attention(attn_input, attn_input, attn_input)\n","        enhanced = self.channel_attn(self.attention_norm(attn_input + attn_output).reshape(B, H, W, C).permute(0, 3, 1, 2))\n","\n","        dec4 = self.dec4_res(self.dec4_reduce(torch.cat([F.leaky_relu(self.dec4_up(enhanced), 0.2), enc3_out], dim=1)))\n","        dec3 = self.dec3_res(self.dec3_reduce(torch.cat([F.leaky_relu(self.dec3_up(dec4), 0.2), enc2_out], dim=1)))\n","        dec2 = self.dec2_res(self.dec2_reduce(torch.cat([F.leaky_relu(self.dec2_up(dec3), 0.2), enc1_out], dim=1)))\n","        dec1 = self.dec1_res(F.leaky_relu(self.dec1_up(dec2), 0.2))\n","        \n","        output = torch.tanh(self.final_conv(dec1))\n","        if output.shape[2:] != masked_images.shape[2:]:\n","            output = F.interpolate(output, size=masked_images.shape[2:], mode='bilinear', align_corners=False)\n","        return output\n","\n","\n","# ============================================================================\n","# NEW: Refinement Network for Smooth Reconstruction\n","# ============================================================================\n","class RefinementNetwork(nn.Module):\n","    def __init__(self):\n","        super().__init__()\n","        self.encoder = nn.Sequential(\n","            nn.Conv2d(4, 64, kernel_size=3, stride=1, padding=1), nn.LeakyReLU(0.2, inplace=True),\n","            ResidualBlock(64), ResidualBlock(64),\n","        )\n","        self.dilated_processing = nn.Sequential(\n","            DilatedResidualBlock(64), ResidualBlock(64, dilation=8), \n","            ResidualBlock(64, dilation=16), DilatedResidualBlock(64), \n","            ResidualBlock(64), ResidualBlock(64),\n","        )\n","        self.channel_attn = ChannelAttention(64)\n","        self.decoder = nn.Sequential(\n","            nn.Conv2d(64, 32, kernel_size=3, stride=1, padding=1), nn.LeakyReLU(0.2, inplace=True),\n","            ResidualBlock(32),\n","            nn.Conv2d(32, 3, kernel_size=3, stride=1, padding=1),\n","        )\n","\n","    def forward(self, image, mask):\n","        mask_1ch = mask[:, :1, :, :]\n","        x = torch.cat([image, mask_1ch], dim=1)\n","        enc = self.encoder(x)\n","        processed = self.dilated_processing(enc)\n","        processed = self.channel_attn(processed)\n","        residual = self.decoder(processed)\n","        refined = image + residual * (1.0 - mask_1ch)\n","        return torch.clamp(refined, -1.0, 1.0)\n","\n","\n","# ============================================================================\n","# Discriminator \n","# ============================================================================\n","class Discriminator(nn.Module):\n","    def __init__(self):\n","        super().__init__()\n","        self.conv1 = nn.utils.spectral_norm(nn.Conv2d(6, 64, kernel_size=4, stride=2, padding=1))\n","        self.conv2 = nn.utils.spectral_norm(nn.Conv2d(64, 128, kernel_size=4, stride=2, padding=1))\n","        self.conv3 = nn.utils.spectral_norm(nn.Conv2d(128, 256, kernel_size=4, stride=2, padding=1))\n","        self.conv4 = nn.utils.spectral_norm(nn.Conv2d(256, 512, kernel_size=4, stride=2, padding=1))\n","        self.conv5 = nn.utils.spectral_norm(nn.Conv2d(512, 512, kernel_size=3, stride=1, padding=1))\n","        self.conv6 = nn.utils.spectral_norm(nn.Conv2d(512, 512, kernel_size=3, stride=1, padding=1))\n","        self.conv_out = nn.utils.spectral_norm(nn.Conv2d(512, 1, kernel_size=1, stride=1, padding=0))\n","        self.feature_layers = [self.conv1, self.conv2, self.conv3, self.conv4, self.conv5, self.conv6]\n","\n","    def forward(self, x, mask, return_features=False):\n","        input_concat = torch.cat([x, mask], dim=1)\n","        features = []\n","        x = F.leaky_relu(self.conv1(input_concat), 0.2, inplace=True)\n","        if return_features: features.append(x)\n","        x = F.leaky_relu(self.conv2(x), 0.2, inplace=True)\n","        if return_features: features.append(x)\n","        x = F.leaky_relu(self.conv3(x), 0.2, inplace=True)\n","        if return_features: features.append(x)\n","        x = F.leaky_relu(self.conv4(x), 0.2, inplace=True)\n","        if return_features: features.append(x)\n","        x = F.leaky_relu(self.conv5(x), 0.2, inplace=True)\n","        if return_features: features.append(x)\n","        x = F.leaky_relu(self.conv6(x), 0.2, inplace=True)\n","        if return_features: features.append(x)\n","        logits = self.conv_out(x)\n","        if return_features: return logits, features\n","        return logits\n","\n","\n","# ============================================================================\n","# ENHANCED Blend Mask with Gaussian-like Smooth Transition\n","# ============================================================================\n","def make_blend_mask(mask, radius=10, num_passes=3):\n","    if radius is None or radius <= 0: return mask\n","    if mask.dim() != 4: return mask\n","    m = (mask[:, :1] > 0.5).float()\n","    for _ in range(num_passes):\n","        k = int(radius) * 2 + 1\n","        m = F.avg_pool2d(m, kernel_size=k, stride=1, padding=int(radius))\n","        m = torch.clamp(m, 0.0, 1.0)\n","    original_mask = (mask[:, :1] > 0.5).float()\n","    m = m * original_mask\n","    boundary_width = max(3, radius // 2)\n","    eroded = -F.max_pool2d(-m, kernel_size=boundary_width*2+1, stride=1, padding=boundary_width)\n","    smooth_mask = m * 0.7 + eroded * 0.3\n","    if mask.shape[1] != 1: smooth_mask = smooth_mask.repeat(1, mask.shape[1], 1, 1)\n","    return smooth_mask\n","\n","def generate_adaptive_mask(image):\n","    batch_size = image.shape[0]\n","    h, w = image_size\n","    half_height = h // 2\n","    jitter = 4\n","    cuts = half_height + torch.randint(-jitter, jitter + 1, (batch_size,), device=image.device)\n","    cuts = torch.clamp(cuts, min=0, max=h).to(torch.long)\n","    mask = torch.zeros(batch_size, 1, h, w, dtype=torch.float32, device=image.device)\n","    for i in range(batch_size): mask[i, :, :cuts[i], :] = 1.0\n","    return mask.repeat(1, 3, 1, 1)\n","\n","\n","# ============================================================================\n","# Loss Functions\n","# ============================================================================\n","try: vgg_weights = models.VGG16_Weights.DEFAULT\n","except AttributeError: vgg_weights = None\n","vgg = models.vgg16(weights=vgg_weights).features.to(device).eval()\n","loss_model = nn.Sequential(*[vgg[i] for i in range(16)]).to(device)\n","for param in loss_model.parameters(): param.requires_grad = False\n","\n","edge_detector_global = EdgeDetector().to(device).eval()\n","for param in edge_detector_global.parameters(): param.requires_grad = False\n","\n","def perceptual_loss(y_true, y_pred):\n","    y_true = F.interpolate(y_true, size=image_size, mode='bilinear', align_corners=False) * 0.5 + 0.5\n","    y_pred = F.interpolate(y_pred, size=image_size, mode='bilinear', align_corners=False) * 0.5 + 0.5\n","    return torch.mean((loss_model(y_true) - loss_model(y_pred)) ** 2)\n","\n","def half_perceptual_loss(y_true, completion):\n","    y_true = F.interpolate(y_true, size=image_size, mode='bilinear', align_corners=False) * 0.5 + 0.5\n","    completion = F.interpolate(completion, size=image_size, mode='bilinear', align_corners=False) * 0.5 + 0.5\n","    return torch.mean((loss_model(y_true) - loss_model(completion)) ** 2)\n","\n","def style_loss(y_true, y_pred):\n","    y_true = F.interpolate(y_true, size=image_size, mode='bilinear', align_corners=False) * 0.5 + 0.5\n","    y_pred = F.interpolate(y_pred, size=image_size, mode='bilinear', align_corners=False) * 0.5 + 0.5\n","    true_features, pred_features = loss_model(y_true), loss_model(y_pred)\n","    def gram_matrix(feat):\n","        B, C, H, W = feat.shape; feat = feat.view(B, C, H * W)\n","        return torch.bmm(feat, feat.transpose(1, 2)) / (C * H * W)\n","    return torch.mean(torch.stack([torch.mean((gram_matrix(t) - gram_matrix(p)) ** 2) for t, p in zip([true_features], [pred_features])]))\n","\n","def bottom_half_loss(y_true, y_pred, mask):\n","    bottom_region = (mask == 0).float()\n","    return (y_true - y_pred).pow(2).mul(bottom_region).sum() / (bottom_region.sum() + 1e-8)\n","\n","def feature_matching_loss(real_features, fake_features):\n","    return torch.mean(torch.stack([torch.mean((r - f) ** 2) for r, f in zip(real_features, fake_features)]))\n","\n","def identity_loss(y_true, y_pred, mask):\n","    bottom_region = (mask == 0).float()\n","    return torch.mean(torch.abs(y_true * bottom_region - y_pred * bottom_region))\n","\n","def landmark_guided_loss(y_true, y_pred, mask, force_mtcnn=None):\n","    use_mtcnn = USE_MTCNN if force_mtcnn is None else force_mtcnn\n","    if not use_mtcnn: return bottom_half_loss(y_true, y_pred, mask)\n","    return bottom_half_loss(y_true, y_pred, mask)  # Simplified fallback\n","\n","def structural_ssim_loss(y_true, y_pred, mask):\n","    y_true = y_true * 0.5 + 0.5; y_pred = y_pred * 0.5 + 0.5\n","    bottom_mask = (mask == 0).float()\n","    ssim_vals = []\n","    for i in range(y_true.shape[0]):\n","        true_img = (y_true * bottom_mask)[i].permute(1, 2, 0).cpu().detach().numpy()\n","        pred_img = (y_pred * bottom_mask)[i].permute(1, 2, 0).cpu().detach().numpy()\n","        ssim_vals.append(ssim(true_img, pred_img, channel_axis=2, data_range=1.0, win_size=7))\n","    return 1.0 - torch.mean(torch.tensor(ssim_vals, device=device))\n","\n","def gradient_penalty_loss(discriminator, real_images, fake_images, masks, device):\n","    batch_size = real_images.size(0)\n","    alpha = torch.rand(batch_size, 1, 1, 1).to(device)\n","    interpolated = (alpha * real_images + (1 - alpha) * fake_images).detach().requires_grad_(True)\n","    disc_interpolated = discriminator(interpolated, masks, return_features=False)\n","    if not disc_interpolated.requires_grad: return torch.tensor(0.0, device=device, requires_grad=True)\n","    gradients = torch.autograd.grad(outputs=disc_interpolated, inputs=interpolated, grad_outputs=torch.ones_like(disc_interpolated), create_graph=True, retain_graph=True, only_inputs=True)[0]\n","    return ((gradients.view(gradients.size(0), -1).norm(2, dim=1) - 1) ** 2).mean()\n","\n","def attention_loss(y_true, y_pred, mask):\n","    bottom_region = (mask == 0).float()\n","    diff = torch.abs(y_true - y_pred) * bottom_region\n","    true_grad_x = F.pad(torch.abs(y_true[:, :, :, 1:] - y_true[:, :, :, :-1]), (0, 1, 0, 0), mode='constant', value=0)\n","    true_grad_y = F.pad(torch.abs(y_true[:, :, 1:, :] - y_true[:, :, :-1, :]), (0, 0, 0, 1), mode='constant', value=0)\n","    attention_weights = (true_grad_x + true_grad_y).mean(dim=1, keepdim=True) / ((true_grad_x + true_grad_y).mean() + 1e-8)\n","    return (diff * attention_weights).mean()\n","\n","def edge_loss(y_true, y_pred, mask, edge_detector):\n","    with torch.no_grad(): edges_true = edge_detector(y_true * 0.5 + 0.5)\n","    return (torch.abs(edges_true - edge_detector(y_pred * 0.5 + 0.5)) * (mask == 0).float()).mean()\n","\n","def high_frequency_loss(y_true, y_pred, mask):\n","    lap = torch.tensor([[0, 1, 0], [1, -4, 1], [0, 1, 0]], dtype=torch.float32, device=y_true.device).unsqueeze(0).unsqueeze(0).repeat(3, 1, 1, 1)\n","    return (torch.abs(F.conv2d(y_true, lap, padding=1, groups=3) - F.conv2d(y_pred, lap, padding=1, groups=3)) * (mask == 0).float()).mean()\n","\n","def gradient_loss(y_true, y_pred, mask):\n","    sob_x = torch.tensor([[-1, 0, 1], [-2, 0, 2], [-1, 0, 1]], dtype=torch.float32, device=y_true.device).unsqueeze(0).unsqueeze(0).repeat(3, 1, 1, 1)\n","    sob_y = torch.tensor([[-1, -2, -1], [0, 0, 0], [1, 2, 1]], dtype=torch.float32, device=y_true.device).unsqueeze(0).unsqueeze(0).repeat(3, 1, 1, 1)\n","    grad_true = torch.sqrt(F.conv2d(y_true, sob_x, padding=1, groups=3)**2 + F.conv2d(y_true, sob_y, padding=1, groups=3)**2 + 1e-8)\n","    grad_pred = torch.sqrt(F.conv2d(y_pred, sob_x, padding=1, groups=3)**2 + F.conv2d(y_pred, sob_y, padding=1, groups=3)**2 + 1e-8)\n","    return (torch.abs(grad_true - grad_pred) * (mask == 0).float()).mean()\n","\n","def facial_region_loss(y_true, y_pred, mask):\n","    B, C, H, W = y_true.shape\n","    weight_map = torch.ones_like(mask)\n","    weight_map[:, :, H//2:H, W//4:3*W//4] = 3.0\n","    return (torch.abs(y_true - y_pred) * weight_map * (mask == 0).float()).sum() / (weight_map.sum() + 1e-8)\n","\n","# NEW: Boundary Smoothness Loss\n","def boundary_smoothness_loss(y_true, y_pred, mask):\n","    mask_1ch = mask[:, :1, :, :]\n","    dilated = F.avg_pool2d(mask_1ch, 7, stride=1, padding=3)\n","    eroded = -F.max_pool2d(-mask_1ch, 7, stride=1, padding=3)\n","    boundary = torch.clamp(F.avg_pool2d(dilated - eroded, 5, stride=1, padding=2), 0, 1)\n","    color_diff = torch.abs(y_true - y_pred) * boundary.repeat(1, 3, 1, 1)\n","    \n","    grad_pred_x = F.pad(y_pred[:, :, :, 1:] - y_pred[:, :, :, :-1], (0, 1, 0, 0), mode='reflect')\n","    grad_true_x = F.pad(y_true[:, :, :, 1:] - y_true[:, :, :, :-1], (0, 1, 0, 0), mode='reflect')\n","    grad_pred_y = F.pad(y_pred[:, :, 1:, :] - y_pred[:, :, :-1, :], (0, 0, 0, 1), mode='reflect')\n","    grad_true_y = F.pad(y_true[:, :, 1:, :] - y_true[:, :, :-1, :], (0, 0, 0, 1), mode='reflect')\n","    \n","    bnd_3ch = boundary.repeat(1, 3, 1, 1)\n","    grad_diff = (torch.abs(grad_pred_x - grad_true_x) + torch.abs(grad_pred_y - grad_true_y)) * bnd_3ch\n","    return color_diff.mean() + 0.5 * grad_diff.mean()\n","\n","\n","def generator_loss(disc_fake_logits, y_true, y_pred, disc_features_real, disc_features_fake, mask, mu, logvar):\n","    logvar = torch.clamp(logvar, min=-10, max=10)\n","    nan = lambda x: torch.nan_to_num(x, nan=0.0, posinf=0.0, neginf=0.0)\n","    \n","    adv_loss = nan(-torch.mean(disc_fake_logits))\n","    l1_loss = nan(torch.mean(torch.abs(y_true - y_pred) * (mask == 0).float()))\n","    rec_loss = nan(bottom_half_loss(y_true, y_pred, mask))\n","    blend_mask = make_blend_mask(mask)\n","    completion = y_true * blend_mask + y_pred * (1.0 - blend_mask)\n","    perc_loss = nan(half_perceptual_loss(y_true, completion))\n","    sty_loss = nan(style_loss(y_true, y_pred))\n","    fm_loss = nan(feature_matching_loss(disc_features_real, disc_features_fake))\n","    id_loss = nan(identity_loss(y_true, y_pred, mask))\n","    lm_loss = nan(landmark_guided_loss(y_true, y_pred, mask))\n","    struct_loss = nan(structural_ssim_loss(y_true, y_pred, mask))\n","    att_loss = nan(attention_loss(y_true, y_pred, mask))\n","    edg_loss = nan(edge_loss(y_true, y_pred, mask, edge_detector_global))\n","    hf_loss = nan(high_frequency_loss(y_true, y_pred, mask))\n","    grad_loss = nan(gradient_loss(y_true, y_pred, mask))\n","    facial_loss = nan(facial_region_loss(y_true, y_pred, mask))\n","    bnd_loss = nan(boundary_smoothness_loss(y_true, y_pred, mask))  # NEW\n","    \n","    kl_loss = torch.clamp(nan(-0.5 * torch.mean(1 + logvar - mu**2 - torch.exp(logvar))), min=0.0, max=10.0)\n","\n","    total_loss = (lambda_adv * adv_loss + lambda_l1 * l1_loss + lambda_rec * rec_loss + lambda_perc * perc_loss +\n","                  lambda_style * sty_loss + lambda_fm * fm_loss + lambda_identity * id_loss +\n","                  lambda_landmark * lm_loss + lambda_struct * struct_loss + lambda_attention * att_loss + \n","                  lambda_vae * kl_loss + lambda_edge * edg_loss + lambda_hf * hf_loss + \n","                  lambda_gradient * grad_loss + lambda_facial * facial_loss + lambda_boundary * bnd_loss)\n","    return nan(total_loss)\n","\n","def discriminator_loss(disc_real_logits, disc_fake_logits):\n","    nan = lambda x: torch.nan_to_num(x, nan=0.0, posinf=0.0, neginf=0.0)\n","    real_loss = nan(torch.mean(F.relu(1.0 - torch.clamp(disc_real_logits, -5, 5))))\n","    fake_loss = nan(torch.mean(F.relu(1.0 + torch.clamp(disc_fake_logits, -5, 5))))\n","    reg = nan(lambda_d_reg * (torch.mean(disc_real_logits**2) + torch.mean(disc_fake_logits**2)))\n","    return nan(real_loss + fake_loss + reg)\n","\n","# Evaluation metrics\n","def calculate_psnr_bottom_half(y_true, y_pred, mask):\n","    y_true = y_true * 0.5 + 0.5; y_pred = y_pred * 0.5 + 0.5\n","    bottom_mask = (mask == 0).float()\n","    psnr_vals = []\n","    for i in range(y_true.shape[0]):\n","        psnr_vals.append(psnr((y_true * bottom_mask)[i].permute(1,2,0).cpu().numpy(), (y_pred * bottom_mask)[i].permute(1,2,0).cpu().numpy(), data_range=1.0))\n","    return torch.mean(torch.tensor(psnr_vals, device=device))\n","\n","def calculate_ssim_bottom_half(y_true, y_pred, mask):\n","    y_true = y_true * 0.5 + 0.5; y_pred = y_pred * 0.5 + 0.5\n","    bottom_mask = (mask == 0).float()\n","    ssim_vals = []\n","    for i in range(y_true.shape[0]):\n","        ssim_vals.append(ssim((y_true * bottom_mask)[i].permute(1,2,0).cpu().numpy(), (y_pred * bottom_mask)[i].permute(1,2,0).cpu().numpy(), channel_axis=2, data_range=1.0, win_size=7))\n","    return torch.mean(torch.tensor(ssim_vals, device=device))\n","\n","def calculate_mse_bottom_half(y_true, y_pred, mask): return bottom_half_loss(y_true, y_pred, mask)\n","\n","\n","# Multi-resolution & helpers\n","def multi_resolution_inpainting(image, mask, model, edge_map=None, levels=3):\n","    outputs, mus, logvars = [], [], []\n","    for level in range(levels):\n","        scaled_image = F.interpolate(image, scale_factor=1 / (2 ** level), mode='bilinear')\n","        scaled_mask = F.interpolate(mask, scale_factor=1 / (2 ** level), mode='nearest')\n","        if edge_map is not None:\n","            out, mu, logvar = model(scaled_image, scaled_mask, F.interpolate(edge_map, scale_factor=1 / (2 ** level), mode='bilinear'))\n","        else:\n","            out, mu, logvar = model(scaled_image, scaled_mask)\n","        outputs.append(F.interpolate(out, size=image.shape[-2:], mode='bilinear'))\n","        mus.append(mu); logvars.append(logvar)\n","    return torch.mean(torch.stack(outputs), dim=0), torch.mean(torch.stack(mus), dim=0), torch.mean(torch.stack(logvars), dim=0)\n","\n","def retrain(model, pruned_graph, optimizer):\n","    optimizer.zero_grad()\n","    output, _, _ = model(torch.randn(1, 3, 64, 64).to(device), torch.randn(1, 3, 64, 64).to(device))\n","    torch.mean(output).backward()\n","    optimizer.step()\n","\n","\n","# ============================================================================\n","# ENHANCED Training Step with RefinementNetwork\n","# ============================================================================\n","def train_step(images, edge_generator, coarse_generator, fine_generator, refinement_network,\n","               discriminator, edge_optimizer, g_optimizer, refine_optimizer, d_optimizer, scaler):\n","    images = images.to(device)\n","    masks = generate_adaptive_mask(images)\n","    blend_masks = make_blend_mask(masks)\n","    masked_images = images * masks\n","\n","    # Discriminator training\n","    d_optimizer.zero_grad()\n","    d_loss_accumulated = 0.0\n","    for _ in range(n_critic):\n","        with amp.autocast('cuda'):\n","            with torch.no_grad():\n","                edge_map = edge_generator(masked_images, masks)\n","                coarse_output, mu, logvar = multi_resolution_inpainting(masked_images, masks, coarse_generator, edge_map)\n","                if coarse_output.shape != images.shape: coarse_output = F.interpolate(coarse_output, size=images.shape[2:], mode='bilinear', align_corners=False)\n","                fine_output = fine_generator(masked_images, coarse_output, masks, edge_map)\n","                if fine_output.shape != images.shape: fine_output = F.interpolate(fine_output, size=images.shape[2:], mode='bilinear', align_corners=False)\n","                blended = images * blend_masks + fine_output * (1.0 - blend_masks)\n","                refined_output = refinement_network(blended, masks)\n","\n","            combined_input_detached = refined_output.detach()\n","            disc_real_logits = discriminator(images, masks, return_features=False)\n","            disc_fake_logits = discriminator(combined_input_detached, masks, return_features=False)\n","            d_loss = discriminator_loss(disc_real_logits, disc_fake_logits) + lambda_gp * gradient_penalty_loss(discriminator, images, combined_input_detached, masks, device)\n","        scaler.scale(d_loss).backward()\n","        d_loss_accumulated += d_loss.item()\n","    \n","    scaler.unscale_(d_optimizer)\n","    torch.nn.utils.clip_grad_norm_(discriminator.parameters(), max_norm=1.0)\n","    scaler.step(d_optimizer)\n","    d_loss_val = d_loss_accumulated / n_critic\n","\n","    # Generator training (Edge + Coarse + Fine + Refinement)\n","    edge_optimizer.zero_grad(); g_optimizer.zero_grad(); refine_optimizer.zero_grad()\n","    with amp.autocast('cuda'):\n","        edge_map = edge_generator(masked_images, masks)\n","        with torch.no_grad(): true_edges = edge_detector_global(images * 0.5 + 0.5)\n","        edge_recon_loss = torch.mean(torch.abs(true_edges - edge_map) * (masks == 0).float())\n","        \n","        coarse_output, mu, logvar = multi_resolution_inpainting(masked_images, masks, coarse_generator, edge_map)\n","        if coarse_output.shape != images.shape: coarse_output = F.interpolate(coarse_output, size=images.shape[2:], mode='bilinear', align_corners=False)\n","        \n","        fine_output = fine_generator(masked_images, coarse_output, masks, edge_map)\n","        if fine_output.shape != images.shape: fine_output = F.interpolate(fine_output, size=images.shape[2:], mode='bilinear', align_corners=False)\n","        \n","        blended = images * blend_masks + fine_output * (1.0 - blend_masks)\n","        refined_output = refinement_network(blended, masks)\n","\n","        disc_real_logits, disc_features_real = discriminator(images, masks, return_features=True)\n","        disc_fake_logits, disc_features_fake = discriminator(refined_output, masks, return_features=True)\n","        \n","        g_loss = generator_loss(disc_fake_logits, images, refined_output, disc_features_real, disc_features_fake, masks, mu, logvar)\n","        refine_consistency_loss = lambda_refine * torch.mean(torch.abs(refined_output - fine_output) * (masks == 0).float())\n","        \n","        total_gen_loss = edge_recon_loss + g_loss + refine_consistency_loss\n","\n","    scaler.scale(total_gen_loss).backward()\n","    scaler.unscale_(edge_optimizer); scaler.unscale_(g_optimizer); scaler.unscale_(refine_optimizer)\n","    torch.nn.utils.clip_grad_norm_(edge_generator.parameters(), max_norm=1.0)\n","    torch.nn.utils.clip_grad_norm_(list(coarse_generator.parameters()) + list(fine_generator.parameters()), max_norm=1.0)\n","    torch.nn.utils.clip_grad_norm_(refinement_network.parameters(), max_norm=1.0)\n","    scaler.step(edge_optimizer); scaler.step(g_optimizer); scaler.step(refine_optimizer)\n","    scaler.update()\n","\n","    edge_loss_val = edge_recon_loss.item()\n","    g_loss_val = g_loss.item()\n","    refine_loss_val = refine_consistency_loss.item()\n","    \n","    if np.isnan(g_loss_val) or np.isnan(d_loss_val): \n","        print(f\"⚠️ WARNING: NaN detected. G={g_loss_val}, D={d_loss_val}\")\n","        return 0.0, 0.0, 0.0, 0.0\n","    return g_loss_val, d_loss_val, edge_loss_val, refine_loss_val\n","\n","\n","# ============================================================================\n","# Load Dataset\n","# ============================================================================\n","# celeba_dir = '/kaggle/input/celeba-6464/selected_celeba'\n","celeba_dir = '/kaggle/input/datasets/masoudshahrian/celeba-6464/selected_celeba'\n","print(f\"Loading dataset from {celeba_dir}...\")\n","train_files, val_files, test_files = split_dataset(celeba_dir)\n","train_loader, val_loader, test_loader = create_split_datasets(celeba_dir, train_files, val_files, test_files, image_size, batch_size)\n","\n","\n","# ============================================================================\n","# Build Models (ENHANCED with RefinementNetwork)\n","# ============================================================================\n","print(\"\\nBuilding ENHANCED models...\")\n","print(\"🔷 Multi-Stage Architecture: Edge → Coarse → Fine → Refinement\")\n","edge_generator = EdgeGenerator().to(device)\n","coarse_generator = CoarseGenerator().to(device)\n","fine_generator = FineGenerator().to(device)\n","refinement_network = RefinementNetwork().to(device)\n","discriminator = Discriminator().to(device)\n","\n","print(f\"Edge Generator: {sum(p.numel() for p in edge_generator.parameters()):,} params\")\n","print(f\"Coarse Generator: {sum(p.numel() for p in coarse_generator.parameters()):,} params\")\n","print(f\"Fine Generator: {sum(p.numel() for p in fine_generator.parameters()):,} params\")\n","print(f\"Refinement Network: {sum(p.numel() for p in refinement_network.parameters()):,} params\")\n","print(f\"Discriminator: {sum(p.numel() for p in discriminator.parameters()):,} params\")\n","\n","# Test dimensions\n","print(\"\\nTesting model dimensions...\")\n","test_input = torch.randn(1, 3, 64, 64).to(device)\n","test_mask = torch.randn(1, 3, 64, 64).to(device)\n","with torch.no_grad():\n","    try:\n","        edge_map = edge_generator(test_input, test_mask)\n","        coarse_output, mu, logvar = coarse_generator(test_input, test_mask, edge_map)\n","        fine_output = fine_generator(test_input, coarse_output, test_mask, edge_map)\n","        refined = refinement_network(fine_output, test_mask)\n","        disc_logits, _ = discriminator(test_input, test_mask, return_features=True)\n","        print(f\"✓ Edge: {edge_map.shape}, Coarse: {coarse_output.shape}, Fine: {fine_output.shape}, Refined: {refined.shape}, Disc: {disc_logits.shape}\")\n","        print(\"✅ All model dimensions correct!\")\n","    except Exception as e:\n","        print(f\"❌ Dimension test failed: {e}\")\n","        raise\n","\n","# Optimizers & Schedulers\n","edge_optimizer = torch.optim.AdamW(edge_generator.parameters(), lr=learning_rate_g, betas=(0.5, 0.999), weight_decay=1e-4)\n","g_optimizer = torch.optim.AdamW(list(coarse_generator.parameters()) + list(fine_generator.parameters()), lr=learning_rate_g, betas=(0.5, 0.999), weight_decay=1e-4)\n","refine_optimizer = torch.optim.AdamW(refinement_network.parameters(), lr=learning_rate_refine, betas=(0.5, 0.999), weight_decay=1e-4)\n","d_optimizer = torch.optim.AdamW(discriminator.parameters(), lr=learning_rate_d, betas=(0.5, 0.999), weight_decay=1e-4)\n","\n","try:\n","    edge_scheduler = torch.optim.lr_scheduler.ReduceLROnPlateau(edge_optimizer, mode='min', factor=0.5, patience=5, verbose=True, min_lr=learning_rate_g * 0.01)\n","    g_scheduler = torch.optim.lr_scheduler.ReduceLROnPlateau(g_optimizer, mode='min', factor=0.5, patience=5, verbose=True, min_lr=learning_rate_g * 0.01)\n","    refine_scheduler = torch.optim.lr_scheduler.ReduceLROnPlateau(refine_optimizer, mode='min', factor=0.5, patience=5, verbose=True, min_lr=learning_rate_refine * 0.01)\n","    d_scheduler = torch.optim.lr_scheduler.ReduceLROnPlateau(d_optimizer, mode='min', factor=0.5, patience=5, verbose=True, min_lr=learning_rate_d * 0.01)\n","except TypeError:\n","    edge_scheduler = torch.optim.lr_scheduler.ReduceLROnPlateau(edge_optimizer, mode='min', factor=0.5, patience=5, min_lr=learning_rate_g * 0.01)\n","    g_scheduler = torch.optim.lr_scheduler.ReduceLROnPlateau(g_optimizer, mode='min', factor=0.5, patience=5, min_lr=learning_rate_g * 0.01)\n","    refine_scheduler = torch.optim.lr_scheduler.ReduceLROnPlateau(refine_optimizer, mode='min', factor=0.5, patience=5, min_lr=learning_rate_refine * 0.01)\n","    d_scheduler = torch.optim.lr_scheduler.ReduceLROnPlateau(d_optimizer, mode='min', factor=0.5, patience=5, min_lr=learning_rate_d * 0.01)\n","\n","scaler = amp.GradScaler('cuda')\n","\n","\n","# ============================================================================\n","# CHECKPOINT LOADING\n","# ============================================================================\n","if USE_KAGGLE_INPUT:\n","    models_load_dir = os.path.join(KAGGLE_INPUT_DATASET, 'models')\n","else:\n","    models_load_dir = MODELS_DIR\n","os.makedirs(CHECKPOINT_DIR, exist_ok=True); os.makedirs(MODELS_DIR, exist_ok=True)\n","\n","start_epoch = 0; best_val_loss = float('inf')\n","train_g_losses, train_d_losses, val_g_losses, val_d_losses = [], [], [], []\n","\n","if RESUME_TRAINING and LOAD_FROM_MODELS:\n","    suffix = \"_best.pth\" if USE_BEST_MODELS else \"_bottom_half.pth\"\n","    model_files = {\n","        'coarse': os.path.join(models_load_dir, f'coarse_generator{suffix}'),\n","        'fine': os.path.join(models_load_dir, f'fine_generator{suffix}'),\n","        'disc': os.path.join(models_load_dir, f'discriminator{suffix}'),\n","    }\n","    if all(os.path.exists(p) for p in model_files.values()):\n","        try:\n","            print(f\"⏳ Loading existing model weights (non-strict for enhanced architecture)...\")\n","            coarse_generator.load_state_dict(torch.load(model